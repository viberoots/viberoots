#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
workspace_root="$(cd -- "${script_dir}/.." && pwd)"
viberoots_dir="${workspace_root}/viberoots"
viberoots_source_dir="${VIBEROOTS_SOURCE_ROOT:-${viberoots_dir}}"

if [[ "${script_dir}" != "${viberoots_dir}" ]]; then
  echo "error: viberoots/init must be run from a checkout mounted at ./viberoots" >&2
  echo "expected: ${viberoots_dir}" >&2
  echo "actual:   ${script_dir}" >&2
  exit 1
fi

write_generated_file() {
  local file="$1"
  local marker="$2"
  local tmp
  tmp="$(mktemp "${file}.tmp.XXXXXX")"
  cat >"${tmp}"
  if [[ -e "${file}" ]] && ! grep -Fq "${marker}" "${file}"; then
    local backup_dir backup_name backup_file
    backup_dir=".viberoots/workspace/backups"
    mkdir -p "${backup_dir}"
    backup_name="${file//\//__}"
    backup_file="${backup_dir}/${backup_name}.$(date +%Y%m%d%H%M%S).$$.bak"
    cp -p "${file}" "${backup_file}"
    echo "repair: ${file} exists and is not generated by viberoots/init; backed up to ${backup_file}" >&2
  fi
  mv "${tmp}" "${file}"
}

write_if_missing() {
  local file="$1"
  if [[ -e "${file}" ]]; then
    echo "preserve: ${file} exists" >&2
    cat >/dev/null
    return 0
  fi
  cat >"${file}"
}

write_buckroot() {
  local file=".buckroot"
  if [[ -e "${file}" ]] && cmp -s "${file}" <(printf '.\n'); then
    return 0
  fi
  if [[ -e "${file}" ]]; then
    local backup_dir backup_name backup_file
    backup_dir=".viberoots/workspace/backups"
    mkdir -p "${backup_dir}"
    backup_name="${file//\//__}"
    backup_file="${backup_dir}/${backup_name}.$(date +%Y%m%d%H%M%S).$$.bak"
    cp -p "${file}" "${backup_file}"
    echo "repair: ${file} exists and is not canonical; backed up to ${backup_file}" >&2
  fi
  printf '.\n' >"${file}"
}

repair_workspace_buck_link() {
  local link=".viberoots/workspace/buck"
  local target="../buck"
  local real=".viberoots/buck"
  mkdir -p ".viberoots/workspace" "${real}"
  if [[ -L "${link}" ]]; then
    if [[ "$(readlink "${link}")" == "${target}" ]]; then
      return 0
    fi
    rm -f "${link}"
  elif [[ -e "${link}" ]]; then
    if [[ ! -e "${real}" ]]; then
      mv "${link}" "${real}"
    else
      rm -rf "${link}"
    fi
    echo "repair: ${link} moved outside the workspace flake root" >&2
  fi
  ln -s "${target}" "${link}"
}

repair_workspace_flake_root() {
  rm -rf ".viberoots/workspace/.viberoots"
}

repair_current_symlink() {
  local link=".viberoots/current"
  local expected="../viberoots"
  local backup_dir backup_name backup_file
  mkdir -p ".viberoots"
  if [[ -L "${link}" ]]; then
    if [[ "$(readlink "${link}")" == "${expected}" ]]; then
      return 0
    fi
    rm -f "${link}"
    ln -s "${expected}" "${link}"
    echo "repair: ${link} now points to ${expected}" >&2
    return 0
  fi
  if [[ -e "${link}" ]]; then
    backup_dir=".viberoots/workspace/backups"
    mkdir -p "${backup_dir}"
    backup_name="${link//\//__}"
    backup_file="${backup_dir}/${backup_name}.$(date +%Y%m%d%H%M%S).$$.bak"
    mv "${link}" "${backup_file}"
    echo "repair: ${link} existed and was not a symlink; moved to ${backup_file}" >&2
  fi
  ln -s "${expected}" "${link}"
}

cd "${workspace_root}"

mkdir -p projects .viberoots/workspace .viberoots/buck
repair_current_symlink
repair_workspace_buck_link
repair_workspace_flake_root
write_buckroot

write_generated_file ".buckconfig" "generated by viberoots/init" <<'EOF'
# generated by viberoots/init
[buildfile]
name = TARGETS

[repositories]
root = .
viberoots = ./.viberoots/current
prelude = ./.viberoots/current/prelude
toolchains = ./.viberoots/current/toolchains
repo_toolchains = ./.viberoots/current/toolchains
fbsource = ./.viberoots/current/config/fbsource_stub
fbcode = ./.viberoots/current/config/fbcode_stub
config = ./.viberoots/current/prelude
workspace_providers = ./.viberoots/workspace/providers
workspace_buck = ./.viberoots/workspace/buck

[cells]
root = .
viberoots = ./.viberoots/current
prelude = ./.viberoots/current/prelude
toolchains = ./.viberoots/current/toolchains
repo_toolchains = ./.viberoots/current/toolchains
fbsource = ./.viberoots/current/config/fbsource_stub
fbcode = ./.viberoots/current/config/fbcode_stub
config = ./.viberoots/current/prelude
workspace_providers = ./.viberoots/workspace/providers
workspace_buck = ./.viberoots/workspace/buck

[build]
prelude = prelude
user_platform = prelude//platforms:default
target_platforms = prelude//platforms:default

[project]
ignore = .viberoots/workspace/buck/tmp/tmpdir,.claude/worktrees,.codex/worktrees
EOF

write_generated_file ".envrc" "generated by viberoots/init" <<'EOF'
# generated by viberoots/init
if [[ "${NIX_CONFIG:-}" != *"builders ="* ]]; then
  export NIX_CONFIG=$'builders = \nbuild-hook = \nmax-jobs = auto\n'"${NIX_CONFIG:-}"
fi
if [[ "${NIX_CONFIG:-}" != *"warn-dirty = false"* ]]; then
  export NIX_CONFIG=$'warn-dirty = false\n'"${NIX_CONFIG:-}"
fi
export NODE_OPTIONS="--disable-warning=ExperimentalWarning${NODE_OPTIONS:+ $NODE_OPTIONS}"
if [[ -n "${IN_NIX_SHELL:-}" ]]; then
  return
fi

__nix_direnv_direnvrc=""
for __candidate in \
  "${HOME}/.nix-profile/share/nix-direnv/direnvrc" \
  "/nix/var/nix/profiles/default/share/nix-direnv/direnvrc"
do
  if [[ -f "${__candidate}" ]]; then
    __nix_direnv_direnvrc="${__candidate}"
    break
  fi
done

if [[ -z "${__nix_direnv_direnvrc}" ]]; then
  echo "error: nix-direnv is required for this repository shell cache path." 1>&2
  echo "install: nix profile install nixpkgs#nix-direnv" 1>&2
  echo "then run: direnv reload" 1>&2
  return 1
fi

source "${__nix_direnv_direnvrc}"
unset __nix_direnv_direnvrc
unset __candidate

if [[ "${NIX_CONFIG:-}" != *"experimental-features ="* ]]; then
  export NIX_CONFIG=$'experimental-features = nix-command flakes\n'"${NIX_CONFIG:-}"
fi
export WORKSPACE_ROOT="${PWD}"

if [[ -f "${PWD}/viberoots/build-tools/tools/bin/_env.sh" ]]; then
  source "${PWD}/viberoots/build-tools/tools/bin/_env.sh"
  env_apply_nix_cache_health
  set +u
fi

watch_file viberoots/build-tools/tools/nix/devshell.nix
watch_file viberoots/build-tools/tools/bin/_env.sh
watch_file viberoots/build-tools/tools/nix/lib/zx-wrapper.nix
watch_file viberoots/build-tools/tools/nix/flake/outputs.nix
watch_file viberoots/build-tools/tools/nix/flake/outputs-devshells.nix
watch_file .viberoots/workspace/flake.nix
watch_file .viberoots/workspace/flake.lock

use flake "path:${PWD}/.viberoots/workspace#default" --override-input viberoots "path:${VIBEROOTS_SOURCE_ROOT:-${PWD}/viberoots}"
EOF

write_generated_file ".viberoots/workspace/flake.nix" "generated by viberoots/init" <<'EOF'
# generated by viberoots/init
{
  description = "viberoots consumer workspace";

  nixConfig.allowed-impure-env-vars = [
    "BUCK_GRAPH_JSON"
    "ROOT_GOMOD2NIX_TOML"
    "BUCK_TEST_SRC"
    "BUCK_TARGET"
    "NIX_GO_DEV_OVERRIDE_JSON"
    "NIX_CPP_DEV_OVERRIDE_JSON"
    "NIX_PY_DEV_OVERRIDE_JSON"
    "NIX_PY_TEST_RESOLVE_JSON"
    "PLANNER_NO_DEV_OVERRIDE_LOG"
    "PLANNER_TRACE"
    "NIX_PNPM_ALLOW_GENERATE"
    "NIX_PNPM_FETCH_TIMEOUT"
    "NIX_NODE_TEST_PATTERNS"
    "COVERAGE"
    "WORKSPACE_ROOT"
    "VIBEROOTS_ROOT"
    "VIBEROOTS_SOURCE_ROOT"
    "TEST_RSYNC_ROOTS"
    "TEST_PARTIAL_CLONE_GO_ONLY"
    "TEST_EXCLUDE_CPP_REQS"
  ];

  inputs = {
    nixpkgs.url = "github:NixOS/nixpkgs/nixos-unstable";
    buck2.url = "github:facebook/buck2/201beb86106fecdc84e30260b0f1abb5bf576988";
    gomod2nix.url = "github:nix-community/gomod2nix";
    gomod2nix.inputs.nixpkgs.follows = "nixpkgs";
    viberoots.url = "path:__VIBEROOTS_SOURCE_ROOT__";
    viberoots.inputs.nixpkgs.follows = "nixpkgs";
    viberoots.inputs.buck2.follows = "buck2";
    viberoots.inputs.gomod2nix.follows = "gomod2nix";
  };

  outputs = inputs:
    inputs.viberoots.lib.mkWorkspace {
      workspaceSrc =
        let
          root = builtins.getEnv "WORKSPACE_ROOT";
        in
        if root != "" then builtins.toPath root else __VIBEROOTS_WORKSPACE_ROOT__;
      viberootsInput = inputs.viberoots;
      workspaceName = "viberoots-consumer";
    };
}
EOF
perl -0pi -e 's#__VIBEROOTS_WORKSPACE_ROOT__#'"${workspace_root}"'#g' ".viberoots/workspace/flake.nix"
perl -0pi -e 's#__VIBEROOTS_SOURCE_ROOT__#'"${viberoots_source_dir}"'#g' ".viberoots/workspace/flake.nix"

if [[ -f ".viberoots/workspace/flake.lock" ]]; then
  perl -0pi -e 's/"path": "\.\/viberoots"/"path": "..\/..\/viberoots"/g' \
    ".viberoots/workspace/flake.lock"
fi

write_generated_file ".viberoots/workspace/TARGETS" "generated by viberoots/init" <<'EOF'
# generated by viberoots/init
filegroup(
    name = "flake.lock",
    srcs = ["flake.lock"],
    visibility = ["PUBLIC"],
)
EOF

write_if_missing "README.md" <<'EOF'
# Workspace

This workspace is split between:

- `viberoots/`: reusable build tooling and development shell support.
- `projects/`: application and project source.

See `viberoots/README.md` and `projects/README.md`.
EOF

write_if_missing "projects/README.md" <<'EOF'
# Projects

Project and application source belongs here.
EOF

NO_DEV_SHELL=1 WORKSPACE_ROOT="${workspace_root}" "${viberoots_dir}/build-tools/tools/bin/viberoots" \
  init-workspace --source "${viberoots_dir}" >/dev/null

if command -v direnv >/dev/null 2>&1; then
  if direnv allow "${workspace_root}"; then
    echo "direnv allowed: ${workspace_root}"
  else
    echo "warning: direnv allow failed" >&2
    echo "next: cd ${workspace_root} && direnv allow && direnv reload" >&2
  fi
else
  echo "direnv is not installed or not on PATH." >&2
  echo "next: install direnv and nix-direnv, then run:" >&2
  echo "  cd ${workspace_root}" >&2
  echo "  direnv allow" >&2
  echo "  direnv reload" >&2
fi

echo "viberoots workspace initialized: ${workspace_root}"
