#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
workspace_root="$(cd -- "${script_dir}/.." && pwd)"
viberoots_dir="${workspace_root}/viberoots"
viberoots_flake_input_dir="${viberoots_dir}"
workspace_name="${workspace_root##*/}"

if [[ "${script_dir}" != "${viberoots_dir}" ]]; then
  echo "error: viberoots/init must be run from a checkout mounted at ./viberoots" >&2
  echo "expected: ${viberoots_dir}" >&2
  echo "actual:   ${script_dir}" >&2
  exit 1
fi

select_nix_bin() {
  local candidate
  if [[ -n "${VBR_NIX_BIN:-}" && -x "${VBR_NIX_BIN}" ]]; then
    printf '%s\n' "${VBR_NIX_BIN}"
    return 0
  fi
  if [[ "${VIBEROOTS_TEST_IGNORE_HOST_PROFILE_NIX:-0}" != "1" && -x "/nix/var/nix/profiles/default/bin/nix" ]]; then
    printf '%s\n' "/nix/var/nix/profiles/default/bin/nix"
    return 0
  fi
  candidate="$(command -v nix 2>/dev/null || true)"
  if [[ -n "${candidate}" ]]; then
    printf '%s\n' "${candidate}"
    return 0
  fi
  return 1
}

mkdir -p "${workspace_root}/.viberoots"
current_path="${workspace_root}/.viberoots/current"
current_target="../viberoots"
if [[ -L "${current_path}" ]]; then
  if [[ "$(readlink "${current_path}")" != "${current_target}" ]]; then
    rm -f "${current_path}"
    ln -s "${current_target}" "${current_path}"
    echo "repair: .viberoots/current now points to ${current_target}" >&2
  fi
elif [[ ! -e "${current_path}" ]]; then
  ln -s "${current_target}" "${current_path}"
else
  backup_dir="${workspace_root}/.viberoots/workspace/backups"
  mkdir -p "${backup_dir}"
  mv "${current_path}" "${backup_dir}/current.$(date +%s).$$.bak"
  ln -s "${current_target}" "${current_path}"
  echo "repair: .viberoots/current now points to ${current_target}" >&2
fi

has_workspace_name=0
for arg in "$@"; do
  case "${arg}" in
    --workspace-name | --workspace-name=*)
      has_workspace_name=1
      ;;
  esac
done

init_args=(
  init-consumer
  --mode submodule
  --workspace-root "${workspace_root}"
  --viberoots-url "path:${viberoots_flake_input_dir}"
  --source "${viberoots_dir}"
)

if [[ "${has_workspace_name}" != "1" ]]; then
  init_args+=(--workspace-name "${workspace_name}")
fi

init_args+=("$@")

nix_bin="$(select_nix_bin || true)"
if [[ -z "${nix_bin}" || ! -x "${nix_bin}" ]]; then
  echo "error: nix is required to initialize a submodule workspace before the dev shell is available" >&2
  exit 127
fi

if [[ "${VBR_INIT_USE_LOCAL_COMMAND:-0}" == "1" ]]; then
  VBR_NIX_BIN="${nix_bin}" \
    NO_DEV_SHELL=1 \
    WORKSPACE_ROOT="${workspace_root}" \
    "${viberoots_dir}/build-tools/tools/bin/viberoots" \
    "${init_args[@]}"
else
  VBR_NIX_BIN="${nix_bin}" \
    WORKSPACE_ROOT="${workspace_root}" \
    "${nix_bin}" run --accept-flake-config "path:${viberoots_flake_input_dir}#viberoots" -- \
    "${init_args[@]}"
fi
