#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
workspace_root="$(cd -- "${script_dir}/.." && pwd)"
viberoots_dir="${workspace_root}/viberoots"
viberoots_flake_input_dir="${VIBEROOTS_FLAKE_INPUT_ROOT:-${viberoots_dir}}"
workspace_name="${workspace_root##*/}"

if [[ "${script_dir}" != "${viberoots_dir}" ]]; then
  echo "error: viberoots/init must be run from a checkout mounted at ./viberoots" >&2
  echo "expected: ${viberoots_dir}" >&2
  echo "actual:   ${script_dir}" >&2
  exit 1
fi

has_workspace_name=0
for arg in "$@"; do
  case "${arg}" in
    --workspace-name | --workspace-name=*)
      has_workspace_name=1
      ;;
  esac
done

init_args=(
  init-consumer
  --mode submodule
  --workspace-root "${workspace_root}"
  --viberoots-url "path:${viberoots_flake_input_dir}"
  --source "${viberoots_dir}"
)

if [[ "${has_workspace_name}" != "1" ]]; then
  init_args+=(--workspace-name "${workspace_name}")
fi

if [[ "${VBR_POST_CLONE:-0}" == "1" || "${VIBEROOTS_POST_CLONE:-0}" == "1" ]]; then
  init_args+=(--no-lock)
fi

init_args+=("$@")

if [[ "${VBR_INIT_USE_LOCAL_COMMAND:-0}" == "1" ]]; then
  NO_DEV_SHELL=1 WORKSPACE_ROOT="${workspace_root}" "${viberoots_dir}/build-tools/tools/bin/viberoots" \
    "${init_args[@]}"
else
  nix_bin="${VBR_NIX_BIN:-nix}"
  if ! command -v "${nix_bin}" >/dev/null 2>&1; then
    echo "error: nix is required to initialize a submodule workspace before the dev shell is available" >&2
    exit 127
  fi
  WORKSPACE_ROOT="${workspace_root}" "${nix_bin}" run "path:${viberoots_flake_input_dir}#viberoots" -- \
    "${init_args[@]}"
fi
