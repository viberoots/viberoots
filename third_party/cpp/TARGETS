load("@prelude//:rules.bzl", "cxx_library")

# Local shim exposing gtest headers; used as a fallback include-only provider.
cxx_library(
    name = "gtest",
    exported_headers = {
        "gtest/gtest.h": "include/gtest/gtest.h",
    },
    exported_preprocessor_flags = ["-Ithird_party/cpp/include"],
    labels = ["lang:cpp"],
    visibility = ["PUBLIC"],
)

cxx_library(
    name = "gtest_main",
    srcs = ["src/main.cpp"],
    deps = [":gtest"],
    labels = ["lang:cpp"],
    visibility = ["PUBLIC"],
)


