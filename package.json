{
  "name": "bucknix-fresh",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:check": "tools/dev/startup-check.ts",
    "dev:clear-overrides": "tools/dev/clear-overrides.ts",
    "fmt": "prettier -w .",
    "fmt:check": "prettier -c .",
    "lint": "eslint . --ext .ts --max-warnings=0 --ignore-pattern coverage --ignore-pattern .clinic",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepare": "husky",
    "coverage:summary": "tools/dev/coverage-summary.ts",
    "coverage:build": "node tools/dev/coverage-raw-normalize.mjs && node ./node_modules/c8/bin/c8.js report --clean=false --temp-directory coverage/raw --reports-dir coverage --reporter=json-summary --reporter=lcov --reporter=html --extension .ts --allowExternal --src . --include '**/*.ts' --exclude 'node_modules/**' --exclude 'buck-out/**' --exclude '.clinic/**' --exclude '**/*.d.ts' && node tools/dev/coverage-normalize.mjs",
    "coverage:open": "pnpm coverage:build && pnpm coverage:summary --open-browser || open coverage/lcov-report/index.html",
    "test:cov": "buck2 test //... && pnpm coverage:build",
    "jio:lint": "tools/jio/lint-specs.ts",
    "gen:types": "tools/jio/schema/gen-types.ts tools/jio/schema/types.ts"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "prettier -w",
      "eslint --fix"
    ],
    "**/*.{js,mjs,cjs}": [
      "prettier -w"
    ]
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.17.4",
    "ajv": "^8.12.0",
    "json-schema-to-zod": "^2.6.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/semver": "^7.6.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "c8": "^10.1.3",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "jsonpath": "^1.1.1",
    "jsonpath-plus": "^10.3.0",
    "ajv-formats": "^3.0.1",
    "lint-staged": "^16.1.5",
    "fast-glob": "^3.3.2",
    "prettier": "^3.3.3",
    "prettier-plugin-curly": "^0.3.2",
    "semver": "^7.6.0",
    "tsx": "^4.19.1",
    "zx": "^8.0.0",
    "@sinclair/typebox": "^0.32.35",
    "zod": "^4.0.0"
  }
}
