{
  "name": "viberoots",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev:check": "zx-wrapper build-tools/tools/dev/startup-check.ts",
    "dev:clear-overrides": "build-tools/tools/dev/clear-overrides.ts",
    "fmt": "prettier -w .",
    "fmt:check": "prettier -c .",
    "fmt:write": "prettier -w",
    "lint:eslint": "eslint . --ext .ts,.tsx --max-warnings=0 --ignore-pattern buck-out --ignore-pattern coverage --ignore-pattern .clinic --ignore-pattern '**/.vite-cache/**'",
    "lint:eslint:fix": "eslint . --ext .ts,.tsx --fix --max-warnings=0 --ignore-pattern buck-out --ignore-pattern coverage --ignore-pattern .clinic --ignore-pattern '**/.vite-cache/**'",
    "lint": "pnpm -s lint:eslint && pnpm -s fmt:check",
    "lint:fix": "pnpm -s lint:eslint:fix && pnpm -s fmt",
    "prepare": "husky",
    "coverage:summary": "build-tools/tools/dev/coverage-summary.ts",
    "coverage:build": "node build-tools/tools/dev/coverage-raw-normalize.mjs && node ./node_modules/c8/bin/c8.js report --clean=false --temp-directory coverage/raw --reports-dir coverage --reporter=json-summary --reporter=lcov --reporter=html --merge-async --extension .ts --allowExternal --src . --include '**/*.ts' --exclude 'node_modules/**' --exclude 'buck-out/**' --exclude '.clinic/**' --exclude '**/*.d.ts' && node build-tools/tools/dev/coverage-normalize.mjs",
    "coverage:open": "pnpm coverage:build && pnpm coverage:summary --open-browser || open coverage/lcov-report/index.html",
    "test:cov": "buck2 test //... && pnpm coverage:build"
  },
  "lint-staged": {
    "**/*.{ts,tsx}": [
      "pnpm exec eslint --max-warnings=0 --no-warn-ignored --fix --ignore-pattern buck-out --ignore-pattern coverage --ignore-pattern .clinic --ignore-pattern '**/.vite-cache/**' --",
      "pnpm -s fmt:write --",
      "node build-tools/tools/dev/stale-names-lint.ts"
    ],
    "**/*.{bzl,nix,md}": [
      "node build-tools/tools/dev/stale-names-lint.ts"
    ],
    "**/*.{js,mjs,cjs,json,yml,yaml}": [
      "pnpm -s fmt:write --"
    ]
  },
  "devDependencies": {
    "@anthropic-ai/claude-code": "2.1.128",
    "@modelcontextprotocol/sdk": "^1.17.4",
    "@openai/codex": "0.128.0",
    "@sinclair/typebox": "^0.32.35",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@types/semver": "^7.6.0",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^3.0.1",
    "c8": "^10.1.3",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-promise": "^7.2.1",
    "fast-glob": "^3.3.2",
    "fs-extra": "^11.2.0",
    "husky": "^9.1.7",
    "json-schema-to-zod": "^2.6.0",
    "jsonpath": "^1.1.1",
    "jsonpath-plus": "^10.3.0",
    "lint-staged": "^16.1.5",
    "pg": "^8.20.0",
    "pg-mem": "^3.0.14",
    "prettier": "^3.3.3",
    "prettier-plugin-curly": "^0.3.2",
    "semver": "^7.6.0",
    "tsx": "^4.19.1",
    "wrangler": "4.17.0",
    "yaml": "^2.5.0",
    "zod": "^3.25.76",
    "zx": "^8.0.0"
  }
}
