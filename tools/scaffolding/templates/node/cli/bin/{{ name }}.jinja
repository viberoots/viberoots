#!/usr/bin/env node
import('../dist/index.js').then(m => {
  const code = (m && typeof m.run === 'function') ? m.run(process.argv.slice(2)) : 0;
  if (typeof code === 'number') process.exit(code);
  if (typeof code?.then === 'function') code.then((c:number)=>process.exit(c)).catch(()=>process.exit(1));
}).catch(()=>process.exit(1));

