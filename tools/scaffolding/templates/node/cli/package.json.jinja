{
  "name": "{{ pkgScope }}/{{ name }}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "bin": {
    "{{ name }}": "bin/{{ name }}"
  },
  "scripts": {
    "build": "tsc -p .",
    "test": "node --test dist/**/*.test.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier -w ."
  }
}

