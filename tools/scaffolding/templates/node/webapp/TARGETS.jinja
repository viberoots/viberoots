load("//node:defs.bzl", "node_webapp", "nix_node_test")

node_webapp(
    name = "app",
    labels = [
        "lockfile:apps/{{ name }}/pnpm-lock.yaml#apps/{{ name }}",
        "lang:node",
        "kind:app",
    ],
)

{% if includeNodeTests %}
nix_node_test(
    name = "unit",
    lockfile_label = "lockfile:apps/{{ name }}/pnpm-lock.yaml#apps/{{ name }}",
)
{% endif %}
