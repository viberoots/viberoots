{ pkgs }:
# tools/nix/templates/{{ lang_id }}.nix — {{ display_name }} language templates (skeleton)
# Keep small; wire real logic later.
ctx:
{
  # Example placeholders mirroring Go surface for consistency
  {{ lang_id }}App = { name, srcRoot ? ./. }:
    pkgs.runCommand "{{ lang_id }}-${name}" {} ''
      mkdir -p "$out"
      echo {{ display_name }} > "$out/README"
    '';

  {{ lang_id }}Lib = { name, srcRoot ? ./. }:
    pkgs.runCommand "{{ lang_id }}lib-${name}" {} ''
      mkdir -p "$out"
      echo {{ display_name }}-lib > "$out/README"
    '';
}
