{
  "specVersion": "1.0.0",
  "schemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "tool": {
    "name": "ctlndjson",
    "title": "Emit NDJSON with a control line",
    "description": "Emits one data item then a $jio.ctl elicit control message.",
    "inputSchema": { "type": "object", "additionalProperties": false },
    "outputSchema": { "type": "object" }
  },
  "command": {
    "package": "io.example.examples",
    "exec": "bash",
    "parameters": {
      "script": {
        "type": "string",
        "position": 1,
        "value": "-lc"
      },
      "body": {
        "type": "string",
        "position": 2,
        "value": "printf '%s\n' '{\"file\":\"a.txt\"}' '{\"$jio.ctl\":true,\"$jio.ctl.elicit\":{\"message\":\"confirm?\",\"requestedSchema\":{\"type\":\"object\",\"properties\":{\"confirm\":{\"type\":\"boolean\"}},\"required\":[\"confirm\"],\"additionalProperties\":false}}'"
      }
    },
    "stdoutTransform": { "shell": "cat", "format": "ndjson" }
  }
}
