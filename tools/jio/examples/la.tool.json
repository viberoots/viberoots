{
  "specVersion": "1.0.0",
  "schemaDialect": "https://json-schema.org/draft/2020-12/schema",

  "tool": {
    "name": "la",
    "title": "List all (long)",
    "description": "ls that returns all stats for each file",
    "inputSchema": {
      "type": "object",
      "additionalProperties": false
    },
    "outputSchema": {
      "type": "object",
      "properties": { "file": { "type": "string" } },
      "required": ["file"]
    }
  },

  "command": {
    "package": "io.example.examples",
    "exec": "ls",
    "inheritCallerCwd": true,
    "parameters": {
      "path": { "path": "$.path", "type": "string", "position": 1, "required": false }
    },
    "stdoutTransform": {
      "shell": "xargs stat | jc --stat | jq -c '.[]'",
      "format": "ndjson"
    }
  }
}
