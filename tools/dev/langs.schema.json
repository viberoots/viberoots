{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Languages Manifest Schema",
  "type": ["array", "object"],
  "definitions": {
    "lang": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "displayName", "requiredPaths", "kinds", "templatesDir"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "requiredPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "optionalPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "kinds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "templatesDir": { "type": "string", "minLength": 1 }
      }
    }
  },
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/definitions/lang" }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "items": { "$ref": "#/definitions/lang" }
        }
      }
    }
  ]
}
