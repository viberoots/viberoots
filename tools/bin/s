#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Status watch for verify logs.
# Equivalent to: tools/bin/tail-log --status -w [SECONDS] [--json] [PID]
export TAIL_LOG_EXTRA_STATUS=1
command -v "${SCRIPT_DIR}/c" >/dev/null 2>&1 && "${SCRIPT_DIR}/c"
exec "${SCRIPT_DIR}/tail-log" --status -w "$@"


