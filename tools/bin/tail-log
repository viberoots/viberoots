#!/usr/bin/env bash
set -euo pipefail

# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/_env.sh"

LOCK_DIR="${LIVE_ROOT}/buck-out/tmp/verify-lock"

is_int() {
  [[ "${1:-}" =~ ^[0-9]+$ ]]
}

is_number() {
  [[ "${1:-}" =~ ^[0-9]+([.][0-9]+)?$ ]]
}

run_verify_log_status() {
  local log_file="$1"
  local pid="$2"
  local json_mode="$3"
  # Avoid noisy direnv banners on every tick.
  local DIRENV_LOG_FORMAT=""
  export DIRENV_LOG_FORMAT

  if [[ -n "${IN_NIX_SHELL:-}" ]]; then
    if [[ "${json_mode}" == "1" ]]; then
      zx-wrapper "${REPO_ROOT}/tools/dev/verify-log-status.ts" --log "${log_file}" --pid "${pid}" --json
    else
      zx-wrapper "${REPO_ROOT}/tools/dev/verify-log-status.ts" --log "${log_file}" --pid "${pid}"
    fi
    return 0
  fi

  if ! command -v direnv >/dev/null 2>&1; then
    echo "error: direnv not found on PATH; run inside the dev shell" 1>&2
    return 127
  fi

  if [[ "${json_mode}" == "1" ]]; then
    direnv exec "${LIVE_ROOT}" zx-wrapper "${REPO_ROOT}/tools/dev/verify-log-status.ts" --log "${log_file}" --pid "${pid}" --json
  else
    direnv exec "${LIVE_ROOT}" zx-wrapper "${REPO_ROOT}/tools/dev/verify-log-status.ts" --log "${log_file}" --pid "${pid}"
  fi
}

render_watch_status_loop() {
  local log_file="$1"
  local pid="$2"
  local json_mode="$3"
  local watch_interval="$4"

  # On Ctrl-C, print a trailing newline so the shell prompt doesn't land mid-line.
  on_sigint() {
    # Restore cursor if we hid it.
    printf "\033[?25h" >/dev/tty 2>/dev/null || true
    # Newline: prefer controlling TTY, fall back to stdout.
    printf "\n" >/dev/tty 2>/dev/null || printf "\n"
    exit 130
  }
  trap on_sigint INT

  # Allow log rotation / lock handoff: if the log disappears, attempt to re-resolve.
  resolve_log_or_empty() {
    local cur_pid="$1"
    local cur_log="$2"
    if [[ -f "${cur_log}" ]]; then
      printf "%s\n" "${cur_log}"
      return 0
    fi
    # Prefer lockfile pointer if present and matching.
    if [[ -d "${LOCK_DIR}" ]]; then
      local locked_pid locked_log
      locked_pid="$(cat "${LOCK_DIR}/pid" 2>/dev/null || true)"
      locked_log="$(cat "${LOCK_DIR}/log" 2>/dev/null || true)"
      if [[ -n "${locked_pid}" && "${locked_pid}" == "${cur_pid}" && -n "${locked_log}" && -f "${locked_log}" ]]; then
        printf "%s\n" "${locked_log}"
        return 0
      fi
    fi
    local maybe
    maybe="$(resolve_verify_log_for_pid "${cur_pid}")"
    if [[ -n "${maybe}" && -f "${maybe}" ]]; then
      printf "%s\n" "${maybe}"
      return 0
    fi
    printf "%s\n" ""
  }

  if [[ "${json_mode}" == "1" ]]; then
    while true; do
      current="$(resolve_log_or_empty "${pid}" "${log_file}")"
      if [[ -n "${current}" ]]; then
        log_file="${current}"
        run_verify_log_status "${log_file}" "${pid}" "${json_mode}" || true
      else
        # NDJSON: always write one JSON object per line to stdout.
        printf "%s\n" '{"pid":'"${pid}"',"pass":0,"fail":0,"fatal":0,"skip":0,"build_failure":0,"remaining":null,"failed":[],"done":false,"elapsed":null,"log":null,"source":"derived","error":"log file missing"}' || true
      fi
      sleep "${watch_interval}"
    done
  fi

  # TTY redraw without full-screen clears (avoid "black flash").
  local prev_lines=0
  trap 'printf "\033[?25h" >/dev/tty 2>/dev/null || true' EXIT TERM HUP
  printf "\033[?25l" >/dev/tty 2>/dev/null || true

  while true; do
    current="$(resolve_log_or_empty "${pid}" "${log_file}")"
    if [[ -n "${current}" ]]; then
      log_file="${current}"
    fi
    # We capture stdout into a variable; that would normally disable color auto-detection.
    # Force color so the rendered block is colored when printed back to the TTY.
    export FORCE_COLOR=1
    if [[ -z "${log_file}" || ! -f "${log_file}" ]]; then
      out=$'Time elapsed: ?\nTests so far:   Pass 0. Fail 0. Fatal 0. Skip 0. Build failure 0\nLog: (missing)\n(error: log file missing; waiting...)'
    else
      out="$(run_verify_log_status "${log_file}" "${pid}" "${json_mode}" 2>&1 || true)"
    fi
    # Move up to the start of previous block, clear to end, print new block.
    if (( prev_lines > 0 )); then
      printf "\033[%dA" "${prev_lines}"
    fi
    printf "\033[J"
    printf "%s\n" "${out}"
    # Count lines we just printed (ensure at least 1).
    prev_lines="$(printf "%s\n" "${out}" | wc -l | tr -d ' ')"
    if [[ -z "${prev_lines}" || "${prev_lines}" == "0" ]]; then prev_lines=1; fi
    sleep "${watch_interval}"
  done
}

usage() {
  cat 1>&2 <<'EOF'
usage:
  tools/bin/tail-log [-n LINES] [PID]
  tools/bin/l        [-n LINES] [PID]
  tools/bin/tail-log --status [--json] [PID]
  tools/bin/l        --status [--json] [PID]
  tools/bin/tail-log --status -w [SECONDS] [--json] [PID]
  tools/bin/l        --status -w [SECONDS] [--json] [PID]

If PID is omitted:
  - tails the log if exactly one verify process is running
  - errors if zero or multiple verify processes are running (and prints their PIDs)

If -n is provided:
  - uses 'tail -n LINES' (no follow)

If --status is provided:
  - computes counters from the full log file and exits (no follow)
  - with -w/--watch: re-runs status repeatedly (always full-log scan)
  - when no verify is running: shows status for the most recent verify log (if present)
EOF
}

verify_pids_in_repo() {
  local pattern="${REPO_ROOT}/tools/bin/verify"
  local pids=""
  if command -v pgrep >/dev/null 2>&1; then
    pids="$(pgrep -f "${pattern}" 2>/dev/null || true)"
    if [[ -n "${pids}" ]]; then
      printf "%s\n" "${pids}"
      return 0
    fi
    # Fallback: match generic "tools/bin/verify" and filter to this repo root.
    pids="$(pgrep -f "tools/bin/verify" 2>/dev/null || true)"
    if [[ -z "${pids}" ]]; then
      return 0
    fi
    while IFS= read -r pid; do
      [[ -z "${pid}" ]] && continue
      cmd="$(/bin/ps -p "${pid}" -o command= 2>/dev/null || true)"
      if [[ "${cmd}" == *"${pattern}"* ]]; then
        printf "%s\n" "${pid}"
      fi
    done <<< "${pids}"
  fi
}

resolve_verify_log_for_pid() {
  local pid="$1"
  local by_pid="${REPO_ROOT}/buck-out/tmp/verify-logs/by-pid/${pid}.log"
  local legacy_guess="${REPO_ROOT}/buck-out/tmp/verify-logs/verify-${pid}.log"

  # Prefer lockfile pointer if present and matching.
  if [[ -d "${LOCK_DIR}" ]]; then
    local locked_pid locked_log
    locked_pid="$(cat "${LOCK_DIR}/pid" 2>/dev/null || true)"
    locked_log="$(cat "${LOCK_DIR}/log" 2>/dev/null || true)"
    if [[ "${locked_pid}" == "${pid}" && -n "${locked_log}" ]]; then
      printf "%s\n" "${locked_log}"
      return 0
    fi
  fi

  if [[ -e "${by_pid}" ]]; then
    printf "%s\n" "${by_pid}"
    return 0
  fi

  # Back-compat for older verify runs that used pid-named logs.
  printf "%s\n" "${legacy_guess}"
}

print_running_verify_pids() {
  local pids=("$@")
  echo "running verify pids:" 1>&2
  for pid in "${pids[@]}"; do
    echo "  - ${pid}" 1>&2
  done
}

main() {
  local lines=""
  local arg=""
  local status_mode="0"
  local json_mode="0"
  local watch_mode="0"
  local watch_interval="0.25"

  # Parse optional -n <lines> (or -n<lines>)
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)
        status_mode="1"
        shift || true
        ;;
      -w|--watch)
        watch_mode="1"
        shift || true
        # optional interval
        if [[ $# -gt 0 && "$1" != -* ]]; then
          watch_interval="$1"
          shift || true
        fi
        ;;
      --watch=*)
        watch_mode="1"
        watch_interval="${1#--watch=}"
        shift || true
        ;;
      --json)
        json_mode="1"
        shift || true
        ;;
      -n)
        shift || true
        lines="${1:-}"
        shift || true
        ;;
      -n*)
        lines="${1#-n}"
        shift || true
        ;;
      -h|--help)
        usage
        exit 2
        ;;
      *)
        arg="$1"
        shift || true
        # Only allow one positional arg (PID)
        if [[ $# -gt 0 ]]; then
          echo "error: unexpected extra args: $*" 1>&2
          usage
          exit 2
        fi
        ;;
    esac
  done

  if [[ -n "${lines}" ]]; then
    if ! is_int "${lines}"; then
      echo "error: -n expects an integer number of lines, got: ${lines}" 1>&2
      exit 2
    fi
  fi

  if [[ "${watch_mode}" == "1" && "${status_mode}" != "1" ]]; then
    echo "error: -w/--watch requires --status" 1>&2
    exit 2
  fi
  if [[ "${watch_mode}" == "1" ]]; then
    if ! is_number "${watch_interval}"; then
      echo "error: -w/--watch interval must be a seconds value (e.g. 0.25), got: ${watch_interval}" 1>&2
      exit 2
    fi
  fi

  if [[ "${status_mode}" == "1" && -n "${lines}" ]]; then
    echo "error: -n cannot be combined with --status (status always scans the full log)" 1>&2
    exit 2
  fi

  if [[ -n "${arg}" ]]; then
    if ! is_int "${arg}"; then
      echo "error: expected PID as an integer, got: ${arg}" 1>&2
      exit 2
    fi
    local pid="${arg}"
    if ! kill -0 "${pid}" >/dev/null 2>&1; then
      echo "error: pid ${pid} is not running" 1>&2
      exit 2
    fi
    local log_file
    log_file="$(resolve_verify_log_for_pid "${pid}")"
    if [[ ! -f "${log_file}" ]]; then
      echo "error: log file not found for pid ${pid}: ${log_file}" 1>&2
      exit 2
    fi
    if [[ "${status_mode}" == "1" ]]; then
      if [[ "${watch_mode}" == "1" ]]; then
        render_watch_status_loop "${log_file}" "${pid}" "${json_mode}" "${watch_interval}"
      fi
      if [[ "${json_mode}" == "1" ]]; then
        run_verify_log_status "${log_file}" "${pid}" "${json_mode}"
      else
        run_verify_log_status "${log_file}" "${pid}" "${json_mode}"
      fi
      exit 0
    fi
    if [[ -n "${lines}" ]]; then
      exec tail -n "${lines}" "${log_file}"
    fi
    exec tail -f "${log_file}"
  fi

  # Prefer the verify lock if present; it's authoritative for "the" local verify run.
  lock_pid=""
  lock_log=""
  if [[ -d "${LOCK_DIR}" ]]; then
    lock_pid="$(cat "${LOCK_DIR}/pid" 2>/dev/null || true)"
    lock_log="$(cat "${LOCK_DIR}/log" 2>/dev/null || true)"
  fi

  # If the lock exists and points to a live PID, use it regardless of how many verify processes exist
  # (verify re-exec can create a short-lived parent+child pair).
  if [[ -n "${lock_pid}" ]] && kill -0 "${lock_pid}" >/dev/null 2>&1; then
    local pid="${lock_pid}"
    local log_file="${lock_log}"
    if [[ -z "${log_file}" ]]; then
      log_file="$(resolve_verify_log_for_pid "${pid}")"
    fi
    if [[ "${status_mode}" == "1" ]]; then
      if [[ "${watch_mode}" == "1" ]]; then
        # Even if the log is missing (e.g. deleted mid-run), watch mode should not crash.
        render_watch_status_loop "${log_file}" "${pid}" "${json_mode}" "${watch_interval}"
      fi
      if [[ ! -f "${log_file}" ]]; then
        echo "error: log file not found for pid ${pid}: ${log_file}" 1>&2
        exit 2
      fi
      run_verify_log_status "${log_file}" "${pid}" "${json_mode}"
      exit 0
    fi
    if [[ ! -f "${log_file}" ]]; then
      echo "error: log file not found for pid ${pid}: ${log_file}" 1>&2
      exit 2
    fi
    if [[ -n "${lines}" ]]; then
      exec tail -n "${lines}" "${log_file}"
    fi
    exec tail -f "${log_file}"
  fi

  mapfile -t pids < <(verify_pids_in_repo || true)
  if [[ "${#pids[@]}" -eq 0 ]]; then
    if [[ "${status_mode}" == "1" ]]; then
      # No running verify: show status for most recent verify log (completed run).
      local newest
      newest="$(ls -1t "${REPO_ROOT}/buck-out/tmp/verify-logs"/verify-*.log 2>/dev/null | head -1 || true)"
      if [[ -z "${newest}" || ! -f "${newest}" ]]; then
        echo "error: no verify process is running and no prior verify logs were found" 1>&2
        exit 2
      fi
      if [[ "${watch_mode}" == "1" ]]; then
        # Watch a completed log file (useful for CI artifacts / post-mortem); PID is unknown.
        render_watch_status_loop "${newest}" "0" "${json_mode}" "${watch_interval}"
      fi
      run_verify_log_status "${newest}" "0" "${json_mode}"
      exit 0
    fi
    echo "error: no verify process is running" 1>&2
    exit 2
  fi
  if [[ "${#pids[@]}" -ne 1 ]]; then
    echo "error: expected exactly one running verify process, found ${#pids[@]}" 1>&2
    print_running_verify_pids "${pids[@]}"
    exit 2
  fi

  local pid="${pids[0]}"
  local log_file
  log_file="$(resolve_verify_log_for_pid "${pid}")"
  if [[ ! -f "${log_file}" ]]; then
    echo "error: log file not found for pid ${pid}: ${log_file}" 1>&2
    exit 2
  fi
  if [[ "${status_mode}" == "1" ]]; then
    if [[ "${watch_mode}" == "1" ]]; then
      render_watch_status_loop "${log_file}" "${pid}" "${json_mode}" "${watch_interval}"
    fi
    if [[ "${json_mode}" == "1" ]]; then
      run_verify_log_status "${log_file}" "${pid}" "${json_mode}"
    else
      run_verify_log_status "${log_file}" "${pid}" "${json_mode}"
    fi
    exit 0
  fi
  if [[ -n "${lines}" ]]; then
    exec tail -n "${lines}" "${log_file}"
  fi
  exec tail -f "${log_file}"
}

main "$@"


