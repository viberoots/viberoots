#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}/../.."
LIVE_ROOT="${WORKSPACE_ROOT:-$REPO_ROOT}"
TARGET_TS="${LIVE_ROOT}/tools/patch/patch-pkg.ts"

# Ensure coverage directory for child node processes when COVERAGE=1
if [[ "${COVERAGE:-}" == "1" ]]; then
  mkdir -p "${REPO_ROOT}/coverage/raw"
  export NODE_V8_COVERAGE="${REPO_ROOT}/coverage/raw"
fi

NODE_BIN_RESOLVED="${NODE_BIN:-}"
if [[ -z "$NODE_BIN_RESOLVED" ]]; then
  if command -v node >/dev/null 2>&1; then
    NODE_BIN_RESOLVED="$(command -v node)"
  else
    echo "error: node not found on PATH and NODE_BIN not set" >&2
    exit 127
  fi
fi

exec "$NODE_BIN_RESOLVED" \
  --experimental-top-level-await \
  --disable-warning=ExperimentalWarning \
  --experimental-strip-types \
  --import "${LIVE_ROOT}/tools/dev/zx-init.mjs" \
  "$TARGET_TS" "$@"
