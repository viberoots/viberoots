#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="${SCRIPT_DIR}/../.."
# Prefer running the source from the original workspace root if provided (when executed from a temp copy)
LIVE_ROOT="${WORKSPACE_ROOT:-$REPO_ROOT}"
TARGET="${LIVE_ROOT}/tools/dev/dev-build.ts"

if [[ -z "${NODE_V8_COVERAGE:-}" ]]; then
  export NODE_V8_COVERAGE="${REPO_ROOT}/coverage/raw"
fi
mkdir -p "${NODE_V8_COVERAGE}"

RUN=("${NODE_BIN:-node}" \
  --experimental-top-level-await \
  --disable-warning=ExperimentalWarning \
  --experimental-strip-types \
  --import "${LIVE_ROOT}/tools/dev/zx-init.mjs" \
  "$TARGET" "$@")

if [[ -z "${IN_NIX_SHELL:-}" ]]; then
  if ! command -v direnv >/dev/null 2>&1; then
    echo "error: direnv not found on PATH; run inside the dev shell" 1>&2
    exit 127
  fi
  exec direnv exec "${LIVE_ROOT}" "${RUN[@]}"
else
  exec "${RUN[@]}"
fi
