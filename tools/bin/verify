#!/usr/bin/env bash
# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/_env.sh"

# Determine external timeout command
TIMEOUT_CMD=()
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD=(timeout -k 10s 900s)
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD=(gtimeout -k 10s 900s)
else
  TIMEOUT_CMD=()
fi
if [[ "${CI:-}" == "true" ]]; then
  TIMEOUT_CMD=()
fi

# Flags
COVERAGE=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --coverage)
      COVERAGE=1
      ;;
    --)
      shift
      ARGS+=("$@")
      break
      ;;
    *)
      ARGS+=("$a")
      ;;
  esac
done

# Ensure COVERAGE is visible to the wrapper script environment
export COVERAGE

# Use PATH for buck2; shellHook ensures upstream buck2 is first
BUCK_BIN="buck2"

# Resolve prelude strictly from this flake's buck2-prelude (built from upstream input)
if ! command -v nix >/dev/null 2>&1; then
  echo "error: nix not found; cannot resolve buck2 prelude" 1>&2
  exit 127
fi
PRE_OUT=$(nix build .#buck2-prelude --no-link --accept-flake-config --print-out-paths 2>/dev/null | tail -1)
if [[ -z "$PRE_OUT" || ! -d "$PRE_OUT/prelude" ]]; then
  echo "error: failed to resolve flake .#buck2-prelude" 1>&2
  exit 1
fi
BUCK_PRELUDE="$PRE_OUT/prelude"

export BUCK_ROOT="${WORKSPACE_ROOT:-$LIVE_ROOT}"

# Always operate from repo root so this script can be called from any directory
ROOT_DIR="$(cd "$(dirname "$0")"/../.. && pwd)"
ORIG_CWD="$PWD"
cd "$ROOT_DIR"
export BUCK_ROOT="$ROOT_DIR"

# Remove any ephemeral repo-root .tmp that may contain test-generated TARGETS
rm -rf .tmp || true

# Clean previous coverage artifacts regardless of coverage mode
rm -rf coverage || true

# Write deterministic Buck config mapping, symlinking prelude into repo for stable alias
printf '.\n' > .buckroot
rm -rf prelude && ln -s "$BUCK_PRELUDE" prelude
cat > .buckconfig <<EOF
[buildfile]
name = TARGETS

[repositories]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[cells]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[build]
prelude = prelude
user_platform = prelude//platforms:default
target_platforms = prelude//platforms:default
EOF

# Ensure toolchains/ has its own .buckconfig so Buck uses TARGETS there too
mkdir -p toolchains
cat > toolchains/.buckconfig <<EOF
[buildfile]
name = TARGETS
EOF

build_run_array() {
  local PLATFORM_FLAGS=(--target-platforms prelude//platforms:default)
  local TARGETS=()
  if [[ $# -gt 0 ]]; then
    TARGETS=("$@")
  else
    TARGETS=("//...")
  fi
  # Create a small wrapper script to execute tests and always kill the per-run buck2 daemon.
  local TMP_SCRIPT_DIR TMP_SCRIPT
  TMP_SCRIPT_DIR=$(mktemp -d "${TMPDIR:-/tmp}/verify-run-$$-XXXXXX")
  TMP_SCRIPT="$TMP_SCRIPT_DIR/run.sh"
  cat >"$TMP_SCRIPT" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
ISO="v-$$"
# Ensure we always teardown our buck2 daemon and terminate our process group on exit/signals
cleanup() {
  # Kill foreground/background children in our process group first (best-effort)
  kill -- -$$ >/dev/null 2>&1 || true
  "buck2" --isolation-dir "$ISO" kill >/dev/null 2>&1 || true
  # Also clean up any test/exporter-specific daemons left behind from interrupted runs
  if command -v /bin/ps >/dev/null 2>&1; then
    # Retry a few times in case buck2d is still winding down
    for _i in 1 2 3; do
      # Collect isolations from active client commands (--isolation-dir) and from running buck2d[iso]
      _isos_cli_str=$(/bin/ps -A -o pid=,command= 2>/dev/null \
        | sed -n 's/.*--isolation-dir \([^ ]*\).*/\1/p' \
        | grep -E '^(zxtest-|exporter-|devbuild-|v-|scaf-)' \
        | sort -u || true)
      _isos_d_str=$(/bin/ps -A -o pid=,comm= 2>/dev/null \
        | sed -n 's/.*buck2d\[\([^]]*\)\].*/\1/p' \
        | grep -E '^(zxtest-|exporter-|devbuild-|v-|scaf-)' \
        | sort -u || true)
      for iso in $_isos_cli_str $_isos_d_str; do
        [ -n "$iso" ] || continue
        "buck2" --isolation-dir "$iso" kill >/dev/null 2>&1 || true
      done
      # If no matching buck2d remain, stop retrying
      if ! /bin/ps -A -o pid=,comm= 2>/dev/null | grep -E "buck2d\\[(zxtest-|exporter-|devbuild-|v-|scaf-).*\\]" >/dev/null 2>&1; then
        break
      fi
      sleep 0.3
    done
  fi
}
trap cleanup EXIT INT TERM HUP

# Spawn a detached watchdog that reaps our isolation if this script dies abruptly (e.g., SIGKILL)
if command -v nohup >/dev/null 2>&1; then
  (
    nohup bash --noprofile --norc -c '
      parent="'"$$"'";
      if command -v node >/dev/null 2>&1; then
        node --experimental-top-level-await --experimental-strip-types --disable-warning=ExperimentalWarning --import '"$LIVE_ROOT"'/tools/dev/zx-init.mjs '"$LIVE_ROOT"'/tools/dev/buck-watchdog.ts --parent "$parent" --iso '"$ISO"' --patterns zxtest-,exporter-,devbuild-,v-,scaf- & disown
      else
        # Fallback to simple loop if node unavailable
        while kill -0 "$parent" >/dev/null 2>&1; do sleep 2; done
        buck2 --isolation-dir '"$ISO"' kill >/dev/null 2>&1 || true
      fi
    ' >/dev/null 2>&1 &
  ) || true
fi
# Run tests; pass through any target patterns as arguments. Preserve TTY for Buck superconsole.
# Suppress benign tailer/event-log and post-run INFO spam; keep superconsole visible.
export RUST_LOG="${RUST_LOG:-warn},buck2_client_ctx::file_tailers::tailer=off,buck2_event_log::writer=off"
export BUCK_LOG="${BUCK_LOG:-warn},buck2_client_ctx::file_tailers::tailer=off,buck2_event_log::writer=off"
CMD="buck2 --isolation-dir \"$ISO\" test --console super --target-platforms prelude//platforms:default \"$@\" -- --env COVERAGE=\"${COVERAGE:-0}\""
if command -v script >/dev/null 2>&1; then
  # Use a PTY so Buck detects an interactive console; avoid login/profile shells
  script -q /dev/null bash --noprofile --norc -c "$CMD"
else
  eval "$CMD"
fi
STATUS=$?
# Final best-effort cleanup
cleanup || true
exit "$STATUS"
EOS
  chmod +x "$TMP_SCRIPT"
  # External timeout policy: 900s (10 minutes) for both full suite and single focused tests
  local RUN_TIMEOUT=()
  if [[ -n ${TIMEOUT_CMD+x} && ${#TIMEOUT_CMD[@]} -gt 0 ]]; then
    if [[ ${#TARGETS[@]} -eq 1 && "${TARGETS[0]}" == *:* ]]; then
      if command -v timeout >/dev/null 2>&1; then
        RUN_TIMEOUT=(timeout -k 10s 900s)
      elif command -v gtimeout >/dev/null 2>&1; then
        RUN_TIMEOUT=(gtimeout -k 10s 900s)
      fi
    else
      RUN_TIMEOUT=("${TIMEOUT_CMD[@]}")
    fi
  fi
  if [[ ${#RUN_TIMEOUT[@]} -gt 0 ]]; then
    RUN=("${RUN_TIMEOUT[@]}" "$TMP_SCRIPT" "${TARGETS[@]}")
  else
    RUN=("$TMP_SCRIPT" "${TARGETS[@]}")
  fi
}

export NO_NODE_MODULES_LINK=1
if [[ ${#ARGS[@]} -eq 0 ]]; then
  build_run_array
else
  build_run_array "${ARGS[@]}"
fi

exec_in_dev_shell "${LIVE_ROOT}" "${RUN[@]}"
