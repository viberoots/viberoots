#!/usr/bin/env bash
# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/_env.sh"

# Determine external timeout command
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD=(timeout -k 10s 300s)
elif command -v gtimeout >/dev/null 2>&1; then
  TIMEOUT_CMD=(gtimeout -k 10s 300s)
else
  TIMEOUT_CMD=()
fi
if [[ "${CI:-}" == "true" ]]; then
  TIMEOUT_CMD=()
fi

# Flags
COVERAGE=0
ARGS=()
for a in "$@"; do
  case "$a" in
    --coverage)
      COVERAGE=1
      ;;
    --)
      shift
      ARGS+=("$@")
      break
      ;;
    *)
      ARGS+=("$a")
      ;;
  esac
done

# Use PATH for buck2; shellHook ensures upstream buck2 is first
BUCK_BIN="buck2"

# Resolve prelude strictly from this flake's buck2-prelude (built from upstream input)
if ! command -v nix >/dev/null 2>&1; then
  echo "error: nix not found; cannot resolve buck2 prelude" 1>&2
  exit 127
fi
PRE_OUT=$(nix build .#buck2-prelude --no-link --accept-flake-config --print-out-paths 2>/dev/null | tail -1)
if [[ -z "$PRE_OUT" || ! -d "$PRE_OUT/prelude" ]]; then
  echo "error: failed to resolve flake .#buck2-prelude" 1>&2
  exit 1
fi
BUCK_PRELUDE="$PRE_OUT/prelude"

export BUCK_ROOT="${WORKSPACE_ROOT:-$PWD}"

# Write deterministic Buck config mapping, symlinking prelude into repo for stable alias
: > .buckroot
rm -rf prelude && ln -s "$BUCK_PRELUDE" prelude
cat > .buckconfig <<EOF
[buildfile]
name = TARGETS

[repositories]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[cells]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[build]
prelude = prelude
user_platform = prelude//platforms:default
target_platforms = prelude//platforms:default
EOF

# Ensure toolchains/ has its own .buckconfig so Buck uses TARGETS there too
mkdir -p toolchains
cat > toolchains/.buckconfig <<EOF
[buildfile]
name = TARGETS
EOF

build_run_array() {
  local PLATFORM_FLAGS=(--target-platforms prelude//platforms:default)
  local args=("$BUCK_BIN" test "${PLATFORM_FLAGS[@]}" "$@" -- --env COVERAGE="${COVERAGE}")
  # External timeout policy: 300s full suite; 180s for a single focused test
  local RUN_TIMEOUT=("${TIMEOUT_CMD[@]}")
  if [[ ${#TIMEOUT_CMD[@]} -gt 0 ]]; then
    if [[ $# -eq 1 && "$1" == //:* || ( $# -eq 1 && "$1" == //*) ]]; then
      # Focused single target → shorter timeout
      if command -v timeout >/dev/null 2>&1; then
        RUN_TIMEOUT=(timeout -k 10s 180s)
      elif command -v gtimeout >/dev/null 2>&1; then
        RUN_TIMEOUT=(gtimeout -k 10s 180s)
      fi
    fi
  fi
  if [[ ${#RUN_TIMEOUT[@]} -gt 0 ]]; then
    RUN=("${RUN_TIMEOUT[@]}" "${args[@]}")
  else
    RUN=("${args[@]}")
  fi
}

if [[ ${#ARGS[@]} -eq 0 ]]; then
  build_run_array //...
else
  build_run_array "${ARGS[@]}"
fi

exec_in_dev_shell "${LIVE_ROOT}" "${RUN[@]}"
