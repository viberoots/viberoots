#!/usr/bin/env bash
# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/_env.sh"

TIMEOUT_CMD=(timeout -k 10s 180s)
if [[ "${CI:-}" == "true" ]]; then
  TIMEOUT_CMD=()
fi

: "${COVERAGE:=1}"

if [[ $# -eq 0 ]]; then
  RUN=("${TIMEOUT_CMD[@]}" buck2 test //... -- --env COVERAGE="${COVERAGE}")
else
  RUN=("${TIMEOUT_CMD[@]}" buck2 test "$@" -- --env COVERAGE="${COVERAGE}")
fi

exec_in_dev_shell "${LIVE_ROOT}" "${RUN[@]}"
