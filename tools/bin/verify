#!/usr/bin/env bash
# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/_env.sh"

# Ensure the entire verify workflow runs inside the dev shell so all tools are nix-supplied.
if [[ -z "${NO_DEV_SHELL:-}" && -z "${IN_NIX_SHELL:-}" && -z "${BNX_VERIFY_REEXEC:-}" ]]; then
  if ! command -v direnv >/dev/null 2>&1; then
    echo "error: direnv not found on PATH; run inside the dev shell" 1>&2
    exit 127
  fi
  export BNX_VERIFY_REEXEC=1
  exec direnv exec "${LIVE_ROOT}" "$0" "$@"
fi

# Prevent accidental concurrent verify runs locally (they cause massive performance regressions).
# In CI we intentionally allow concurrent runs.
# Allow override with VERIFY_ALLOW_CONCURRENT=1.
if [[ "${CI:-}" != "true" && ( -z "${VERIFY_ALLOW_CONCURRENT:-}" || "${VERIFY_ALLOW_CONCURRENT}" != "1" ) ]]; then
  LOCK_DIR="${LIVE_ROOT}/buck-out/tmp/verify-lock"
  mkdir -p "${LIVE_ROOT}/buck-out/tmp" >/dev/null 2>&1 || true
  export BNX_VERIFY_LOCK_DIR="${LOCK_DIR}"

  verify_lock_release() {
    rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
  }

  verify_lock_pid_alive_with_sig() {
    local pid="$1"
    local expected_sig="$2"
    if [[ -z "${pid}" ]]; then return 1; fi
    if ! kill -0 "${pid}" >/dev/null 2>&1; then return 1; fi
    local sig=""
    sig="$(/bin/ps -p "${pid}" -o lstart= 2>/dev/null | tr -d '\r' | xargs || true)"
    if [[ -z "${sig}" ]]; then return 1; fi
    [[ "${sig}" == "${expected_sig}" ]]
  }

  ensure_verify_log_path() {
    # Stable path for l/tail-log to use, but ensure each verify run gets a unique file to avoid
    # PID reuse / stale content issues.
    LOG_DIR="${LIVE_ROOT}/buck-out/tmp/verify-logs"
    mkdir -p "$LOG_DIR" >/dev/null 2>&1 || true

    existing="$(cat "${LOCK_DIR}/log" 2>/dev/null || true)"
    if [[ -n "${existing}" ]]; then
      BNX_VERIFY_LOG_FILE="${existing}"
      export BNX_VERIFY_LOG_FILE
      # Ensure the file exists immediately so `l --status` works even before the first test output.
      : > "${BNX_VERIFY_LOG_FILE}" 2>/dev/null || true
      return 0
    fi

    # macOS mktemp only replaces X's at the end of the template. Create a temp file first, then
    # rename to include a .log suffix.
    tmp_log="$(mktemp "${LOG_DIR}/verify-$(date +%Y%m%d-%H%M%S)-XXXXXXXX")"
    BNX_VERIFY_LOG_FILE="${tmp_log}.log"
    mv -f "${tmp_log}" "${BNX_VERIFY_LOG_FILE}" 2>/dev/null || true
    : > "${BNX_VERIFY_LOG_FILE}" 2>/dev/null || true
    export BNX_VERIFY_LOG_FILE
    echo "${BNX_VERIFY_LOG_FILE}" > "${LOCK_DIR}/log" || true

    # Stable per-PID pointer for tools/bin/tail-log when called with an explicit PID.
    # (Logs are no longer named verify-<pid>.log due to PID reuse risk.)
    by_pid="${LOG_DIR}/by-pid"
    mkdir -p "${by_pid}" >/dev/null 2>&1 || true
    ln -sf "${BNX_VERIFY_LOG_FILE}" "${by_pid}/${$}.log" 2>/dev/null || true

    # Stable pointer for "most recent verify log".
    ln -sf "${BNX_VERIFY_LOG_FILE}" "${LOG_DIR}/latest.log" 2>/dev/null || true
  }

  if mkdir "$LOCK_DIR" >/dev/null 2>&1; then
    echo "$$" > "${LOCK_DIR}/pid"
    /bin/ps -p "$$" -o lstart= 2>/dev/null | tr -d '\r' | xargs > "${LOCK_DIR}/lstart" || true
    ensure_verify_log_path
    trap verify_lock_release EXIT INT TERM HUP
  else
    pid="$(cat "${LOCK_DIR}/pid" 2>/dev/null || true)"
    sig="$(cat "${LOCK_DIR}/lstart" 2>/dev/null || true)"
    if verify_lock_pid_alive_with_sig "${pid}" "${sig}"; then
      # Allow our own re-exec (same PID) to continue without tripping the lock.
      if [[ "${pid}" == "$$" ]]; then
        ensure_verify_log_path
      else
        log_file="$(cat "${LOCK_DIR}/log" 2>/dev/null || true)"
        echo "error: verify is already running (pid ${pid}); refusing to start a concurrent run." 1>&2
        if [[ -n "${log_file:-}" && -f "${log_file}" ]]; then
          echo "hint: tail -f ${log_file}" 1>&2
        elif [[ -n "${log_file:-}" ]]; then
          echo "hint: recorded log path does not exist on disk: ${log_file}" 1>&2
          echo "hint: this usually means buck-out/tmp/verify-logs was deleted while verify was running." 1>&2
          echo "hint: verify is still running; check progress with: ps -p ${pid} -o pid=,stat=,etime=,command=" 1>&2
        else
          echo "hint: tail its log (or set VERIFY_ALLOW_CONCURRENT=1 if you really mean it)." 1>&2
        fi
        exit 2
      fi
    else
      # Stale lock (e.g. SIGKILL): clear and retry once.
      rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
      if mkdir "$LOCK_DIR" >/dev/null 2>&1; then
        echo "$$" > "${LOCK_DIR}/pid"
        /bin/ps -p "$$" -o lstart= 2>/dev/null | tr -d '\r' | xargs > "${LOCK_DIR}/lstart" || true
        ensure_verify_log_path
        trap verify_lock_release EXIT INT TERM HUP
      else
        echo "error: verify lock is held and could not be acquired (path: ${LOCK_DIR})." 1>&2
        exit 2
      fi
    fi
  fi
fi

# Determine external timeout command (respect VERIFY_TIMEOUT_SECS)
TSEC="${VERIFY_TIMEOUT_SECS:-3600}"
TIMEOUT_CMD=()
if command -v timeout >/dev/null 2>&1; then
  TIMEOUT_CMD=(timeout -k 10s "${TSEC}s")
else
  echo "error: timeout not found on PATH (expected via direnv/devshell)" 1>&2
  exit 127
fi
if [[ "${CI:-}" == "true" ]]; then
  TIMEOUT_CMD=()
fi

# Flags
COVERAGE=0
VERIFY_CONSOLE="auto" # auto | super | simple
ARGS=()
for a in "$@"; do
  case "$a" in
    --coverage)
      COVERAGE=1
      ;;
    --console=*)
      VERIFY_CONSOLE="${a#--console=}"
      ;;
    --console)
      shift
      VERIFY_CONSOLE="${1:-}"
      ;;
    --)
      shift
      ARGS+=("$@")
      break
      ;;
    *)
      ARGS+=("$a")
      ;;
  esac
done

# Ensure COVERAGE is visible to the wrapper script environment
export COVERAGE
export VERIFY_CONSOLE

# Default free-space target: higher when coverage is enabled (GB-only threshold; overridable)
if [[ -z "${VERIFY_TARGET_FREE_GB:-}" ]]; then
  if [[ "${COVERAGE:-0}" == "1" ]]; then
    # Coverage mode now generates a single merged report at the end (not per test),
    # so the free-space requirement can match non-coverage runs in typical workflows.
    export VERIFY_TARGET_FREE_GB=15
  else
    export VERIFY_TARGET_FREE_GB=20
  fi
fi

# Use PATH for buck2; shellHook ensures upstream buck2 is first
BUCK_BIN="buck2"

# Speed up local Nix builds by default: detect CPU count unless explicitly overridden
CPU_COUNT=""
if command -v sysctl >/dev/null 2>&1; then
  CPU_COUNT="$(sysctl -n hw.ncpu 2>/dev/null || true)"
fi
if [[ -z "${CPU_COUNT:-}" ]] && command -v nproc >/dev/null 2>&1; then
  CPU_COUNT="$(nproc 2>/dev/null || true)"
fi
if [[ -z "${CPU_COUNT:-}" ]]; then
  CPU_COUNT="4"
fi
export NIX_MAX_JOBS="${NIX_MAX_JOBS:-${CPU_COUNT}}"
export NIX_CORES="${NIX_CORES:-${CPU_COUNT}}"

# Resolve prelude strictly from this flake's buck2-prelude (built from upstream input)
if ! command -v nix >/dev/null 2>&1; then
  echo "error: nix not found; cannot resolve buck2 prelude" 1>&2
  exit 127
fi
PRE_OUT=$(nix build .#buck2-prelude --no-link --accept-flake-config --print-out-paths 2>/dev/null | tail -1)
if [[ -z "$PRE_OUT" || ! -d "$PRE_OUT/prelude" ]]; then
  echo "error: failed to resolve flake .#buck2-prelude" 1>&2
  exit 1
fi
BUCK_PRELUDE="$PRE_OUT/prelude"

export BUCK_ROOT="${WORKSPACE_ROOT:-$LIVE_ROOT}"

# Always operate from repo root so this script can be called from any directory
ROOT_DIR="$(cd "$(dirname "$0")"/../.. && pwd)"
ORIG_CWD="$PWD"
cd "$ROOT_DIR"
export BUCK_ROOT="$ROOT_DIR"

# Remove any ephemeral repo-root .tmp that may contain test-generated TARGETS
rm -rf .tmp || true

# Coverage directories:
# - Merged reports: $ROOT_DIR/coverage
# - Raw V8 coverage: per-run dir under $ROOT_DIR/buck-out/tmp/node-v8-coverage (Buck-ignored)
#   Using a unique dir avoids cross-run accumulation, which can make c8 aggregation unstable.
V8COV_PARENT="$ROOT_DIR/buck-out/tmp/node-v8-coverage"
mkdir -p "$V8COV_PARENT" >/dev/null 2>&1 || true
V8COV_DIR="$(mktemp -d "$V8COV_PARENT/v-XXXXXX")"
export V8COV_DIR

# Clean previous coverage artifacts (best-effort, but deterministic).
if [[ -d coverage ]]; then
  chmod -R u+w coverage >/dev/null 2>&1 || true
  find coverage -mindepth 1 -maxdepth 1 -print0 2>/dev/null | xargs -0 rm -rf >/dev/null 2>&1 || true
  rmdir coverage >/dev/null 2>&1 || true
fi
mkdir -p coverage >/dev/null 2>&1 || true

# Ensure raw coverage dir exists (unique per verify invocation).
mkdir -p "$V8COV_DIR" >/dev/null 2>&1 || true

# Preflight housekeeping to reduce ENOSPC risk while preserving full coverage:
# - prune stale buck-impure temp dirs and dangling result links
# - drop previous test logs
# - optimise store (bounded) and, if needed, loop bounded GC until a safe free-space target
housekeep_once() {
  local target_gb="${VERIFY_TARGET_FREE_GB:-12}"
  echo "[verify] housekeeping preflight: cleaning temp outs and checking disk space..." 1>&2
  if command -v zx-wrapper >/dev/null 2>&1; then
    ( zx-wrapper "$ROOT_DIR/tools/dev/clean-temp-outs.ts" --minutes 30 >/dev/null 2>&1 || true )
  elif command -v nix >/dev/null 2>&1; then
    ( nix run --accept-flake-config "$ROOT_DIR"#zx-wrapper -- "$ROOT_DIR/tools/dev/clean-temp-outs.ts" --minutes 30 >/dev/null 2>&1 || true )
  fi
  rm -rf "$ROOT_DIR/buck-out/test-logs" >/dev/null 2>&1 || true
  # Check disk free
  local df_line free_kb free_pct
  df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
  free_kb=0
  free_pct=100
  if [[ -n "$df_line" ]]; then
    free_kb="$(echo "$df_line" | awk '{print $4}')"
    local use_pct_raw; use_pct_raw="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
    [[ -n "$use_pct_raw" ]] && free_pct="$((100 - use_pct_raw))"
  fi
  echo "[verify] disk free: ${free_pct}% (~$((free_kb/1024/1024))GiB)" 1>&2
  # If critically low, purge repo-local ephemeral dirs to break logjams fast
  local free_gb="$((free_kb/1024/1024))"
  if (( free_gb < 4 )); then
    echo "[verify] very low space (<4GiB): purging repo-local temp dirs (buck-out/tmp, .tmp)..." 1>&2
    chmod -R u+w "$ROOT_DIR/buck-out/tmp" "$ROOT_DIR/.tmp" >/dev/null 2>&1 || true
    rm -rf "$ROOT_DIR/buck-out/tmp" "$ROOT_DIR/.tmp" >/dev/null 2>&1 || true
    df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
    if [[ -n "$df_line" ]]; then
      free_kb="$(echo "$df_line" | awk '{print $4}')"
      local use_pct_raw2a; use_pct_raw2a="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
      [[ -n "$use_pct_raw2a" ]] && free_pct="$((100 - use_pct_raw2a))"
    fi
    free_gb="$((free_kb/1024/1024))"
    echo "[verify] after purge: ${free_pct}% (~${free_gb}GiB)" 1>&2
  fi
  # Best-effort store optimise (cap ~60s)
  set +e
  timeout -k 5s 60s nix store optimise >/dev/null 2>&1
  set -e
  # If still low, run GC cycles (2G -> 4G -> 8G) with a short cap (45s each)
  df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
  if [[ -n "$df_line" ]]; then
    free_kb="$(echo "$df_line" | awk '{print $4}')"
    local use_pct_raw2; use_pct_raw2="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
    [[ -n "$use_pct_raw2" ]] && free_pct="$((100 - use_pct_raw2))"
  fi
  free_gb="$((free_kb/1024/1024))"
  if (( free_gb < target_gb )); then
    echo "[verify] low disk free detected; running bounded nix-store GC (<=45s each)..." 1>&2
    local cap
    for cap in 2G 4G 8G 16G 32G; do
      echo "[verify] running GC with --max-freed ${cap} ..." 1>&2
      set +e
      timeout -k 5s 45s nix-store --gc --max-freed "${cap}" >/dev/null 2>&1
      set -e
      df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
      free_kb="$(echo "$df_line" | awk '{print $4}')"
      local use_pct_raw3; use_pct_raw3="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
      local free_pct2=100
      [[ -n "$use_pct_raw3" ]] && free_pct2="$((100 - use_pct_raw3))"
      free_gb="$((free_kb/1024/1024))"
      echo "[verify] post-GC(${cap}) disk free: ${free_pct2}% (~${free_gb}GiB)" 1>&2
      if (( free_gb >= target_gb )); then
        break
      fi
    done
  fi
}

housekeep_once

# Write deterministic Buck config mapping, symlinking prelude into repo for stable alias
printf '.\n' > .buckroot
rm -rf prelude && ln -s "$BUCK_PRELUDE" prelude
cat > .buckconfig <<'EOF'
[buildfile]
name = TARGETS

[repositories]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[cells]
root = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./prelude/third-party/fbsource_stub
fbcode = ./prelude/third-party/fbcode_stub
config = ./prelude

[build]
prelude = prelude
user_platform = prelude//platforms:default
target_platforms = prelude//platforms:default
EOF

# Ensure toolchains/ has its own .buckconfig so Buck uses TARGETS there too
mkdir -p toolchains
cat > toolchains/.buckconfig <<'EOF'
[buildfile]
name = TARGETS
EOF

# Prewarm unified PNPM store once per repo state (best-effort) to avoid per-test prewarm work
if [[ ! -f "$ROOT_DIR/buck-out/.unified-pnpm-store/path" ]]; then
  if command -v node >/dev/null 2>&1; then
    (cd "$ROOT_DIR" && node "$ROOT_DIR/tools/dev/require-unified-pnpm-store.ts" >/dev/null 2>&1 || true)
  elif command -v nix >/dev/null 2>&1; then
    (cd "$ROOT_DIR" && nix run --accept-flake-config "$ROOT_DIR"#zx-wrapper -- "$ROOT_DIR/tools/dev/require-unified-pnpm-store.ts" >/dev/null 2>&1 || true)
  fi
fi

# Best-effort prewarm of heavy toolchains (Go/Clang/WASM). Controlled by VERIFY_PREWARM (default=0).
# Verify already executes a large number of builds/tests, so prewarming by default adds latency without
# improving determinism. Opt-in when explicitly debugging cold-start behavior.
if [[ "${VERIFY_PREWARM:-0}" == "1" ]]; then
  if command -v node >/dev/null 2>&1; then
    (cd "$ROOT_DIR" && node "$ROOT_DIR/tools/dev/prewarm-toolchains.ts" >/dev/null 2>&1 || true)
  elif command -v nix >/dev/null 2>&1; then
    (cd "$ROOT_DIR" && nix run --accept-flake-config "$ROOT_DIR"#zx-wrapper -- "$ROOT_DIR/tools/dev/prewarm-toolchains.ts" >/dev/null 2>&1 || true)
  fi
fi

# No repo-scoped shared importers; zx tests may scaffold ephemeral importers inside temp repos when needed.

run_merged_coverage_report() {
  local repo_root="$1"
  local raw_dir="${V8COV_DIR:-${repo_root}/buck-out/tmp/node-v8-coverage}"
  if [[ "${COVERAGE:-0}" != "1" ]]; then
    return 0
  fi
  local node_bin="${NODE_BIN:-node}"
  local c8_js="${repo_root}/node_modules/c8/bin/c8.js"
  if [[ ! -x "${c8_js}" ]]; then
    echo "error: coverage enabled but c8 is missing at ${c8_js}" 1>&2
    echo "hint: run 'i' to ensure node_modules are linked." 1>&2
    return 2
  fi
  # Normalize any temp-repo file:// urls back to the repo root before generating the merged report.
  NODE_V8_COVERAGE="${raw_dir}" "${node_bin}" "${repo_root}/tools/dev/coverage-raw-normalize.mjs" || true
  "${node_bin}" "${c8_js}" report \
    --clean=false \
    --temp-directory "${raw_dir}" \
    --reports-dir "${repo_root}/coverage" \
    --reporter=json-summary \
    --reporter=lcov \
    --reporter=html \
    --merge-async \
    --extension .ts \
    --allowExternal \
    --src "${repo_root}" \
    --include "**/*.ts" \
    --exclude "node_modules/**" \
    --exclude "buck-out/**" \
    --exclude ".clinic/**" \
    --exclude "**/*.d.ts"
  "${node_bin}" "${repo_root}/tools/dev/coverage-normalize.mjs" || true
}

build_run_array() {
  local PLATFORM_FLAGS=(--target-platforms prelude//platforms:default)
  local -a TARGETS=()
  if [[ $# -gt 0 ]]; then
    TARGETS=("$@")
  else
    # Default behavior: run the full suite (Buck schedules execution internally).
    TARGETS=("//...")
  fi
  # Create a small wrapper script to execute tests and always kill the per-run buck2 daemon.
  local TMP_SCRIPT_DIR TMP_SCRIPT
  TMP_SCRIPT_DIR=$(mktemp -d "${TMPDIR:-/tmp}/verify-run-$$-XXXXXX")
  TMP_SCRIPT="$TMP_SCRIPT_DIR/run.sh"
  cat >"$TMP_SCRIPT" <<'EOS'
#!/usr/bin/env bash
set -euo pipefail
ISO="v-$$"
# Record iso in the outer verify lock (if present) and emit a stable marker for status parsing.
if [[ -n "${BNX_VERIFY_LOCK_DIR:-}" ]]; then
  echo "${ISO}" > "${BNX_VERIFY_LOCK_DIR}/iso" 2>/dev/null || true
fi
echo "[verify] begin iso=${ISO}"
# Determine repo root for helper scripts spawned from this wrapper.
LIVE_ROOT="${LIVE_ROOT:-$(pwd)}"
export LIVE_ROOT
# Ensure we always teardown only our own buck2 daemon and terminate our process group on exit/signals
cleanup() {
  # Kill foreground/background children in our process group first (best-effort)
  kill -- -$$ >/dev/null 2>&1 || true
  "buck2" --isolation-dir "$ISO" kill >/dev/null 2>&1 || true
}
trap cleanup EXIT INT TERM HUP

# Start a single buck-daemon-reaper for this verify run (per batch). Individual zx tests register
# temp repo roots via BNX_BUCK_REAPER_STATE_FILE; they must not spawn their own reapers.
BNX_BUCK_REAPER_STATE_FILE="${TMPDIR:-/tmp}/bucknix-buck-reaper-${ISO}.txt"
export BNX_BUCK_REAPER_STATE_FILE
: > "$BNX_BUCK_REAPER_STATE_FILE" 2>/dev/null || true
PARENT_SIG="$(/bin/ps -p "$$" -o lstart= 2>/dev/null | tail -1 | tr -d '\n' || true)"
if command -v node >/dev/null 2>&1 && command -v nohup >/dev/null 2>&1 && [[ -n "$PARENT_SIG" ]]; then
  # Best-effort; reaper is hardened to self-exit.
  nohup node --experimental-top-level-await --experimental-strip-types --disable-warning=ExperimentalWarning \
    --import "$LIVE_ROOT/tools/dev/zx-init.mjs" \
    "$LIVE_ROOT/tools/tests/lib/buck-daemon-reaper.ts" \
    --parent "$$" --parent-sig "$PARENT_SIG" --state-file "$BNX_BUCK_REAPER_STATE_FILE" --poll-ms 1000 \
    >/dev/null 2>&1 & disown || true
fi

# Spawn a detached watchdog that reaps our isolation if this script dies abruptly (e.g., SIGKILL)
if command -v nohup >/dev/null 2>&1; then
  (
    nohup bash --noprofile --norc -c '
      parent="'"$$"'";
      if command -v node >/dev/null 2>&1; then
        node --experimental-top-level-await --experimental-strip-types --disable-warning=ExperimentalWarning --import '"$LIVE_ROOT"'/tools/dev/zx-init.mjs '"$LIVE_ROOT"'/tools/dev/buck-watchdog.ts --parent "$parent" --iso '"$ISO"' --patterns v- & disown
      else
        # Fallback to simple loop if node unavailable
        while kill -0 "$parent" >/dev/null 2>&1; do sleep 2; done
        buck2 --isolation-dir '"$ISO"' kill >/dev/null 2>&1 || true
      fi
    ' >/dev/null 2>&1 &
  ) || true
fi
# Suppress benign tailer/event-log and post-run INFO spam; keep superconsole visible.
export RUST_LOG="${RUST_LOG:-warn},buck2_client_ctx::file_tailers::tailer=off,buck2_event_log::writer=off"
export BUCK_LOG="${BUCK_LOG:-warn},buck2_client_ctx::file_tailers::tailer=off,buck2_event_log::writer=off"

run_batch() {
  local iso="$1"; shift
  local -a targets=( "$@" )
  local tsec="${VERIFY_TIMEOUT_SECS:-3600}"
  local tms=$(( tsec * 1000 ))
  local prefix=""
  if command -v timeout >/dev/null 2>&1; then
    prefix="timeout -k 10s ${tsec}s "
  else
    echo "error: timeout not found on PATH (expected via direnv/devshell)" 1>&2
    return 127
  fi
  local v8cov="${V8COV_DIR:-${LIVE_ROOT}/buck-out/tmp/node-v8-coverage}"
  mkdir -p "${v8cov}" >/dev/null 2>&1 || true
  # Console selection:
  # - auto (default): let Buck pick (superconsole on TTY, simple otherwise)
  # - super: force superconsole
  # - simple: force simple line-oriented output (useful for logs/CI)
  local console_flag=""
  case "${VERIFY_CONSOLE:-auto}" in
    auto) console_flag="";;
    super) console_flag="--console super";;
    simple) console_flag="--console simple";;
    *)
      echo "error: unknown --console value: ${VERIFY_CONSOLE} (expected auto|super|simple)" 1>&2
      return 2
      ;;
  esac

  # Compute Node dev-deps node_modules out path once per batch to avoid per-test nix eval storms.
  # This is consumed by tools/buck/zx_test.bzl via $ZX_TEST_NODE_MODULES_OUT.
  local node_bin=""
  node_bin="$(command -v node)"
  local zx_nm_out=""
  zx_nm_out="$(ZX_TEST_NODE_MODULES_IMPORTER="." "$node_bin" --experimental-strip-types --import "${LIVE_ROOT}/tools/dev/zx-init.mjs" "${LIVE_ROOT}/tools/dev/node-modules-build.ts" --print-out-paths)"

  local extra_test_env=""
  if [[ -n "${TEST_TIMING:-}" ]]; then
    extra_test_env="${extra_test_env} --env TEST_TIMING=\"${TEST_TIMING}\""
  fi
  if [[ -n "${TEST_TIMING_SUMMARY:-}" ]]; then
    extra_test_env="${extra_test_env} --env TEST_TIMING_SUMMARY=\"${TEST_TIMING_SUMMARY}\""
  fi

  local cmd="${prefix}buck2 --isolation-dir \"$iso\" test ${console_flag} --overall-timeout ${tsec}s --target-platforms prelude//platforms:default ${targets[*]} -- --env COVERAGE=\"${COVERAGE:-0}\" --env NODE_V8_COVERAGE=\"${v8cov}\" --env TEST_NODE_OPTIONS=\"--test-timeout=${tms}\" --env BNX_BUCK_REAPER_STATE_FILE=\"${BNX_BUCK_REAPER_STATE_FILE:-}\" --env ZX_TEST_NODE_MODULES_OUT=\"${zx_nm_out}\"${extra_test_env}"

  # If a verify log is configured, capture output without forcing buck2 to see a pipe:
  # 'script' allocates a pty, preserving the superconsole UX in the terminal while recording output.
  if [[ -n "${BNX_VERIFY_LOG_FILE:-}" ]]; then
    # Capture output for tailing/status. Note: this makes stdout a pipe, so Buck's console will
    # behave like non-interactive output; use --console=super if you want to force superconsole.
    echo "[verify] buck2 test begin iso=${iso} start_s=$(date +%s)" | tee -a "${BNX_VERIFY_LOG_FILE}"
    set +e
    bash --noprofile --norc -c "$cmd" 2>&1 | tee -a "${BNX_VERIFY_LOG_FILE}"
    rc="${PIPESTATUS[0]}"
    set -e
    echo "[verify] buck2 test exit iso=${iso} status=${rc} end_s=$(date +%s)" | tee -a "${BNX_VERIFY_LOG_FILE}"
    return "${rc}"
  else
    eval "$cmd"
  fi
}

  hk_between() {
    local target="${VERIFY_TARGET_FREE_GB:-12}"
    local df_line avail_kb use_pct_raw free_pct free_gb
    df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
    avail_kb="$(echo "$df_line" | awk '{print $4}')"
    use_pct_raw="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
    free_pct="$((100 - ${use_pct_raw:-0}))"
    free_gb="$((avail_kb/1024/1024))"
    if (( free_gb < 4 )); then
      echo "[verify] between-batch: very low space (<4GiB); purging repo-local temp dirs..." 1>&2
      chmod -R u+w "$LIVE_ROOT/buck-out/tmp" "$LIVE_ROOT/.tmp" >/dev/null 2>&1 || true
      rm -rf "$LIVE_ROOT/buck-out/tmp" "$LIVE_ROOT/.tmp" >/dev/null 2>&1 || true
      df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
      avail_kb="$(echo "$df_line" | awk '{print $4}')"
      use_pct_raw="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
      free_pct="$((100 - ${use_pct_raw:-0}))"
      free_gb="$((avail_kb/1024/1024))"
      echo "[verify] between-batch after purge: ${free_gb}GiB (~${free_pct}%)." 1>&2
    fi
    if (( free_gb < target )); then
      # Short optimise
      set +e
      timeout -k 5s 30s nix store optimise >/dev/null 2>&1
      set -e
      # Single bounded GC pass with escalating caps until target
      local cap
      for cap in 2G 4G 8G 16G 32G; do
        echo "[verify] between-batch GC --max-freed ${cap} ..." 1>&2
        df_line="$(df -Pk . 2>/dev/null | tail -n1 || true)"
        avail_kb="$(echo "$df_line" | awk '{print $4}')"
        use_pct_raw="$(echo "$df_line" | awk '{print $5}' | tr -d '%')"
        free_pct="$((100 - ${use_pct_raw:-0}))"
        free_gb="$((avail_kb/1024/1024))"
        if (( free_gb >= target )); then
          break
        fi
        set +e
        timeout -k 5s 45s nix-store --gc --max-freed "${cap}" >/dev/null 2>&1
        set -e
      done
    fi
  }

STATUS=0
run_batch "$ISO" "$@" || STATUS=$?
# Final best-effort cleanup
cleanup || true
exit "$STATUS"
EOS
  chmod +x "$TMP_SCRIPT"
  # External timeout policy: 900s (10 minutes) for both full suite and single focused tests
  local RUN_TIMEOUT=()
  if [[ -n ${TIMEOUT_CMD+x} && ${#TIMEOUT_CMD[@]} -gt 0 ]]; then
    if [[ ${#TARGETS[@]} -eq 1 && "${TARGETS[0]}" == *:* ]]; then
      # For single-target runs, also honor VERIFY_TIMEOUT_SECS
      RUN_TIMEOUT=(timeout -k 10s "${VERIFY_TIMEOUT_SECS:-3600}s")
    else
      RUN_TIMEOUT=("${TIMEOUT_CMD[@]}")
    fi
  fi
  if [[ ${#RUN_TIMEOUT[@]} -gt 0 ]]; then
    if [[ ${#TARGETS[@]} -gt 0 ]]; then
      RUN=("${RUN_TIMEOUT[@]}" "$TMP_SCRIPT" "${TARGETS[@]}")
    else
      RUN=("${RUN_TIMEOUT[@]}" "$TMP_SCRIPT")
    fi
  else
    if [[ ${#TARGETS[@]} -gt 0 ]]; then
      RUN=("$TMP_SCRIPT" "${TARGETS[@]}")
    else
      RUN=("$TMP_SCRIPT")
    fi
  fi
}

export NO_NODE_MODULES_LINK=1
# Prefer linking by default; allow caller override
export NO_NODE_MODULES_LINK="${NO_NODE_MODULES_LINK:-0}"
if [[ ${#ARGS[@]} -eq 0 ]]; then
build_run_array
else
  build_run_array "${ARGS[@]}"
fi

set +e
# This script already re-execs itself into the dev shell near the top. Do not `exec` the test
# runner here, because we need to run the merged coverage aggregation afterward.
"${RUN[@]}"
STATUS="$?"
set -e

if [[ "${STATUS}" == "0" ]]; then
  run_merged_coverage_report "${ROOT_DIR}"
fi

exit "${STATUS}"
