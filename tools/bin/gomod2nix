#!/usr/bin/env bash
set -euo pipefail

# Uniform gomod2nix entrypoint for dev and CI.
# Prefer a flake app, then shell, then a bare binary on PATH.

ARGS=("$@")

try_run() {
  local cmd=(bash -lc "$1")
  if "${cmd[@]}"; then
    exit 0
  fi
}

# Prefer upstream flake first on hosts where nixpkgs may not expose apps
try_run "nix run github:nix-community/gomod2nix -- ${ARGS[*]}" || true

# Fallback to upstream shell
try_run "nix shell github:nix-community/gomod2nix -c bash -lc 'gomod2nix ${ARGS[*]}'" || true

# Then try nixpkgs app and shell
try_run "nix run nixpkgs#gomod2nix -- ${ARGS[*]}" || true
try_run "nix shell nixpkgs#gomod2nix -c bash -lc 'gomod2nix ${ARGS[*]}'" || true

# 5) fallback to PATH
if command -v gomod2nix >/dev/null 2>&1; then
  gomod2nix "${ARGS[@]}"
  exit 0
fi

echo "error: gomod2nix is not available via nix or PATH" >&2
exit 127


