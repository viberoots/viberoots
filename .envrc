if [[ "${NIX_CONFIG:-}" != *"warn-dirty = false"* ]]; then
  export NIX_CONFIG="warn-dirty = false ${NIX_CONFIG:-}"
fi
# Silence Node's ExperimentalWarning for --experimental-strip-types without hiding other warnings
export NODE_OPTIONS="--disable-warning=ExperimentalWarning${NODE_OPTIONS:+ $NODE_OPTIONS}"
use flake
