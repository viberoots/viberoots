{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "types": ["node"],
    "typeRoots": ["./types", "./node_modules/@types"],
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": false,
    "checkJs": false,
    "noEmit": true,
    "strict": true,
    "allowImportingTsExtensions": true
  },
  "include": ["types/**/*.d.ts", "**/*.ts"],
  "exclude": ["**/node_modules/**", "**/dist/**", "**/build/**", "**/buck-out/**"]
}
