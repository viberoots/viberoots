# Isolation: prevent shadow dependencies
node-linker=isolated
package-import-method=clone-or-copy

# Standardize patch location for provider wiring
patches-dir=patches/node

# Per-importer lockfiles: each workspace package (apps/*, libs/*) manages its own pnpm-lock.yaml.
# This enables importer-scoped Buck2 providers for precise rebuild invalidation.
# Required for: fine-grained invalidation, per-importer Nix derivations, isolation guarantees.
shared-workspace-lockfile=false
