#!/usr/bin/env bash
set -euo pipefail

env_or_default() {
  local default_value="$1"
  shift
  local name value
  for name in "$@"; do
    value="${!name:-}"
    if [[ -n "${value}" ]]; then
      printf '%s' "${value}"
      return 0
    fi
  done
  printf '%s' "${default_value}"
}

mode="$(env_or_default flake VBR_CONSUMER VBR_CONSUMER_MODE VIBEROOTS_CONSUMER_MODE VIBROOTS_CONSUMER_MODE)"
mode_explicit=0
if [[ -n "${VBR_CONSUMER:-}" || -n "${VBR_CONSUMER_MODE:-}" || -n "${VIBEROOTS_CONSUMER_MODE:-}" || -n "${VIBROOTS_CONSUMER_MODE:-}" ]]; then
  mode_explicit=1
fi
ref="$(env_or_default main VBR_REF VIBEROOTS_REF)"
rev="$(env_or_default "" VBR_REV VIBEROOTS_REV)"
rev_explicit=0
if [[ -n "${VBR_REV:-}" || -n "${VIBEROOTS_REV:-}" ]]; then
  rev_explicit=1
fi
post_clone="$(env_or_default 0 VBR_POST_CLONE VIBEROOTS_POST_CLONE)"
update="$(env_or_default 0 VBR_UPDATE VIBEROOTS_UPDATE)"
ref_explicit=0
if [[ -n "${VBR_REF:-}" || -n "${VIBEROOTS_REF:-}" ]]; then
  ref_explicit=1
fi
workspace_root="$(env_or_default "" VBR_WORKSPACE_ROOT)"
workspace_name=""
viberoots_url="$(env_or_default "" VBR_URL VBR_VIBEROOTS_URL VIBEROOTS_URL)"
bootstrap_tool_url="$(env_or_default "" VBR_BOOTSTRAP_TOOL_URL VIBEROOTS_BOOTSTRAP_TOOL_URL)"
official_submodule_url="https://github.com/viberoots/viberoots.git"
submodule_url="$(env_or_default "${official_submodule_url}" VBR_SUBMODULE VBR_SUBMODULE_URL VIBEROOTS_SUBMODULE_URL)"
trust_submodule_url="$(env_or_default 0 VBR_TRUST_SUBMODULE VBR_TRUST_SUBMODULE_URL VIBEROOTS_TRUST_SUBMODULE_URL)"
install_nix="$(env_or_default 1 VBR_INSTALL_NIX VIBEROOTS_INSTALL_NIX)"
allow_nix_install="$(env_or_default 0 VBR_ALLOW_NIX_INSTALL VIBEROOTS_ALLOW_NIX_INSTALL)"
trust_nix_user="$(env_or_default prompt VBR_TRUST_NIX_USER VIBEROOTS_TRUST_NIX_USER)"
run_install="$(env_or_default 1 VBR_RUN_INSTALL VIBEROOTS_RUN_INSTALL)"
run_validate="$(env_or_default 0 VBR_RUN_VALIDATE VIBEROOTS_RUN_VALIDATE)"
dry_run="$(env_or_default 0 VBR_DRY_RUN VIBEROOTS_DRY_RUN)"
direnv_allow="$(env_or_default 1 VBR_DIRENV_ALLOW VIBEROOTS_DIRENV_ALLOW)"
ui_color_enabled=0

truthy() {
  case "${1:-}" in
    1 | true | TRUE | yes | YES | on | ON | always | ALWAYS) return 0 ;;
    *) return 1 ;;
  esac
}

falsy() {
  case "${1:-}" in
    0 | false | FALSE | no | NO | off | OFF | never | NEVER) return 0 ;;
    *) return 1 ;;
  esac
}

default_viberoots_url() {
  if [[ -n "${rev}" ]]; then
    if [[ "${ref_explicit}" == "1" ]]; then
      printf 'git+https://github.com/viberoots/viberoots.git?ref=%s&rev=%s' "${ref}" "${rev}"
    else
      printf 'git+https://github.com/viberoots/viberoots.git?rev=%s' "${rev}"
    fi
  else
    printf 'git+https://github.com/viberoots/viberoots.git?ref=%s' "${ref}"
  fi
}

discover_workspace_root() {
  local dir
  dir="$(pwd -P)"
  while true; do
    if [[ -f "${dir}/.viberoots/workspace/flake.nix" ]] ||
      [[ -f "${dir}/flake.lock" ]] ||
      [[ -f "${dir}/.buckroot" && -d "${dir}/projects" ]] ||
      [[ -e "${dir}/.viberoots/current" ]]; then
      printf '%s' "${dir}"
      return 0
    fi
    local parent
    parent="$(dirname "${dir}")"
    [[ "${parent}" != "${dir}" ]] || break
    dir="${parent}"
  done
  pwd -P
}

ui_init_color() {
  ui_color_enabled=0
  if [[ -n "${NO_COLOR:-}" ]] || falsy "${VBR_COLOR:-}"; then
    return 0
  fi
  if truthy "${VBR_COLOR:-}" || truthy "${FORCE_COLOR:-}" || truthy "${CLICOLOR_FORCE:-}"; then
    ui_color_enabled=1
    return 0
  fi
  if [[ -t 1 || -n "${COLORTERM:-}" || -n "${TERM_PROGRAM:-}" ]]; then
    ui_color_enabled=1
  fi
}

ui_use_color() {
  [[ "${ui_color_enabled}" == "1" ]]
}

ui_color() {
  local code="$1"
  local value="$2"
  if ui_use_color; then
    printf '\033[%sm%s\033[0m' "${code}" "${value}"
  else
    printf '%s' "${value}"
  fi
}

ui_heading() {
  ui_color "1;38;5;141" "$1"
  printf '\n'
}

ui_status() {
  local kind="$1"
  local label="$2"
  local detail="${3:-}"
  local mark gap label_text detail_text
  case "${kind}" in
    set)
      mark="$(ui_color "35;1" "set")"
      gap="   "
      ;;
    ok)
      mark="$(ui_color "32;1" "ok")"
      gap="    "
      ;;
    warn)
      mark="$(ui_color "33;1" "warn")"
      gap="  "
      ;;
    *)
      mark="$(ui_color "34;1" "run")"
      gap="   "
      ;;
  esac
  label_text="$(ui_color "1" "${label}")"
  detail_text="$(ui_color "2" "${detail}")"
  if ui_use_color; then
    if [[ -n "${detail}" ]]; then
      printf '  %s%s%s %s\n' "${mark}" "${gap}" "${label_text}" "${detail_text}"
    else
      printf '  %s%s%s\n' "${mark}" "${gap}" "${label_text}"
    fi
  elif [[ -n "${detail}" ]]; then
    printf '  %-5s %s %s\n' "${mark}" "${label}" "${detail}"
  else
    printf '  %-5s %s\n' "${mark}" "${label}"
  fi
}

ui_step() {
  ui_status run "$@"
}

ui_set() {
  ui_status set "$@"
}

ui_ok() {
  ui_status ok "$@"
}

ui_warn() {
  ui_status warn "$@"
}

ui_list() {
  local item
  for item in "$@"; do
    printf '    - %s\n' "${item}"
  done
}

ui_continuation_list() {
  local item bullet text
  for item in "$@"; do
    if ui_use_color; then
      bullet="$(ui_color "2" "-")"
      text="$(ui_color "2" "${item}")"
      printf '      %s %s\n' "${bullet}" "${text}"
    else
      printf '      - %s\n' "${item}"
    fi
  done
}

usage() {
  cat >&2 <<'EOF'
usage: bootstrap [--mode flake|submodule] [--ref <ref>] [--rev <sha>] [--workspace-root <dir>]
                 [--workspace-name <name>] [--viberoots-url <flake-ref>]
                 [--submodule-url <git-url>] [--no-run-install] [--run-validate]
                 [--trust-submodule-url] [--allow-nix-install] [--trust-nix-user]
                 [--no-install-nix] [--no-trust-nix-user] [--no-direnv-allow]
                 [--post-clone] [--dry-run]

Defaults:
  --mode flake
  --ref main
  --rev disabled
  --install-nix
  --allow-nix-install disabled; prompt when interactive
  --trust-nix-user prompt when interactive
  --run-install
  --run-validate disabled
  --direnv-allow
  --post-clone disabled
  --dry-run disabled
  --viberoots-url git+https://github.com/viberoots/viberoots.git?ref=<ref> or ?rev=<sha>
  --submodule-url https://github.com/viberoots/viberoots.git

Examples:
  curl -fsSL https://viberoots.dev/bootstrap | bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_CONSUMER=submodule bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_INSTALL_NIX=0 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_ALLOW_NIX_INSTALL=1 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_TRUST_NIX_USER=1 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_RUN_INSTALL=0 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_RUN_VALIDATE=1 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_DIRENV_ALLOW=0 bash
  curl -fsSL https://viberoots.dev/bootstrap | VBR_DRY_RUN=1 bash
  curl -fsSL https://viberoots.dev/post-clone | bash
EOF
  exit 2
}

ui_init_color
export VBR_HOST_PATH="${VBR_HOST_PATH:-${PATH:-}}"

load_nix_profile() {
  if [[ -n "${VIBEROOTS_NIX_PROFILE_SCRIPT:-}" && -f "${VIBEROOTS_NIX_PROFILE_SCRIPT}" ]]; then
    # shellcheck disable=SC1090
    source "${VIBEROOTS_NIX_PROFILE_SCRIPT}"
    return 0
  fi
  for __candidate in \
    "/nix/var/nix/profiles/default/etc/profile.d/nix-daemon.sh" \
    "${HOME}/.nix-profile/etc/profile.d/nix.sh"
  do
    if [[ -f "${__candidate}" ]]; then
      # shellcheck disable=SC1090
      source "${__candidate}"
      return 0
    fi
  done
  return 1
}

refresh_nix_profile_path() {
  local __dir
  for __dir in "${HOME}/.nix-profile/bin" "/nix/var/nix/profiles/default/bin"; do
    if [[ -d "${__dir}" && ":${PATH}:" != *":${__dir}:"* ]]; then
      PATH="${PATH}:${__dir}"
    fi
  done
  export PATH
}

select_nix_bin() {
  local candidate
  if [[ -n "${VBR_NIX_BIN:-}" && -x "${VBR_NIX_BIN}" ]]; then
    export VBR_NIX_BIN
    return 0
  fi
  if [[ "${VIBEROOTS_TEST_IGNORE_HOST_PROFILE_NIX:-0}" != "1" && -x "/nix/var/nix/profiles/default/bin/nix" ]]; then
    export VBR_NIX_BIN="/nix/var/nix/profiles/default/bin/nix"
    return 0
  fi
  candidate="$(command -v nix 2>/dev/null || true)"
  if [[ -n "${candidate}" ]]; then
    export VBR_NIX_BIN="${candidate}"
    return 0
  fi
  return 1
}

nix_cmd() {
  select_nix_bin || {
    echo "error: nix is required but no usable nix binary was found" >&2
    exit 1
  }
  "${VBR_NIX_BIN}" "$@"
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "error: required command not found: $1" >&2
    exit 1
  fi
}

git_is_usable() {
  command -v git >/dev/null 2>&1 && git --version >/dev/null 2>&1
}

is_macos() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]
}

macos_developer_tools_ready() {
  command -v xcode-select >/dev/null 2>&1 || return 1
  command -v xcrun >/dev/null 2>&1 || return 1
  xcode-select -p >/dev/null 2>&1 || return 1
  xcrun --find clang >/dev/null 2>&1 || return 1
  xcrun --sdk macosx --show-sdk-path >/dev/null 2>&1 || return 1
}

ensure_macos_developer_tools() {
  is_macos || return 0
  if macos_developer_tools_ready; then
    ui_ok "xcode" "developer tools ready"
    return 0
  fi
  if ! command -v xcode-select >/dev/null 2>&1; then
    cat >&2 <<'EOF'
error: macOS developer tools are required, but xcode-select is not available.

Install Xcode or the Xcode Command Line Tools, then rerun bootstrap.
EOF
    exit 1
  fi

  ui_warn "xcode" "developer tools missing"
  if xcode-select --install >/dev/null 2>&1; then
    cat >&2 <<'EOF'
Started the Xcode Command Line Tools installer.

Complete the Apple installer prompt, then rerun this viberoots command.
If you prefer full Xcode, install it from the App Store or Apple Developer,
run `sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer`,
then rerun this command.
EOF
    exit 1
  fi

  cat >&2 <<'EOF'
error: macOS developer tools are required, but viberoots could not start the installer.

If an Apple installer prompt is already open, complete it, then rerun this command.
Otherwise run `xcode-select --install` manually, or install full Xcode and select it
with `sudo xcode-select --switch /Applications/Xcode.app/Contents/Developer`.
EOF
  exit 1
}

ensure_git_metadata_writable() {
  local git_probe
  git_probe="$(git rev-parse --git-path viberoots-bootstrap-write-test 2>/dev/null || true)"
  if [[ -z "${git_probe}" ]]; then
    echo "error: unable to resolve Git metadata path for ${workspace_root}" >&2
    exit 1
  fi
  if ! { : >"${git_probe}"; } 2>/dev/null; then
    cat >&2 <<EOF
error: Git metadata is not writable for ${workspace_root}

Submodule mode needs to update the repository index and .git/modules state.
The workspace files may be writable while .git is read-only, which prevents
commands such as 'git submodule add' from creating .git/index.lock.

Fix: rerun bootstrap from an environment that can write ${git_probe%/*}, or
use flake mode in restricted sandboxes that cannot grant .git write access.
EOF
    exit 1
  fi
  rm -f "${git_probe}" 2>/dev/null || true
}

gitmodules_has_viberoots_submodule() {
  [[ -f .gitmodules ]] &&
    git config -f .gitmodules --get-regexp '^submodule\..*\.path$' |
      awk '{print $2}' |
      grep -qx 'viberoots'
}

gitmodules_viberoots_url() {
  if [[ ! -f .gitmodules ]]; then
    return 1
  fi
  local section
  section="$(
    git config -f .gitmodules --get-regexp '^submodule\..*\.path$' |
      awk '$2 == "viberoots" {print $1; exit}'
  )"
  if [[ -z "${section}" ]]; then
    return 1
  fi
  git config -f .gitmodules --get "${section%.path}.url"
}

is_official_submodule_url() {
  case "$1" in
    "${official_submodule_url}"|"https://github.com/viberoots/viberoots"|"git@github.com:viberoots/viberoots.git")
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

source_git_remote_url() {
  local source="$1"
  source="${source#git+}"
  source="${source%%\?*}"
  source="${source%%#*}"
  case "${source}" in
    github:viberoots/viberoots|github:viberoots/viberoots/*)
      printf '%s' "${official_submodule_url}"
      ;;
    *)
      printf '%s' "${source}"
      ;;
  esac
}

is_official_viberoots_source() {
  local remote
  remote="$(source_git_remote_url "$1")"
  is_official_submodule_url "${remote}"
}

probe_ref_for_source_access() {
  if [[ -n "${rev}" && "${ref_explicit}" != "1" ]]; then
    printf '%s' HEAD
  else
    printf '%s' "${ref}"
  fi
}

assert_viberoots_source_access() {
  local source="$1"
  local remote ref_probe output status
  remote="$(source_git_remote_url "${source}")"
  ref_probe="$(probe_ref_for_source_access)"
  output="$(git ls-remote --exit-code "${remote}" "${ref_probe}" 2>&1)" || status=$?
  status="${status:-0}"
  if [[ "${status}" == "0" ]]; then
    return 0
  fi
  if is_official_viberoots_source "${source}"; then
    cat >&2 <<EOF
error: viberoots is currently in closed beta

This bootstrap script needs access to the private viberoots GitHub repository,
but Git could not read ${remote}.

If you should have access, make sure you are signed in to GitHub for Git over
HTTPS or SSH, then retry this command. If you do not have access yet, ask for
an invite to the viberoots closed beta.
EOF
  else
    cat >&2 <<EOF
error: unable to read the configured viberoots source

Git could not read ${remote}.
Source: ${source}

Check the repository URL, selected ref, network access, and Git credentials,
then retry bootstrap.
EOF
  fi
  if [[ -n "${output}" ]]; then
    printf '\nGit said:\n%s\n' "${output}" >&2
  fi
  exit 1
}

confirm_trusted_submodule_url() {
  local url="$1"
  if is_official_submodule_url "${url}" || [[ "${trust_submodule_url}" == "1" ]]; then
    return 0
  fi
  cat >&2 <<EOF
warning: submodule mode will use a non-default viberoots repository:
  ${url}

That repository can run non-viberoots code during setup, install, build, and validation.
Only continue if you trust this repository and the selected ref.
EOF
  if ! { : </dev/tty >/dev/tty; } 2>/dev/null; then
    echo "error: refusing non-default submodule URL without confirmation; rerun with VBR_TRUST_SUBMODULE=1 if this is intentional" >&2
    exit 1
  fi
  local answer
  printf 'Type "yes" to continue: ' >/dev/tty
  IFS= read -r answer </dev/tty
  if [[ "${answer}" != "yes" ]]; then
    echo "error: refusing non-default submodule URL" >&2
    exit 1
  fi
}

confirm_nix_install() {
  if [[ "${allow_nix_install}" == "1" ]]; then
    return 0
  fi
  cat >&2 <<'EOF'
Nix was not found. viberoots can install it with the Determinate Nix installer.

This is a system-level developer tool installation. It may create /nix,
configure launch services or daemon state, and change shell profile integration.
EOF
  if ! { : </dev/tty >/dev/tty; } 2>/dev/null; then
    echo "error: refusing to install Nix without confirmation; rerun with --allow-nix-install or VBR_ALLOW_NIX_INSTALL=1 if this is intentional" >&2
    exit 1
  fi
  local answer
  printf 'Install Nix now? Type "yes" to continue: ' >/dev/tty
  IFS= read -r answer </dev/tty
  if [[ "${answer}" != "yes" ]]; then
    echo "error: refusing to install Nix" >&2
    exit 1
  fi
}

confirm_trust_nix_user() {
  if [[ "${trust_nix_user}" == "1" ]]; then
    return 0
  fi
  cat >&2 <<'EOF'
viberoots can add the current user to Nix trusted users.

This is a system-level Nix daemon configuration change. Trusted users can set
restricted Nix options such as build hooks, trusted caches, and remote builders.
Only continue on a personal or administered development machine where this is
intentional.
EOF
  if ! { : </dev/tty >/dev/tty; } 2>/dev/null; then
    ui_warn "nix trust" "skipped; no interactive terminal for confirmation"
    return 1
  fi
  local answer
  printf 'Trust the current user for Nix now? Type "yes" to continue: ' >/dev/tty
  IFS= read -r answer </dev/tty
  if [[ "${answer}" != "yes" ]]; then
    ui_warn "nix trust" "skipped by user"
    return 1
  fi
  return 0
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --mode)
      mode="${2:-}"
      mode_explicit=1
      shift 2
      ;;
    --mode=*)
      mode="${1#--mode=}"
      mode_explicit=1
      shift
      ;;
    --ref)
      ref="${2:-}"
      ref_explicit=1
      shift 2
      ;;
    --ref=*)
      ref="${1#--ref=}"
      ref_explicit=1
      shift
      ;;
    --rev)
      rev="${2:-}"
      rev_explicit=1
      shift 2
      ;;
    --rev=*)
      rev="${1#--rev=}"
      rev_explicit=1
      shift
      ;;
    --workspace-root)
      workspace_root="${2:-}"
      shift 2
      ;;
    --workspace-root=*)
      workspace_root="${1#--workspace-root=}"
      shift
      ;;
    --workspace-name)
      workspace_name="${2:-}"
      shift 2
      ;;
    --workspace-name=*)
      workspace_name="${1#--workspace-name=}"
      shift
      ;;
    --viberoots-url)
      viberoots_url="${2:-}"
      shift 2
      ;;
    --viberoots-url=*)
      viberoots_url="${1#--viberoots-url=}"
      shift
      ;;
    --submodule-url)
      submodule_url="${2:-}"
      shift 2
      ;;
    --submodule-url=*)
      submodule_url="${1#--submodule-url=}"
      shift
      ;;
    --trust-submodule-url)
      trust_submodule_url=1
      shift
      ;;
    --run-install)
      run_install=1
      shift
      ;;
    --no-run-install)
      run_install=0
      shift
      ;;
    --install-nix)
      install_nix=1
      shift
      ;;
    --allow-nix-install)
      allow_nix_install=1
      shift
      ;;
    --trust-nix-user)
      trust_nix_user=1
      shift
      ;;
    --no-install-nix)
      install_nix=0
      shift
      ;;
    --no-trust-nix-user)
      trust_nix_user=0
      shift
      ;;
    --run-validate)
      run_validate=1
      shift
      ;;
    --no-run-validate)
      run_validate=0
      shift
      ;;
    --direnv-allow)
      direnv_allow=1
      shift
      ;;
    --no-direnv-allow|--no-direnv)
      direnv_allow=0
      shift
      ;;
    --dry-run)
      dry_run=1
      shift
      ;;
    --post-clone)
      post_clone=1
      shift
      ;;
    -h|--help)
      usage
      ;;
    *)
      echo "error: unknown argument: $1" >&2
      usage
      ;;
  esac
done

if [[ "${mode}" != "flake" && "${mode}" != "submodule" ]]; then
  echo "error: --mode must be flake or submodule" >&2
  exit 2
fi
if [[ "${install_nix}" != "0" && "${install_nix}" != "1" ]]; then
  echo "error: VBR_INSTALL_NIX must be 0 or 1" >&2
  exit 2
fi
if [[ "${allow_nix_install}" != "0" && "${allow_nix_install}" != "1" ]]; then
  echo "error: VBR_ALLOW_NIX_INSTALL must be 0 or 1" >&2
  exit 2
fi
if [[ "${trust_nix_user}" != "0" && "${trust_nix_user}" != "1" && "${trust_nix_user}" != "prompt" ]]; then
  echo "error: VBR_TRUST_NIX_USER must be 0, 1, or prompt" >&2
  exit 2
fi
if [[ "${trust_submodule_url}" != "0" && "${trust_submodule_url}" != "1" ]]; then
  echo "error: VBR_TRUST_SUBMODULE must be 0 or 1" >&2
  exit 2
fi
if [[ "${run_install}" != "0" && "${run_install}" != "1" ]]; then
  echo "error: VBR_RUN_INSTALL must be 0 or 1" >&2
  exit 2
fi
if [[ "${run_validate}" != "0" && "${run_validate}" != "1" ]]; then
  echo "error: VBR_RUN_VALIDATE must be 0 or 1" >&2
  exit 2
fi
if [[ "${dry_run}" != "0" && "${dry_run}" != "1" ]]; then
  echo "error: VBR_DRY_RUN must be 0 or 1" >&2
  exit 2
fi
if [[ "${direnv_allow}" != "0" && "${direnv_allow}" != "1" ]]; then
  echo "error: VBR_DIRENV_ALLOW must be 0 or 1" >&2
  exit 2
fi
if [[ "${post_clone}" != "0" && "${post_clone}" != "1" ]]; then
  echo "error: VBR_POST_CLONE must be 0 or 1" >&2
  exit 2
fi
if [[ "${update}" != "0" && "${update}" != "1" ]]; then
  echo "error: VBR_UPDATE must be 0 or 1" >&2
  exit 2
fi
if [[ -n "${rev}" && ! "${rev}" =~ ^[0-9a-fA-F]{40}$ ]]; then
  echo "error: --rev must be a full 40-character commit SHA" >&2
  exit 2
fi
if [[ "${run_validate}" == "1" && "${direnv_allow}" != "1" ]]; then
  echo "error: VBR_RUN_VALIDATE=1 requires VBR_DIRENV_ALLOW=1" >&2
  exit 2
fi

workspace_root="${workspace_root:-$(discover_workspace_root)}"
workspace_root="$(cd "$(dirname "${workspace_root}")" && pwd)/$(basename "${workspace_root}")"
workspace_name="${workspace_name:-$(basename "${workspace_root}")}"

checked_in_lock_file() {
  local lock_file="${workspace_root}/flake.lock"
  if [[ ! -f "${lock_file}" ]]; then
    cat >&2 <<EOF
error: post-clone requires an existing checked-in flake.lock

This command repairs an already checked-in viberoots consumer workspace. For a
new workspace, use normal bootstrap:
  curl -fsSL https://viberoots.dev/bootstrap | bash

no tracked files were modified

repair: run viberoots update
EOF
    exit 1
  fi
  printf '%s' "${lock_file}"
}

extract_checked_in_locked_rev() {
  local lock_file="${1:-}"
  [[ -n "${lock_file}" && -f "${lock_file}" ]] || return 0
  local locked_rev
  locked_rev="$(
    awk '
      /"nodes"[[:space:]]*:/ { inNodes=1 }
      inNodes && /"viberoots"[[:space:]]*:/ { inNode=1; depth=0 }
      inNode {
        for (i = 1; i <= length($0); i++) {
          c = substr($0, i, 1)
          if (c == "{") depth++
          if (c == "}") {
            depth--
            if (depth <= 0 && $0 !~ /"rev"[[:space:]]*:/) inNode=0
          }
        }
      }
      inNode && /"locked"[[:space:]]*:/ { inLocked=1 }
      inNode && inLocked && /"rev"[[:space:]]*:/ {
        line=$0
        sub(/^.*"rev"[[:space:]]*:[[:space:]]*"/, "", line)
        sub(/".*$/, "", line)
        print line
        exit
      }
    ' "${lock_file}" 2>/dev/null || true
  )"
  printf '%s' "${locked_rev}"
}

checked_in_locked_rev() {
  local lock_file locked_rev
  lock_file="$(checked_in_lock_file)"
  [[ -n "${lock_file}" ]] || exit 1
  locked_rev="$(extract_checked_in_locked_rev "${lock_file}")"
  if [[ -z "${locked_rev}" ]]; then
    cat >&2 <<EOF
error: post-clone could not find nodes.viberoots.locked.rev in ${lock_file}

Use normal bootstrap for a new workspace, or rerun bootstrap with an explicit
VBR_REV=<full-commit-sha> if this workspace intentionally uses a different
flake input name.

no tracked files were modified

repair: run viberoots update
EOF
    exit 1
  fi
  if [[ ! "${locked_rev}" =~ ^[0-9a-fA-F]{40}$ ]]; then
    cat >&2 <<EOF
error: post-clone requires nodes.viberoots.locked.rev to be a full 40-character commit SHA; got: ${locked_rev}

no tracked files were modified

repair: run viberoots update
EOF
    exit 1
  fi
  printf '%s' "${locked_rev}"
}

valid_full_rev_or_empty() {
  local rev_value="$1"
  [[ -z "${rev_value}" || "${rev_value}" =~ ^[0-9a-fA-F]{40}$ ]]
}

tracked_file_contains_local_viberoots_source() {
  local file="$1"
  [[ -f "${file}" ]] || return 1
  grep -Eq 'viberoots\.url[[:space:]]*=[[:space:]]*"(path|git\+file):(\./)?(\.\./\.\./)?(\.viberoots/workspace/)?viberoots(-flake-input)?"' "${file}" ||
    grep -Fq -- '--override-input viberoots' "${file}"
}

detect_post_clone_mode() {
  local current_path="${workspace_root}/.viberoots/current"
  local local_source="${workspace_root}/viberoots"
  local filtered_source="${workspace_root}/.viberoots/workspace/viberoots-flake-input"
  local current_real local_real filtered_real link_target

  if [[ -L "${current_path}" ]]; then
    link_target="$(readlink "${current_path}" 2>/dev/null || true)"
    if [[ "${link_target}" == "../viberoots" ]]; then
      printf '%s\n%s' "submodule" ".viberoots/current"
      return 0
    fi
  fi

  if [[ -e "${current_path}" ]]; then
    current_real="$(cd "${current_path}" && pwd -P 2>/dev/null || true)"
    local_real=""
    filtered_real=""
    [[ -d "${local_source}" ]] && local_real="$(cd "${local_source}" && pwd -P 2>/dev/null || true)"
    [[ -d "${filtered_source}" ]] && filtered_real="$(cd "${filtered_source}" && pwd -P 2>/dev/null || true)"
    if [[ -n "${current_real}" && -n "${local_real}" && "${current_real}" == "${local_real}" ]]; then
      printf '%s\n%s' "submodule" ".viberoots/current"
      return 0
    fi
    if [[ -n "${current_real}" && -n "${filtered_real}" && "${current_real}" == "${filtered_real}" ]]; then
      printf '%s\n%s' "submodule" ".viberoots/current"
      return 0
    fi
    if [[ "${current_real}" == /nix/store/* ]]; then
      printf '%s\n%s' "flake" ".viberoots/current"
      return 0
    fi
  fi

  if tracked_file_contains_local_viberoots_source "${workspace_root}/.envrc"; then
    printf '%s\n%s' "submodule" ".envrc"
    return 0
  fi
  if tracked_file_contains_local_viberoots_source "${workspace_root}/flake.nix"; then
    printf '%s\n%s' "submodule" "flake.nix"
    return 0
  fi
  if tracked_file_contains_local_viberoots_source "${workspace_root}/.viberoots/workspace/flake.nix"; then
    printf '%s\n%s' "submodule" ".viberoots/workspace/flake.nix"
    return 0
  fi

  printf '%s\n%s' "flake" "default"
}

post_clone_mode_source=""
if [[ "${post_clone}" == "1" ]]; then
  if [[ "${mode_explicit}" != "1" ]]; then
    post_clone_mode_detection="$(detect_post_clone_mode)"
    mode="$(printf '%s\n' "${post_clone_mode_detection}" | sed -n '1p')"
    post_clone_mode_source="$(printf '%s\n' "${post_clone_mode_detection}" | sed -n '2p')"
  else
    post_clone_mode_source="explicit"
  fi
  if [[ "${mode}" == "flake" ]]; then
    locked_rev="$(checked_in_locked_rev)"
  else
    lock_file="$(checked_in_lock_file)"
    [[ -n "${lock_file}" ]] || exit 1
    locked_rev="$(extract_checked_in_locked_rev "${lock_file}")"
    if ! valid_full_rev_or_empty "${locked_rev}"; then
      cat >&2 <<EOF
error: post-clone requires nodes.viberoots.locked.rev to be a full 40-character commit SHA when present; got: ${locked_rev}

no tracked files were modified

repair: run viberoots update
EOF
      exit 1
    fi
  fi
  if [[ "${mode}" == "flake" && -n "${rev}" && "${rev}" != "${locked_rev}" ]]; then
    cat >&2 <<EOF
error: VBR_REV conflicts with checked-in flake.lock for post-clone

VBR_REV: ${rev}
locked:  ${locked_rev}

post-clone is for repairing local ignored state without advancing the checked-in
viberoots input.
no tracked files were modified

repair: run viberoots update
EOF
    exit 2
  fi
  if [[ "${mode}" == "flake" ]]; then
    rev="${locked_rev}"
    ref_explicit=0
    ref="locked"
  elif [[ "${rev_explicit}" == "1" ]]; then
    cat >&2 <<EOF
error: VBR_REV conflicts with submodule-mode post-clone

VBR_REV: ${rev}

post-clone in submodule mode uses the checked-in submodule gitlink as the
source of truth.
no tracked files were modified

repair: run viberoots update
EOF
    exit 2
  else
    rev=""
  fi
fi
viberoots_url="${viberoots_url:-$(default_viberoots_url)}"

run_install_flag=""
if [[ "${run_install}" == "1" ]]; then
  run_install_flag="--run-install"
fi
direnv_allow_flag=""
if [[ "${direnv_allow}" == "0" ]]; then
  direnv_allow_flag="--no-direnv"
fi
post_clone_flag=""
if [[ "${post_clone}" == "1" ]]; then
  post_clone_flag="--post-clone"
fi

actions=()
record_action() {
  actions+=("$1")
}

transaction_dir=".viberoots/bootstrap/transactions"
transaction_file="${transaction_dir}/current.json"
transaction_id=""
transaction_active=0
transaction_created=0
transaction_tmp_file=""
transaction_completed_file=""
install_handled_by_setup=0

json_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  value="${value//$'\n'/\\n}"
  printf '%s' "${value}"
}

json_value() {
  json_escape "$1"
}

flake_locked_rev() {
  local lock_file=".viberoots/workspace/flake.lock"
  [[ -f "${lock_file}" ]] || return 0
  awk '
    /"viberoots"/ { inNode=1 }
    inNode && /"locked"/ { inLocked=1 }
    inNode && inLocked && /"rev"/ {
      gsub(/[",]/, "", $2)
      print $2
      exit
    }
  ' "${lock_file}" 2>/dev/null || true
}

flake_requested_ref() {
  local flake_file=".viberoots/workspace/flake.nix"
  [[ -f "${flake_file}" ]] || return 0
  sed -n 's/.*viberoots\.url = "\(.*\)";.*/\1/p' "${flake_file}" | head -n 1
}

resolve_flake_rev() {
  local flake_ref="$1"
  nix_cmd flake metadata --refresh --json --accept-flake-config --no-write-lock-file "${flake_ref}" 2>/dev/null |
    sed -n 's/.*"rev":"\([^"]*\)".*/\1/p' |
    head -n 1 || true
}

resolve_submodule_target_rev() {
  local url="$1"
  local desired_ref="$2"
  git ls-remote "${url}" "${desired_ref}" 2>/dev/null | awk 'NR == 1 {print $1}' || true
}

gitlink_revision() {
  git ls-files -s viberoots 2>/dev/null | awk '$1 == "160000" {print $2; exit}'
}

current_source_rev() {
  if [[ "${mode}" == "submodule" && -d viberoots ]]; then
    git -C viberoots rev-parse HEAD 2>/dev/null || true
  elif [[ "${mode}" == "flake" ]]; then
    flake_locked_rev
  fi
}

current_source_ref() {
  if [[ "${mode}" == "submodule" ]]; then
    git -C viberoots rev-parse --abbrev-ref HEAD 2>/dev/null || true
  elif [[ "${mode}" == "flake" ]]; then
    flake_requested_ref
  fi
}

target_source_rev() {
  if [[ "${mode}" == "submodule" ]]; then
    if [[ "${post_clone}" == "1" ]]; then
      gitlink_revision
      return 0
    fi
    if [[ -n "${rev}" ]]; then
      printf '%s' "${rev}"
      return 0
    fi
    resolve_submodule_target_rev "${effective_source:-${submodule_url}}" "${ref}"
  elif [[ "${mode}" == "flake" ]]; then
    resolve_flake_rev "${viberoots_url}"
  fi
}

begin_transaction() {
  if [[ -f "${transaction_file}" ]]; then
    transaction_active=1
    record_action "resumed incomplete bootstrap transaction"
    echo "bootstrap transaction: resuming ${transaction_file}"
    return 0
  fi
  mkdir -p "${transaction_dir}"
  transaction_id="$(date -u +%Y%m%dT%H%M%SZ)-$$"
  transaction_tmp_file="${transaction_file}.tmp"
  local from_ref from_rev to_rev source
  from_ref="$(current_source_ref)"
  from_rev="$(current_source_rev)"
  to_rev="$(target_source_rev)"
  source="${effective_source:-${viberoots_url}}"
  cat >"${transaction_tmp_file}" <<EOF
{
  "schema": 1,
  "transactionId": "$(json_value "${transaction_id}")",
  "status": "planned",
  "ownerPid": $$,
  "startedAt": "$(date -u +%Y-%m-%dT%H:%M:%SZ)",
  "mode": "$(json_value "${mode}")",
  "workspaceRoot": "$(json_value "${workspace_root}")",
  "workspaceName": "$(json_value "${workspace_name}")",
  "source": "$(json_value "${source}")",
  "from": {
    "ref": "$(json_value "${from_ref:-unknown}")",
    "rev": "$(json_value "${from_rev:-unknown}")"
  },
  "to": {
    "ref": "$(json_value "${ref}")",
    "url": "$(json_value "${source}")",
    "rev": "$(json_value "${to_rev:-unknown}")"
  }
}
EOF
  mv "${transaction_tmp_file}" "${transaction_file}"
  transaction_tmp_file=""
  transaction_active=1
  transaction_created=1
  record_action "recorded bootstrap transaction"
}

complete_transaction() {
  [[ "${transaction_active}" == "1" && -f "${transaction_file}" ]] || return 0
  local done_dir="${transaction_dir}/completed"
  mkdir -p "${done_dir}"
  local done_id="${transaction_id:-$(date -u +%Y%m%dT%H%M%SZ)-$$}"
  transaction_completed_file="${done_dir}/${done_id}.json"
  mv "${transaction_file}" "${transaction_completed_file}"
  transaction_active=0
  record_action "completed bootstrap transaction"
}

cleanup_failed_post_clone_transaction() {
  local exit_code=$?
  trap - EXIT

  if [[ "${exit_code}" != "0" && "${post_clone}" == "1" ]]; then
    if [[ -n "${transaction_tmp_file}" ]]; then
      rm -f "${transaction_tmp_file}" ||
        echo "warning: could not remove failed bootstrap transaction temporary file" >&2
    fi
    if [[ "${transaction_created}" == "1" ]]; then
      rm -f "${transaction_file}" ||
        echo "warning: could not remove failed bootstrap transaction record" >&2
      if [[ -n "${transaction_completed_file}" ]]; then
        rm -f "${transaction_completed_file}" ||
          echo "warning: could not remove failed bootstrap transaction history" >&2
      fi
      rmdir "${transaction_dir}/completed" 2>/dev/null || true
      rmdir "${transaction_dir}" 2>/dev/null || true
      rmdir .viberoots/bootstrap 2>/dev/null || true
    fi
  fi

  exit "${exit_code}"
}

trap cleanup_failed_post_clone_transaction EXIT

migrate_legacy_buckconfig_prelude() {
  [[ -f .buckconfig ]] || return 1
  grep -Fq -- 'generated by viberoots/init-consumer' .buckconfig || return 1
  grep -Fq -- 'prelude = ./.viberoots/current/prelude' .buckconfig || return 1
  mkdir -p .viberoots/bootstrap/migrations
  local tmp_file=".viberoots/bootstrap/migrations/.buckconfig.$$"
  awk '
    { gsub(/prelude = \.\/\.viberoots\/current\/prelude/, "prelude = ./.viberoots/workspace/prelude"); print }
  ' .buckconfig >"${tmp_file}"
  if cmp -s .buckconfig "${tmp_file}"; then
    rm -f "${tmp_file}"
    return 1
  fi
  mv "${tmp_file}" .buckconfig
  record_action "migrated .buckconfig prelude path"
  ui_ok "migration" "refreshed .buckconfig prelude path"
  return 0
}

run_migrations() {
  local migrated=0
  if migrate_legacy_buckconfig_prelude; then
    migrated=1
  fi
  if [[ "${migrated}" == "0" ]]; then
    ui_ok "migrations" "no known migration steps necessary"
  fi
}

run_writable_migrations() {
  [[ "${post_clone}" != "1" ]] || return 0
  run_migrations
}

run_nix_init_consumer_command() {
  local init_tool_url="$1"
  nix_cmd run --refresh --accept-flake-config "${init_tool_url}#viberoots" -- \
    init-consumer \
    --mode flake \
    --workspace-root "${workspace_root}" \
    --workspace-name "${workspace_name}" \
    --viberoots-url "${viberoots_url}" \
    ${post_clone_flag:+"${post_clone_flag}"} \
    ${run_install_flag:+"${run_install_flag}"} \
    ${direnv_allow_flag:+"${direnv_allow_flag}"} \
    2> >(
      while IFS= read -r line; do
        [[ "${line}" == fetching\ Git\ repository\ * ]] && continue
        [[ "${line}" == remote:\ Enumerating\ objects:* ]] && continue
        [[ "${line}" == remote:\ Counting\ objects:* ]] && continue
        [[ "${line}" == remote:\ Compressing\ objects:* ]] && continue
        [[ "${line}" == remote:\ Total\ * ]] && continue
        [[ "${line}" == From\ *github.com/viberoots/viberoots ]] && continue
        if [[ "${line}" == "   "* && "${line}" == *".."* && "${line}" == *"main"* && "${line}" == *"-> main" ]]; then
          continue
        fi
        [[ "${line}" == "this derivation will be built:" ]] && continue
        [[ "${line}" == "  /nix/store/"*"-viberoots.drv" ]] && continue
        [[ "${line}" == "building '/nix/store/"*"-viberoots.drv'..." ]] && continue
        printf '%s\n' "${line}" >&2
      done
    )
}

run_nix_init_consumer() {
  local init_tool_url="${viberoots_url}"
  if [[ "${post_clone}" == "1" ]]; then
    init_tool_url="${bootstrap_tool_url:-git+https://github.com/viberoots/viberoots.git?ref=main}"
  fi
  ui_step "source" "fetching viberoots"
  if [[ "${post_clone}" == "1" ]]; then
    VBR_POST_CLONE=1 run_nix_init_consumer_command "${init_tool_url}"
  else
    VBR_BOOTSTRAP_PNPM_GENERATE=1 run_nix_init_consumer_command "${init_tool_url}"
  fi
}

required_bootstrap_files_present() {
  [[ -f .buckroot ]] &&
    [[ -f .buckconfig ]] &&
    [[ -f .envrc ]] &&
    [[ -f flake.nix ]] &&
    [[ -d projects ]] &&
    [[ -e .viberoots/current ]] &&
    [[ -f .viberoots/workspace/flake.nix ]] &&
    { [[ "${mode}" != "submodule" ]] || [[ -x viberoots/init ]]; }
}

file_contains_literal() {
  local file="$1"
  local needle="$2"
  [[ -f "${file}" ]] && grep -Fq -- "${needle}" "${file}"
}

submodule_source_matches() {
  if gitmodules_has_viberoots_submodule; then
    local configured_url
    configured_url="$(gitmodules_viberoots_url || true)"
    [[ "${configured_url:-${submodule_url}}" == "${submodule_url}" ]] || return 1
  fi
  [[ -d viberoots ]] || return 1
  if git -C viberoots rev-parse --verify --quiet "${ref}^{commit}" >/dev/null; then
    [[ "$(git -C viberoots rev-parse HEAD)" == "$(git -C viberoots rev-parse "${ref}^{commit}")" ]]
  elif git -C viberoots rev-parse --verify --quiet "origin/${ref}^{commit}" >/dev/null; then
    [[ "$(git -C viberoots rev-parse HEAD)" == "$(git -C viberoots rev-parse "origin/${ref}^{commit}")" ]]
  else
    return 0
  fi
}

bootstrap_source_matches() {
  if [[ "${mode}" == "flake" ]]; then
    file_contains_literal ".viberoots/workspace/flake.nix" "${viberoots_url}" &&
      ! grep -Fq -- '--override-input viberoots' .envrc
  else
    submodule_source_matches &&
      file_contains_literal ".envrc" '--override-input viberoots' &&
      [[ "$(readlink .viberoots/current 2>/dev/null || true)" == "../viberoots" ]]
  fi
}

target_revision_matches_current() {
  local target_rev current_rev
  target_rev="$(target_source_rev)"
  current_rev="$(current_source_rev)"
  [[ -z "${target_rev}" || -z "${current_rev}" || "${target_rev}" == "${current_rev}" ]]
}

bootstrap_ready() {
  required_bootstrap_files_present && bootstrap_source_matches && target_revision_matches_current
}

assert_post_clone_git_authority() {
  [[ "${post_clone}" == "1" ]] || return 0
  if ! (
    cd "${workspace_root}"
    git rev-parse --show-toplevel >/dev/null 2>&1
  ); then
    cat >&2 <<'EOF'
error: post-clone could not verify workspace cleanliness

environment failure: Git could not prove the workspace root.
no tracked files were modified

repair: restore Git worktree access and rerun viberoots post-clone
EOF
    exit 1
  fi
  if ! (
    cd "${workspace_root}"
    git status --short --untracked-files=normal --ignored=no >/dev/null 2>&1
  ); then
    cat >&2 <<'EOF'
error: post-clone could not verify workspace cleanliness

environment failure: Git could not read workspace status.
no tracked files were modified

repair: restore Git worktree access and rerun viberoots post-clone
EOF
    exit 1
  fi
}

assert_post_clone_tracked_clean() {
  [[ "${post_clone}" == "1" ]] || return 0
  local repo_root changed
  if ! repo_root="$(git rev-parse --show-toplevel 2>/dev/null)"; then
    cat >&2 <<'EOF'
error: post-clone could not verify workspace cleanliness

environment failure: Git could not prove the workspace root.
no tracked files were modified

repair: restore Git worktree access and rerun viberoots post-clone
EOF
    exit 1
  fi
  if ! changed="$(
    git -C "${repo_root}" status --short --untracked-files=normal --ignored=no 2>/dev/null
  )"; then
    cat >&2 <<'EOF'
error: post-clone could not verify workspace cleanliness

environment failure: Git could not read workspace status.
no tracked files were modified

repair: restore Git worktree access and rerun viberoots post-clone
EOF
    exit 1
  fi
  if [[ -z "${changed}" ]]; then
    return 0
  fi
  cat >&2 <<EOF
error: post-clone mutated workspace metadata

${changed}

post-clone is read-only by construction and may only repair ignored local state.
Run the intentional update path in a development checkout, then commit and
release the refreshed metadata:
  viberoots update
  git status
  git add -A && git commit
EOF
  exit 1
}

assert_post_clone_required_tracked_inputs() {
  [[ "${post_clone}" == "1" ]] || return 0
  if ! git -C "${workspace_root}" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    cat >&2 <<'EOF'
error: post-clone could not prove required tracked workspace inputs
no tracked files were modified

repair: run viberoots update
EOF
    exit 1
  fi
  local required_inputs=(".buckroot" ".buckconfig" ".envrc" ".gitignore")
  local rel
  for rel in "${required_inputs[@]}"; do
    if ! git -C "${workspace_root}" ls-files --error-unmatch -- "${rel}" >/dev/null 2>&1 ||
      [[ ! -f "${workspace_root}/${rel}" ]]; then
      cat >&2 <<EOF
error: post-clone found stale tracked generated file ${rel}
no tracked files were modified

repair: run viberoots update
EOF
      exit 1
    fi
  done
}

print_summary() {
  local status="$1"
  local source="$2"
  echo
  ui_heading "viberoots bootstrap summary"
  ui_ok "status" "${status}"
  ui_set "mode" "${mode}"
  ui_set "ref" "${ref}"
  if [[ -n "${rev}" ]]; then
    ui_set "rev" "${rev}"
  fi
  ui_set "workspace" "${workspace_root}"
  ui_set "workspace name" "${workspace_name}"
  ui_set "source" "${source}"
  ui_set "ensure nix" "$([[ "${install_nix}" == "1" ]] && echo yes || echo no)"
  ui_set "trust nix user" "${trust_nix_user}"
  ui_set "install" "$([[ "${run_install}" == "1" ]] && echo yes || echo no)"
  ui_set "validate" "$([[ "${run_validate}" == "1" ]] && echo yes || echo no)"
  ui_set "direnv allow" "$([[ "${direnv_allow}" == "1" ]] && echo yes || echo no)"
  ui_set "post-clone" "$([[ "${post_clone}" == "1" ]] && echo yes || echo no)"
  if [[ "${mode}" == "submodule" ]]; then
    ui_set "trust custom submodule" "$([[ "${trust_submodule_url}" == "1" ]] && echo yes || echo no)"
  fi
  ui_set "actions"
  if [[ "${#actions[@]}" -eq 0 ]]; then
    ui_continuation_list "no setup changes needed"
  else
    local action action_list=()
    for action in "${actions[@]}"; do
      action_list+=("${action}")
    done
    ui_continuation_list "${action_list[@]}"
  fi
}

ui_heading "viberoots bootstrap"
ui_set "mode" "${mode}"
ui_set "ref" "${ref}"
if [[ -n "${rev}" ]]; then
  ui_set "rev" "${rev}"
fi
ui_set "workspace" "${workspace_root}"
ui_set "workspace name" "${workspace_name}"
ui_set "ensure nix" "$([[ "${install_nix}" == "1" ]] && echo yes || echo no)"
if [[ "${install_nix}" == "1" ]]; then
  ui_set "allow nix install" "$([[ "${allow_nix_install}" == "1" ]] && echo yes || echo prompt)"
fi
ui_set "install" "$([[ "${run_install}" == "1" ]] && echo yes || echo no)"
ui_set "trust nix user" "${trust_nix_user}"
ui_set "validate" "$([[ "${run_validate}" == "1" ]] && echo yes || echo no)"
ui_set "direnv allow" "$([[ "${direnv_allow}" == "1" ]] && echo yes || echo no)"
ui_set "post-clone" "$([[ "${post_clone}" == "1" ]] && echo yes || echo no)"
if [[ "${post_clone}" == "1" ]]; then
  ui_set "mode source" "${post_clone_mode_source:-explicit}"
fi
ui_set "viberoots url" "${viberoots_url}"
if [[ "${post_clone}" == "1" ]]; then
  ui_warn "local state" "post-clone may repair ignored .viberoots, .direnv, shell helper, current, and workspace state"
  ui_step "tracked proof" "run git diff --exit-code afterward if you need proof no tracked files changed"
fi
if [[ "${mode}" == "submodule" ]]; then
  ui_set "submodule url" "${submodule_url}"
  ui_set "trust custom submodule url" "$([[ "${trust_submodule_url}" == "1" ]] && echo yes || echo no)"
fi
if [[ "${dry_run}" == "1" ]]; then
  ui_set "dry run" "yes"
  echo
  ui_heading "planned actions"
  if is_macos; then
    ui_list "verify Xcode Command Line Tools or full Xcode developer tools"
  fi
  if ! select_nix_bin >/dev/null 2>&1 && [[ "${install_nix}" == "1" ]]; then
    if [[ "${allow_nix_install}" == "1" ]]; then
      ui_list "install Nix with the Determinate Nix installer"
    else
      ui_list "prompt before installing Nix with the Determinate Nix installer"
    fi
  fi
  if [[ "${trust_nix_user}" == "1" ]]; then
    ui_list "add the current user to Nix trusted users if needed"
  elif [[ "${trust_nix_user}" == "prompt" ]]; then
    ui_list "prompt before adding the current user to Nix trusted users if needed"
  fi
  ui_list "create workspace directory if missing" "initialize git repository if missing"
  if [[ "${mode}" == "flake" ]]; then
    if [[ "${post_clone}" == "1" ]]; then
      ui_list "read checked-in flake.lock" "use locked viberoots revision ${rev}" "run viberoots init-consumer from ${viberoots_url}#viberoots without advancing the pin"
    else
      ui_list "run viberoots init-consumer from ${viberoots_url}#viberoots"
    fi
  else
    if [[ "${post_clone}" == "1" ]]; then
      ui_list "initialize checked-in viberoots submodule at ./viberoots without moving the gitlink"
      if [[ -n "${locked_rev:-}" ]]; then
        ui_list "compare checked-in flake.lock revision ${locked_rev} with the submodule gitlink"
      fi
    else
      ui_list "add or update viberoots submodule at ./viberoots"
    fi
    if ! is_official_submodule_url "${submodule_url}" && [[ "${trust_submodule_url}" != "1" ]]; then
      ui_list "require confirmation before using non-default submodule URL"
    fi
    ui_list "run ./viberoots/init"
  fi
  ui_list "run direnv setup through viberoots bootstrap"
  if [[ "${direnv_allow}" == "1" ]]; then
    ui_list "run direnv allow"
  fi
  if [[ "${run_install}" == "1" ]]; then
    ui_list "run i"
  fi
  if [[ "${run_validate}" == "1" ]]; then
    ui_list "run b && v"
  fi
  if [[ "${post_clone}" == "1" ]]; then
    if [[ "${run_install}" == "1" ]]; then
      ui_list "next validation command: b && v"
    else
      ui_list "next validation command: i && b && v"
    fi
  fi
  exit 0
fi

assert_post_clone_required_tracked_inputs
assert_post_clone_git_authority
ensure_macos_developer_tools

if ! select_nix_bin >/dev/null 2>&1; then
  if [[ "${install_nix}" != "1" ]]; then
    echo "error: nix is required; install Nix or rerun with VBR_INSTALL_NIX=1" >&2
    exit 1
  fi
  confirm_nix_install
  require_command curl
  echo "Nix not found; installing with the Determinate Nix installer..."
  record_action "installed Nix with the Determinate Nix installer"
  curl --proto '=https' --tlsv1.2 -sSf -L https://install.determinate.systems/nix |
    sh -s -- install --no-confirm
  load_nix_profile || true
  refresh_nix_profile_path
fi
if ! select_nix_bin >/dev/null 2>&1; then
  load_nix_profile || true
  refresh_nix_profile_path
fi
select_nix_bin || {
  echo "error: nix is required but no usable nix binary was found after loading profile paths" >&2
  exit 1
}

nix_config_value() {
  local key="$1"
  awk -v wanted="${key}" '
    $1 == wanted && $2 == "=" {
      for (i = 3; i <= NF; i++) {
        printf "%s%s", (i == 3 ? "" : " "), $i
      }
      printf "\n"
    }
  '
}

nix_user_is_trusted() {
  local user="$1"
  local config="$2"
  local groups token trusted
  groups="$(id -Gn "${user}" 2>/dev/null || true)"
  trusted="$(
    {
      printf '%s\n' "${config}" | nix_config_value trusted-users
      printf '%s\n' "${config}" | nix_config_value extra-trusted-users
    } | tr ' ' '\n'
  )"
  while IFS= read -r token; do
    [[ -n "${token}" ]] || continue
    [[ "${token}" == "*" || "${token}" == "${user}" ]] && return 0
    if [[ "${token}" == @* ]]; then
      case " ${groups} " in
        *" ${token#@} "*) return 0 ;;
      esac
    fi
  done <<<"${trusted}"
  return 1
}

append_trusted_nix_user() {
  local user="$1"
  local custom_conf="/etc/nix/nix.custom.conf"
  local conf="/etc/nix/nix.conf"
  sudo sh -s -- "${conf}" "${custom_conf}" "${user}" <<'SH'
set -eu
conf="$1"
custom_conf="$2"
user="$3"
mkdir -p "$(dirname "$conf")" "$(dirname "$custom_conf")"

rewrite_if_changed() {
  target="$1"
  candidate="$2"
  if [ ! -f "$target" ] || ! cmp -s "$target" "$candidate"; then
    cat "$candidate" > "$target"
  fi
  rm -f "$candidate"
}

if [ ! -f "$conf" ] || ! awk '
  $1 == "!include" && $2 == "nix.custom.conf" { found = 1 }
  END { exit(found ? 0 : 1) }
' "$conf"; then
  conf_tmp="$(mktemp "${conf}.tmp.XXXXXX")"
  awk '
    { lines[NR] = $0; last = $0 }
    END {
      for (i = 1; i <= NR; i++) print lines[i]
      if (NR > 0 && last !~ /^[[:space:]]*$/) print ""
      print "!include nix.custom.conf"
    }
  ' "$conf" 2>/dev/null > "$conf_tmp" || printf '%s\n' '!include nix.custom.conf' > "$conf_tmp"
  rewrite_if_changed "$conf" "$conf_tmp"
fi

custom_tmp="$(mktemp "${custom_conf}.tmp.XXXXXX")"
awk -v user="$user" '
  BEGIN { updated = 0 }
  {
    line = $0
    if (!updated && line ~ /^[[:space:]]*extra-trusted-users[[:space:]]*=/) {
      eq = index(line, "=")
      prefix = substr(line, 1, eq - 1)
      sub(/[[:space:]]+$/, "", prefix)
      value = substr(line, eq + 1)
      count = split(value, users, /[[:space:]]+/)
      found = 0
      rendered = ""
      for (i = 1; i <= count; i++) {
        if (users[i] == "") continue
        if (users[i] == user) found = 1
        rendered = rendered (rendered == "" ? "" : " ") users[i]
      }
      if (!found) rendered = rendered (rendered == "" ? "" : " ") user
      line = prefix " = " rendered
      updated = 1
    }
    print line
    last = line
  }
  END {
    if (!updated) {
      if (NR > 0 && last !~ /^[[:space:]]*$/) print ""
      print "extra-trusted-users = " user
    }
  }
' "$custom_conf" 2>/dev/null > "$custom_tmp" || printf 'extra-trusted-users = %s\n' "$user" > "$custom_tmp"
rewrite_if_changed "$custom_conf" "$custom_tmp"
SH
}

restart_nix_daemon() {
  if is_macos && command -v launchctl >/dev/null 2>&1; then
    sudo launchctl kickstart -k system/org.nixos.nix-daemon >/dev/null 2>&1 ||
      sudo launchctl kickstart -k system/systems.determinate.nix-daemon >/dev/null 2>&1 ||
      return 1
    return 0
  fi
  if command -v systemctl >/dev/null 2>&1; then
    sudo systemctl restart nix-daemon.service >/dev/null 2>&1 && return 0
  fi
  return 1
}

ensure_nix_trusted_user() {
  [[ "${trust_nix_user}" != "0" ]] || return 0
  local user config refreshed
  user="$(id -un 2>/dev/null || printf '%s' "${USER:-${LOGNAME:-unknown}}")"
  config="$(nix_cmd config show 2>/dev/null || true)"
  if nix_user_is_trusted "${user}" "${config}"; then
    ui_ok "nix trust" "${user} already trusted"
    return 0
  fi
  if ! confirm_trust_nix_user; then
    return 0
  fi
  append_trusted_nix_user "${user}"
  record_action "added ${user} to Nix trusted users"
  if restart_nix_daemon; then
    refreshed="$(nix_cmd config show 2>/dev/null || true)"
    if nix_user_is_trusted "${user}" "${refreshed}"; then
      ui_ok "nix trust" "trusted ${user}"
    else
      ui_warn "nix trust" "updated config; open a new shell or retry if Nix has not reloaded it yet"
    fi
  else
    ui_warn "nix trust" "updated config; restart nix-daemon or open a new shell if needed"
  fi
}

ensure_nix_trusted_user

if ! git_is_usable; then
  nix_cmd profile install nixpkgs#git
  refresh_nix_profile_path
  record_action "installed Git with nix profile"
fi
if ! git_is_usable; then
  echo "error: git is required but the git on PATH is not usable; install Git or rerun after fixing PATH" >&2
  exit 1
fi

if [[ ! -d "${workspace_root}" ]]; then
  record_action "created workspace directory"
fi
mkdir -p "${workspace_root}"
cd "${workspace_root}"

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  git init --quiet
  record_action "initialized git repository"
fi

effective_source="${viberoots_url}"
if [[ "${mode}" == "submodule" ]]; then
  effective_source="${submodule_url}"
  if gitmodules_has_viberoots_submodule; then
    existing_submodule_url="$(gitmodules_viberoots_url || true)"
    effective_source="${existing_submodule_url:-${submodule_url}}"
  fi
fi

assert_viberoots_source_access "${effective_source}"

if bootstrap_ready; then
  run_writable_migrations
  if [[ "${post_clone}" == "1" || "${update}" == "1" ]]; then
    record_action "refreshed generated workspace state"
    if [[ "${mode}" == "flake" ]]; then
      run_nix_init_consumer
    elif [[ "${post_clone}" == "1" ]]; then
      VBR_POST_CLONE=1 ./viberoots/init \
        --mode submodule \
        --workspace-name "${workspace_name}" \
        ${run_install_flag:+"${run_install_flag}"} \
        ${direnv_allow_flag:+"${direnv_allow_flag}"}
    else
      VBR_BOOTSTRAP_PNPM_GENERATE=1 ./viberoots/init \
        --mode submodule \
        --workspace-name "${workspace_name}" \
        ${run_install_flag:+"${run_install_flag}"} \
        ${direnv_allow_flag:+"${direnv_allow_flag}"}
    fi
    if [[ "${run_install}" == "1" ]]; then
      install_handled_by_setup=1
    fi
  elif [[ "${post_clone}" != "1" ]]; then
    cat >&2 <<'EOF'
error: this workspace is already initialized

Bootstrap creates a new viberoots workspace. To intentionally advance the
checked-in viberoots pin and reconcile required metadata, run:
  viberoots update
EOF
    exit 1
  fi
  assert_post_clone_tracked_clean
  print_summary "already up to date" "${effective_source}"
elif [[ "${mode}" == "flake" ]]; then
  begin_transaction
  run_writable_migrations
  record_action "ran viberoots init-consumer"
  run_nix_init_consumer
  if [[ "${run_install}" == "1" ]]; then
    install_handled_by_setup=1
  fi
  complete_transaction
  assert_post_clone_tracked_clean
  print_summary "bootstrapped" "${effective_source}"
else
  confirm_trusted_submodule_url "${effective_source}"
  ensure_git_metadata_writable
  if [[ "${post_clone}" == "1" && -z "$(gitlink_revision)" ]]; then
    echo "error: post-clone detected submodule mode but viberoots is not a checked-in gitlink" >&2
    echo "Use normal bootstrap when you intend to add or change source mode." >&2
    exit 1
  fi
  if [[ -d viberoots ]] &&
    [[ -n "$(git -C viberoots status --porcelain=v1 2>/dev/null || true)" ]] &&
    [[ "$(git -C viberoots rev-parse --abbrev-ref HEAD 2>/dev/null || true)" != "${ref}" ]] &&
    [[ -z "${rev}" || "$(git -C viberoots rev-parse HEAD 2>/dev/null || true)" != "${rev}" ]]; then
    echo "error: viberoots submodule has local changes; commit or stash them before changing refs" >&2
    exit 1
  fi
  begin_transaction
  run_writable_migrations
  if [[ ! -e viberoots ]]; then
    if gitmodules_has_viberoots_submodule; then
      git submodule update --init --recursive viberoots
      record_action "initialized existing viberoots submodule"
    else
      git submodule add "${submodule_url}" viberoots
      record_action "added viberoots submodule"
    fi
  elif [[ ! -d viberoots ]]; then
    echo "error: viberoots exists and is not a directory" >&2
    exit 1
  elif gitmodules_has_viberoots_submodule; then
    git submodule update --init --recursive viberoots
    record_action "updated viberoots submodule"
  fi
  if [[ "${post_clone}" == "1" ]]; then
    submodule_rev="$(git -C viberoots rev-parse HEAD 2>/dev/null || true)"
    gitlink_rev="$(gitlink_revision)"
    if [[ -z "${submodule_rev}" || "${submodule_rev}" != "${gitlink_rev}" ]]; then
      cat >&2 <<EOF
error: post-clone could not initialize viberoots to the checked-in gitlink

gitlink:   ${gitlink_rev:-unknown}
submodule: ${submodule_rev:-unknown}

Run git submodule update --init --recursive viberoots and retry post-clone.
EOF
      exit 1
    fi
    if [[ -n "${locked_rev:-}" && "${locked_rev}" != "${gitlink_rev}" ]]; then
      cat >&2 <<EOF
error: post-clone found mismatched viberoots pins

flake.lock: ${locked_rev}
gitlink:    ${gitlink_rev}

This repo is in submodule mode, so post-clone will not move the checked-in
gitlink.
no tracked files were modified

repair: run viberoots update
EOF
      exit 1
    fi
  else
    fetch_target="${ref}"
    if [[ -n "${rev}" && "${ref_explicit}" != "1" ]]; then
      fetch_target="${rev}"
    fi
    if git -C viberoots fetch origin "${fetch_target}" >/dev/null 2>&1; then
      record_action "fetched viberoots ref"
    fi
    if [[ -n "${rev}" ]] && git -C viberoots rev-parse --verify --quiet "${rev}^{commit}" >/dev/null; then
      git -C viberoots checkout --quiet "${rev}"
      record_action "checked out ${rev}"
    elif git -C viberoots rev-parse --verify --quiet "origin/${ref}^{commit}" >/dev/null; then
      git -C viberoots checkout --quiet "origin/${ref}"
      record_action "checked out origin/${ref}"
    elif git -C viberoots rev-parse --verify --quiet "${ref}^{commit}" >/dev/null; then
      git -C viberoots checkout --quiet "${ref}"
      record_action "checked out ${ref}"
    fi
  fi
  if [[ "${post_clone}" == "1" ]]; then
    VBR_POST_CLONE=1 ./viberoots/init \
      --mode submodule \
      --workspace-name "${workspace_name}" \
      ${run_install_flag:+"${run_install_flag}"} \
      ${direnv_allow_flag:+"${direnv_allow_flag}"}
  else
    VBR_BOOTSTRAP_PNPM_GENERATE=1 ./viberoots/init \
      --mode submodule \
      --workspace-name "${workspace_name}" \
      ${run_install_flag:+"${run_install_flag}"} \
      ${direnv_allow_flag:+"${direnv_allow_flag}"}
  fi
  record_action "ran ./viberoots/init"
  if [[ "${run_install}" == "1" ]]; then
    install_handled_by_setup=1
  fi
  complete_transaction
  assert_post_clone_tracked_clean
  print_summary "bootstrapped" "${effective_source}"
fi

if [[ "${post_clone}" == "1" && "${run_install}" == "1" && "${install_handled_by_setup}" != "1" ]]; then
  ui_step "install" "running i"
  direnv exec "${workspace_root}" sh -lc 'i'
  ui_ok "install" "complete"
  assert_post_clone_tracked_clean
fi

if [[ "${run_validate}" == "1" ]]; then
  direnv exec "${workspace_root}" sh -lc 'i && b && v'
  ui_ok "validation" "complete"
  assert_post_clone_tracked_clean
  if [[ "${post_clone}" == "1" ]]; then
    ui_step "terminal" "open a fresh terminal before using viberoots or direnv; this shell may not have updated PATH setup"
  else
    ui_step "devshell" "direnv may load ${workspace_root}/.envrc now"
  fi
elif [[ "${direnv_allow}" == "1" ]]; then
  if [[ "${post_clone}" == "1" ]]; then
    if [[ "${run_install}" == "1" ]]; then
      ui_ok "next" "open a fresh terminal, then cd ${workspace_root} && b && v"
    else
      ui_ok "next" "open a fresh terminal, then cd ${workspace_root} && i && b && v"
    fi
    ui_step "terminal" "the shell that ran post-clone may not have Nix, direnv, or viberoots on PATH yet"
  else
    if [[ "${run_install}" == "1" ]]; then
      ui_ok "next" "cd ${workspace_root} && b && v"
    else
      ui_ok "next" "cd ${workspace_root} && i && b && v"
    fi
    ui_step "devshell" "direnv may load ${workspace_root}/.envrc now"
  fi
else
  if [[ "${post_clone}" == "1" ]]; then
    if [[ "${run_install}" == "1" ]]; then
      ui_ok "next" "open a fresh terminal, then cd ${workspace_root} && direnv allow && direnv exec . sh -lc 'b && v'"
    else
      ui_ok "next" "open a fresh terminal, then cd ${workspace_root} && direnv allow && direnv exec . sh -lc 'i && b && v'"
    fi
    ui_step "terminal" "the shell that ran post-clone may not have Nix, direnv, or viberoots on PATH yet"
  else
    ui_ok "next" "cd ${workspace_root} && direnv allow && direnv exec . sh -lc 'i && b && v'"
    ui_step "devshell" "run direnv allow before loading the dev shell"
  fi
fi
ui_step "tracked proof" "local ignored state may change; run git diff --exit-code afterward if you need proof no tracked files changed"
