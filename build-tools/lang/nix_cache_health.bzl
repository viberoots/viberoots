def nix_cache_health_shell():
    return (
        "if [ \"${VBR_NIX_CACHE_HEALTH_APPLIED:-}\" != \"1\" ] && [ \"${VBR_NIX_CACHE_POLICY:-auto}\" != \"off\" ] && command -v nix >/dev/null 2>&1; then "
        + "  export VBR_NIX_CACHE_HEALTH_APPLIED=1; "
        + "  NIX_CACHE_TMPDIR=\"${TMPDIR:-${TMP:-/tmp}}\"; mkdir -p \"$NIX_CACHE_TMPDIR\"; "
        + "  NIX_CACHE_CONFIG_FILE=\"$NIX_CACHE_TMPDIR/vbr-nix-cache-config.txt\"; "
        + "  nix config show > \"$NIX_CACHE_CONFIG_FILE\" 2>/dev/null || true; "
        + "  NIX_CACHE_REQUIRED=\"\"; NIX_CACHE_OPTIONAL=\"\"; "
        + "  while IFS= read -r NIX_CACHE_LINE; do "
        + "    case \"$NIX_CACHE_LINE\" in "
        + "      substituters\\ =*) NIX_CACHE_VALUE=\"${NIX_CACHE_LINE#*=}\"; NIX_CACHE_REQUIRED=\"$NIX_CACHE_REQUIRED $NIX_CACHE_VALUE\" ;; "
        + "      extra-substituters\\ =*) NIX_CACHE_VALUE=\"${NIX_CACHE_LINE#*=}\"; NIX_CACHE_OPTIONAL=\"$NIX_CACHE_OPTIONAL $NIX_CACHE_VALUE\" ;; "
        + "    esac; "
        + "  done < \"$NIX_CACHE_CONFIG_FILE\"; "
        + "  if [ -n \"$NIX_CACHE_REQUIRED$NIX_CACHE_OPTIONAL\" ]; then "
        + "    NIX_CACHE_AVAILABLE=\"\"; NIX_CACHE_REMOVED=\"\"; NIX_CACHE_SEEN=\" \"; "
        + "    for NIX_CACHE_SUB in $NIX_CACHE_REQUIRED $NIX_CACHE_OPTIONAL; do "
        + "      case \"$NIX_CACHE_SEEN\" in *\" $NIX_CACHE_SUB \"*) continue ;; esac; "
        + "      NIX_CACHE_SEEN=\"$NIX_CACHE_SEEN$NIX_CACHE_SUB \"; "
        + "      case \"$NIX_CACHE_SUB\" in "
        + "        http://*|https://*) "
        + "          NIX_CACHE_INFO_URL=\"${NIX_CACHE_SUB%/}/nix-cache-info\"; "
        + "          if command -v curl >/dev/null 2>&1; then "
        + "            if curl -fsS --connect-timeout 3 --max-time 5 \"$NIX_CACHE_INFO_URL\" >/dev/null 2>&1; then NIX_CACHE_PROBE_STATUS=0; else NIX_CACHE_PROBE_STATUS=\"$?\"; fi; "
        + "          else "
        + "            if nix store info --store \"$NIX_CACHE_SUB\" --option connect-timeout 3 >/dev/null 2>&1; then NIX_CACHE_PROBE_STATUS=0; else NIX_CACHE_PROBE_STATUS=\"$?\"; fi; "
        + "          fi; "
        + "          if [ \"$NIX_CACHE_PROBE_STATUS\" = \"0\" ]; then "
        + "            NIX_CACHE_AVAILABLE=\"$NIX_CACHE_AVAILABLE ${NIX_CACHE_SUB}\"; "
        + "          else "
        + "            NIX_CACHE_REMOVED=\"$NIX_CACHE_REMOVED ${NIX_CACHE_SUB}\"; "
        + "          fi; "
        + "          ;; "
        + "        *) NIX_CACHE_AVAILABLE=\"$NIX_CACHE_AVAILABLE ${NIX_CACHE_SUB}\" ;; "
        + "      esac; "
        + "    done; "
        + "    if [ -n \"$NIX_CACHE_REMOVED\" ]; then "
        + "      if [ \"${VBR_NIX_CACHE_POLICY:-auto}\" = \"strict\" ]; then echo \"error: configured Nix substituter(s) unavailable:$NIX_CACHE_REMOVED\" >&2; exit 1; fi; "
        + "      NIX_CACHE_OPTIONAL_KEPT=\"\"; "
        + "      for NIX_CACHE_SUB in $NIX_CACHE_OPTIONAL; do case \" $NIX_CACHE_AVAILABLE \" in *\" $NIX_CACHE_SUB \"*) NIX_CACHE_OPTIONAL_KEPT=\"$NIX_CACHE_OPTIONAL_KEPT ${NIX_CACHE_SUB}\" ;; esac; done; "
        + "      NIX_CACHE_REQUIRED_KEPT=\"\"; "
        + "      for NIX_CACHE_SUB in $NIX_CACHE_REQUIRED; do case \" $NIX_CACHE_AVAILABLE \" in *\" $NIX_CACHE_SUB \"*) NIX_CACHE_REQUIRED_KEPT=\"$NIX_CACHE_REQUIRED_KEPT ${NIX_CACHE_SUB}\" ;; esac; done; "
        + "      NIX_CACHE_RETAINED_FILE=\"$NIX_CACHE_TMPDIR/vbr-nix-cache-retained.txt\"; : > \"$NIX_CACHE_RETAINED_FILE\"; "
        + "      printf '%s\n' \"${NIX_CONFIG:-}\" | while IFS= read -r NIX_CACHE_ENV_LINE; do "
        + "        NIX_CACHE_ENV_KEY=\"${NIX_CACHE_ENV_LINE%%=*}\"; "
        + "        NIX_CACHE_ENV_KEY=\"${NIX_CACHE_ENV_KEY#${NIX_CACHE_ENV_KEY%%[![:space:]]*}}\"; "
        + "        NIX_CACHE_ENV_KEY=\"${NIX_CACHE_ENV_KEY%${NIX_CACHE_ENV_KEY##*[![:space:]]}}\"; "
        + "        case \"$NIX_CACHE_ENV_KEY\" in substituters|extra-substituters|connect-timeout|stalled-download-timeout|fallback) ;; *) printf '%s\n' \"$NIX_CACHE_ENV_LINE\" >> \"$NIX_CACHE_RETAINED_FILE\" ;; esac; "
        + "      done; "
        + "      NIX_CACHE_RETAINED=\"\"; "
        + "      while IFS= read -r NIX_CACHE_RETAINED_LINE; do "
        + "        if [ -n \"$NIX_CACHE_RETAINED\" ]; then NIX_CACHE_RETAINED=\"${NIX_CACHE_RETAINED}\"$'\\n'\"${NIX_CACHE_RETAINED_LINE}\"; else NIX_CACHE_RETAINED=\"$NIX_CACHE_RETAINED_LINE\"; fi; "
        + "      done < \"$NIX_CACHE_RETAINED_FILE\"; "
        + "      if [ -n \"$NIX_CACHE_RETAINED\" ]; then "
        + "        printf -v NIX_CONFIG '%s\nsubstituters =%s\nextra-substituters =%s\nconnect-timeout = 3\nstalled-download-timeout = 10\nfallback = true' \"$NIX_CACHE_RETAINED\" \"$NIX_CACHE_REQUIRED_KEPT\" \"$NIX_CACHE_OPTIONAL_KEPT\"; "
        + "      else "
        + "        printf -v NIX_CONFIG 'substituters =%s\nextra-substituters =%s\nconnect-timeout = 3\nstalled-download-timeout = 10\nfallback = true' \"$NIX_CACHE_REQUIRED_KEPT\" \"$NIX_CACHE_OPTIONAL_KEPT\"; "
        + "      fi; "
        + "      export NIX_CONFIG; "
        + "      echo \"[nix] cache health: disabled unreachable substituter(s):$NIX_CACHE_REMOVED\" >&2; "
        + "      echo \"[nix] cache health: using optional substituter(s):${NIX_CACHE_OPTIONAL_KEPT:- <none>}\" >&2; "
        + "    fi; "
        + "  fi; "
        + "fi; "
    )
