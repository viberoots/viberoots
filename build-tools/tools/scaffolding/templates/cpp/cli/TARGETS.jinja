load("@viberoots//build-tools/cpp:defs.bzl", "nix_cpp_binary", "nix_cpp_test")

nix_cpp_binary(
    name = "{{ name }}",
    srcs = ["src/main.cpp"],
    labels = ["lang:cpp", "kind:bin"],
    visibility = ["PUBLIC"],
)

nix_cpp_test(
    name = "{{ name }}_gtest",
    srcs = ["tests/{{ name }}_gtest.cpp"],
    deps = [
        "workspace_providers//:nix_pkgs_googletest",
    ],
    labels = ["lang:cpp", "kind:test"],
)

