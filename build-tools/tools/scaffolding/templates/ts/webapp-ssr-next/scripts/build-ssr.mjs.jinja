mkdirSync("dist/server/wasm-contract", { recursive: true });
cpSync("app/wasm-contract/top.wasm", "dist/server/wasm-contract/top.wasm");
cpSync("app/wasm-modules.manifest.json", "dist/server/wasm-modules.manifest.json");
cpSync("app/ts-modules.manifest.json", "dist/server/ts-modules.manifest.json");
