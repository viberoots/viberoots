import { spawn } from "node:child_process";
import path from "node:path";

const viberootsRoot =
  process.env.VIBEROOTS_SOURCE_ROOT || process.env.VIBEROOTS_ROOT || path.resolve("..", "..", "..");
const viberootsTool = (name) => path.join(viberootsRoot, "build-tools", "tools", "dev", name);

const child = spawn(
  "zx-wrapper",
  [
    viberootsTool("dev-with-wasm-watch.ts"),
    "--vite-cmd",
    "pnpm run dev:ssr:only",
    "--watch-cmd",
    "pnpm run dev:wasm:watch",
  ],
  { stdio: "inherit" },
);

child.on("exit", (code) => {
  process.exit(code ?? 1);
});
