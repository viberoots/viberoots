"use client";

import { useEffect, useState } from "react";
import { listTsModules } from "./ts-modules";
import { readWasmContractBytes } from "./wasm-contract";

export default function HomePage() {
  const [wasmBytes, setWasmBytes] = useState<number | null>(null);
  const moduleKeys = listTsModules();

  useEffect(() => {
    let mounted = true;
    void readWasmContractBytes().then((bytes) => {
      if (mounted) setWasmBytes(bytes.byteLength);
    });
    return () => {
      mounted = false;
    };
  }, []);

  return (
    <main
      data-ssr-marker="next"
      data-wasm-bytes={wasmBytes == null ? "pending" : String(wasmBytes)}
      data-ts-modules={moduleKeys.join(",")}
    >
      <h1>Hello from Next SSR</h1>
    </main>
  );
}
