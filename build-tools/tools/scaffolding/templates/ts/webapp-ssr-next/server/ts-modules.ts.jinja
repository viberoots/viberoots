import path from "node:path";
import { fileURLToPath } from "node:url";
import { readFileSync } from "node:fs";

type TsModuleManifest = {
  defaultModuleKey: string;
  modules: Array<{
    moduleKey: string;
    sourceEntryPath: string;
    runtimeImportPath: string;
  }>;
};

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function readManifestJson(): TsModuleManifest {
  const candidates = [
    path.resolve(__dirname, "ts-modules.manifest.json"),
    path.resolve(__dirname, "../app/ts-modules.manifest.json"),
    path.resolve(__dirname, "../../app/ts-modules.manifest.json"),
  ];
  for (const p of candidates) {
    try {
      const text = readFileSync(p, "utf8");
      return JSON.parse(text) as TsModuleManifest;
    } catch {}
  }
  throw new Error(
    `TS module manifest is missing at expected paths: ${candidates.join(", ")}`,
  );
}

const manifest = readManifestJson();

export type TsModuleNamespace = Record<string, unknown>;

export function listTsModules(): string[] {
  return manifest.modules.map((mod) => mod.moduleKey);
}

export function defaultTsModuleKey(): string {
  return manifest.defaultModuleKey;
}

export async function loadTsModule(moduleKey: string): Promise<TsModuleNamespace> {
  if (moduleKey === "server-runtime") {
    return (await import("./index.js")) as TsModuleNamespace;
  }
  throw new Error(`TS module '${moduleKey}' is not available in server runtime`);
}

