import path from "node:path";
import { fileURLToPath } from "node:url";
import * as fsp from "node:fs/promises";
import { readFileSync } from "node:fs";

type WasmModuleManifest = {
  defaultModuleKey: string;
  modules: Array<{
    moduleKey: string;
    sourcePath: string;
    runtimeDestinations: { client: string; server: string };
  }>;
};

const __filename = fileURLToPath(import.meta.url);
const __dirname = path.dirname(__filename);

function manifestCandidates(fileName: string): string[] {
  const out = [path.resolve(__dirname, fileName)];
  const contractsDir = String(process.env.MODULE_CONTRACTS_DIR || "").trim();
  if (contractsDir) out.push(path.resolve(contractsDir, fileName));
  return out;
}

function readManifestJson(): WasmModuleManifest {
  const candidates = manifestCandidates("wasm-modules.manifest.json");
  for (const p of candidates) {
    try {
      const text = readFileSync(p, "utf8");
      return JSON.parse(text) as WasmModuleManifest;
    } catch {}
  }
  throw new Error(
    `WASM module manifest is missing at expected paths: ${candidates.join(", ")}`,
  );
}

const manifest = readManifestJson();

function manifestEntryFor(moduleKey: string) {
  if (manifest.modules.length === 0) {
    return null;
  }
  const entry = manifest.modules.find((mod) => mod.moduleKey === moduleKey);
  if (!entry) {
    throw new Error(`unknown wasm module key '${moduleKey}'`);
  }
  return entry;
}

function wasmCandidatesFor(moduleKey: string): string[] {
  const entry = manifestEntryFor(moduleKey);
  if (!entry) {
    return [];
  }
  const serverRuntimeDest = entry.runtimeDestinations.server;
  const clientRuntimeDest = entry.runtimeDestinations.client;
  return [
    path.resolve(__dirname, "..", serverRuntimeDest),
    path.resolve(__dirname, serverRuntimeDest),
    path.resolve(__dirname, "..", clientRuntimeDest),
    path.resolve(__dirname, clientRuntimeDest),
  ];
}

export function listWasmModules(): string[] {
  return manifest.modules.map((mod) => mod.moduleKey);
}

export function defaultWasmModuleKey(): string {
  return manifest.defaultModuleKey || "";
}

export async function readServerWasmModuleByteLength(moduleKey: string): Promise<number> {
  const wasmCandidates = wasmCandidatesFor(moduleKey);
  if (wasmCandidates.length === 0) {
    return 0;
  }
  let bytes: Buffer | null = null;
  for (const p of wasmCandidates) {
    try {
      bytes = await fsp.readFile(p);
      break;
    } catch {}
  }
  if (!bytes) {
    throw new Error(
      `server wasm contract asset is missing from expected runtime paths (module '${moduleKey}')`,
    );
  }
  return bytes.byteLength;
}

export async function readServerWasmContractByteLength(): Promise<number> {
  const moduleKey = defaultWasmModuleKey();
  if (!moduleKey) {
    return 0;
  }
  return readServerWasmModuleByteLength(moduleKey);
}
