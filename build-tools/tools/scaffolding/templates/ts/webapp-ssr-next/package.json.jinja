{
  "name": "{{ pkgScope }}/{{ name }}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "zx-wrapper ../../../build-tools/tools/dev/dev-with-wasm-watch.ts --cwd . --ensure-public-top-wasm 1 --vite-cmd \"pnpm run dev:ssr:only\" --watch-cmd \"pnpm run dev:wasm:watch\"",
    "dev:ssr": "pnpm run dev",
    "dev:ssr:only": "next dev -H 127.0.0.1 -p ${PORT:-4173}",
    "dev:wasm": "pnpm run dev",
    "dev:wasm:watch": "zx-wrapper ../../../build-tools/tools/dev/watch-wasm-producer.ts --watch app/wasm-producer/payload.txt --build-cmd \"zx-wrapper ../../../build-tools/tools/dev/build-wasm-producer.ts --payload app/wasm-producer/payload.txt --out .wasm-producer/top.wasm\" --build-out .wasm-producer/top.wasm --sync-out app/wasm-contract/top.wasm",
    "build:ssr": "next build && tsc -p tsconfig.server.json && mkdir -p dist/server/wasm-contract && cp app/wasm-contract/top.wasm dist/server/wasm-contract/top.wasm",
    "start:ssr": "node dist/server/index.js",
    {% if includeNodeTests %}
    "test": "vitest run"
    {% else %}
    "test": "node --test dist/**/*.test.js"
    {% endif %}
  },
  "dependencies": {
    "next": "^14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "esbuild": "^0.21.5",
    "@esbuild/darwin-arm64": "^0.21.5",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1"{% if includeNodeTests %},
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
    {% endif %}
  }
}
