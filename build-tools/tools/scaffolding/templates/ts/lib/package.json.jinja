{
  "name": "{{ pkgScope }}/{{ name }}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p .",
    {% if includeNodeTests %}
    "test": "vitest run",
    {% else %}
    "test": "node --test dist/**/*.test.js",
    {% endif %}
    "lint": "eslint . --ext .ts",
    "format": "prettier -w ."
  }{% if includeNodeTests %},
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "esbuild": "^0.21.5",
    "@types/node": "^22.0.0"
  }
  {% endif %}
}
