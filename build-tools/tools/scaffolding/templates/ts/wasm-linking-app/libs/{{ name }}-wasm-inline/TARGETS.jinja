load("@prelude//:rules.bzl", "export_file")
load("@viberoots//build-tools/node:defs.bzl", "node_wasm_inline_module")

export_file(
    name = "package.json",
    src = "package.json",
    visibility = ["PUBLIC"],
)

node_wasm_inline_module(
    name = "wasm_inline",
    src = "//projects/libs/{{ name }}-api:wasm",
    labels = ["kind:lib"],
    visibility = ["PUBLIC"],
)

node_wasm_inline_module(
    name = "wasm_inline_cpp",
    src = "//projects/libs/{{ name }}-cpp-wasm:app",
    out = "cpp.js",
    visibility = ["PUBLIC"],
)

node_wasm_inline_module(
    name = "wasm_inline_py",
    src = "//projects/libs/{{ name }}-py-wasm:py_wasm",
    out = "py.js",
    visibility = ["PUBLIC"],
)
