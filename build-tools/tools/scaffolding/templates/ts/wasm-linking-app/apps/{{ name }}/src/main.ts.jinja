async function loadWasm(url: URL): Promise<WebAssembly.Instance> {
  const res = await fetch(url);
  const buf = await res.arrayBuffer();
  const module = new WebAssembly.Module(buf);
  const imports: Record<string, any> = {};
  const env: Record<string, any> = {};

  for (const imp of WebAssembly.Module.imports(module)) {
    if (imp.module !== "env") continue;
    if (imp.kind === "function") env[imp.name] = () => 0;
    else if (imp.kind === "global") env[imp.name] = new WebAssembly.Global({ value: "i32", mutable: true }, 0);
    else if (imp.kind === "memory") env[imp.name] = new WebAssembly.Memory({ initial: 256 });
    else if (imp.kind === "table") env[imp.name] = new WebAssembly.Table({ initial: 0, element: "funcref" });
  }
  if (Object.keys(env).length) imports.env = env;

  const { instance } = await WebAssembly.instantiate(module, imports);
  return instance;
}

document.addEventListener("DOMContentLoaded", async () => {
  const root = document.getElementById("app");
  if (!root) return;

  root.innerHTML = `<h1>{{ name }} (Wasm linking demo)</h1>`;

  const wasmUrl = new URL("/top.wasm", window.location.href);
  try {
    const inst = await loadWasm(wasmUrl);
    const exp = inst.exports as any;
    const got = typeof exp.callAdd2 === "function" ? exp.callAdd2() : null;
    const p = document.createElement("p");
    p.textContent = `callAdd2() => ${String(got)}`;
    root.appendChild(p);
  } catch (err) {
    const p = document.createElement("p");
    p.textContent = `Failed to load ${wasmUrl.pathname}: ${String(err)}`;
    root.appendChild(p);
  }
});


