import path from "node:path";
import { promises as fsp } from "node:fs";

const cwd = process.cwd();
const payloadPath = process.env.WASM_PRODUCER_PAYLOAD_PATH
  ? path.resolve(cwd, process.env.WASM_PRODUCER_PAYLOAD_PATH)
  : path.join(cwd, "src", "wasm-producer", "payload.txt");
const outPath = process.env.WASM_PRODUCER_OUT_PATH
  ? path.resolve(cwd, process.env.WASM_PRODUCER_OUT_PATH)
  : path.join(cwd, ".wasm-producer", "top.wasm");

const payload = (await fsp.readFile(payloadPath, "utf8")).trim();
if (payload.toUpperCase() === "FAIL") {
  throw new Error("intentional wasm producer failure marker: payload=FAIL");
}
await fsp.mkdir(path.dirname(outPath), { recursive: true });
const bytes = new TextEncoder().encode(`wasm-producer:${payload}`);
await fsp.writeFile(outPath, bytes);
