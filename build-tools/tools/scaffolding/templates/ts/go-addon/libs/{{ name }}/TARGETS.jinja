load("@viberoots//build-tools/node:defs.bzl", "nix_node_lib", "nix_node_test", "nix_node_gen")

# Copy the compiled addon (.node) into a predictable relative path for runtime loading
nix_node_gen(
    name = "copy_addon",
    srcs = [],
    out = "native/{{ addon_name }}.node",
    cmd = "cp $(location //projects/libs/{{ name }}-native:napi_addon) $OUT",
    deps = ["//projects/libs/{{ name }}-native:napi_addon"],
    labels = ["lang:node", "kind:gen"],
)

# Minimal Node lib target; depends on :copy_addon so the addon is present
nix_node_lib(
    name = "{{ name }}",
    srcs = [],
    out = "build.stamp",
    cmd = "echo ok > $OUT",
    deps = [":copy_addon"],
)

{% if includeNodeTests -%}
nix_node_test(
    name = "unit",
    deps = [":copy_addon"],
)
{%- endif %}


