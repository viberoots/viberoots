{
  "name": "{{ pkgScope }}/{{ name }}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev": "zx-wrapper ../../../build-tools/tools/dev/dev-with-wasm-watch.ts --vite-cmd \"pnpm exec vite --host 127.0.0.1 --port ${PORT:-5187} --strictPort --clearScreen false --logLevel info\" --watch-cmd \"pnpm run dev:wasm:watch\"",
    "dev:wasm": "pnpm run dev",
    "dev:vite": "vite",
    "dev:wasm:watch": "zx-wrapper ../../../build-tools/tools/dev/watch-wasm-producer.ts --watch src/wasm-producer/payload.txt --build-cmd \"node ./scripts/build-wasm-producer.mjs\" --build-out .wasm-producer/top.wasm --sync-out src/wasm-contract/top.wasm",
    "build": "vite build",
    "preview": "vite preview",
    {% if includeNodeTests %}
    "test": "vitest run"
    {% else %}
    "test": "node --test dist/**/*.test.js"
    {% endif %}
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "esbuild": "^0.21.5",
    "@esbuild/darwin-arm64": "^0.21.5",
    "@types/node": "^22.0.0"{% if includeNodeTests %},
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
    {% endif %}
  }
}

