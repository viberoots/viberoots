import { spawn } from "node:child_process";
import path from "node:path";

const viberootsRoot =
  process.env.VIBEROOTS_SOURCE_ROOT || process.env.VIBEROOTS_ROOT || path.resolve("..", "..", "..");
const viberootsTool = (name) => path.join(viberootsRoot, "build-tools", "tools", "dev", name);
const workspaceRoot = path.resolve("..", "..", "..");

const child = spawn(
  "zx-wrapper",
  [
    viberootsTool("dev-with-wasm-watch.ts"),
    "--vite-cmd",
    "pnpm exec vite --host 127.0.0.1 --port ${PORT:-5187} --strictPort --clearScreen false --logLevel info",
    "--watch-cmd",
    "pnpm run dev:wasm:watch",
  ],
  { stdio: "inherit", env: { ...process.env, WORKSPACE_ROOT: workspaceRoot } },
);

child.on("exit", (code) => {
  process.exit(code ?? 1);
});
