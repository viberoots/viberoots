import { execFileSync } from "node:child_process";
import * as fsp from "node:fs";
import path from "node:path";

const viteBin = path.resolve(
  "node_modules",
  ".bin",
  process.platform === "win32" ? "vite.cmd" : "vite",
);
const viberootsRoot =
  process.env.VIBEROOTS_SOURCE_ROOT || process.env.VIBEROOTS_ROOT || path.resolve("..", "..", "..");
const viberootsTool = (name) => path.join(viberootsRoot, "build-tools", "tools", "dev", name);

const wasmManifestPath = path.join("src", "wasm-modules.manifest.json");
execFileSync(
  "zx-wrapper",
  [
    viberootsTool("ensure-wasm-contract-assets.ts"),
    "--cwd",
    ".",
    "--wasm-manifest",
    wasmManifestPath,
  ],
  { stdio: "inherit" },
);
execFileSync(viteBin, ["build"], { stdio: "inherit" });

const manifest = JSON.parse(fsp.readFileSync(wasmManifestPath, "utf8"));
for (const entry of Array.isArray(manifest.modules) ? manifest.modules : []) {
  const rel = String(entry?.runtimeDestinations?.client || "").trim();
  if (!rel) continue;
  const source = path.resolve(rel);
  if (!fsp.existsSync(source)) continue;
  const target = path.resolve("dist", rel);
  fsp.mkdirSync(path.dirname(target), { recursive: true });
  fsp.copyFileSync(source, target);
}
