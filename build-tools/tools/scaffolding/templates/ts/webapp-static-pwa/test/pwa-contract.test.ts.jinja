import { readFileSync } from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import { describe, expect, it } from "vitest";

const thisFile = fileURLToPath(import.meta.url);
const appRoot = path.resolve(path.dirname(thisFile), "..");

describe("static pwa scaffold contract", () => {
  it("includes manifest and install metadata in the html shell", () => {
    const html = readFileSync(path.join(appRoot, "index.html"), "utf8");
    expect(html).toContain('rel="manifest" href="/manifest.webmanifest"');
    expect(html).toContain('name="apple-mobile-web-app-capable" content="yes"');
    expect(html).toContain('name="theme-color" content="#102033"');
    expect(html).toContain('rel="apple-touch-icon" href="/icons/icon-192.svg"');
  });

  it("registers the service worker from the client entry path", () => {
    const entry = readFileSync(path.join(appRoot, "src/main.ts"), "utf8");
    expect(entry).toContain("navigator.serviceWorker");
    expect(entry).toContain('register("/service-worker.js"');
    expect(entry).toContain('scope: "/"');
    expect(entry).toContain("controllerchange");
    expect(entry).not.toContain('addEventListener("load"');
  });

  it("ships a manifest and service worker baseline", () => {
    const manifest = JSON.parse(
      readFileSync(path.join(appRoot, "public/manifest.webmanifest"), "utf8"),
    ) as {
      display?: string;
      start_url?: string;
      icons?: Array<{ src?: string }>;
    };
    expect(manifest.display).toBe("standalone");
    expect(manifest.start_url).toBe("/");
    expect(manifest.icons?.some((icon) => icon.src === "/icons/icon-192.svg")).toBe(true);
    expect(manifest.icons?.some((icon) => icon.src === "/icons/icon-512.svg")).toBe(true);

    const serviceWorker = readFileSync(path.join(appRoot, "public/service-worker.js"), "utf8");
    expect(serviceWorker).toContain('const APP_SHELL_URL = "/"');
    expect(serviceWorker).toContain("/manifest.webmanifest");
    expect(serviceWorker).toContain('requestUrl.pathname.endsWith(".wasm")');
    expect(serviceWorker).toContain("caches.open(APP_SHELL_CACHE)");
  });
});

