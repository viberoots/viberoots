#!/usr/bin/env node
import { fileURLToPath } from "node:url";
import path from "node:path";
import { spawn } from "node:child_process";

const appRoot = path.dirname(fileURLToPath(import.meta.url));
const repoRoot = path.resolve(appRoot, "../../../..");
const viberootsRoot = process.env.VIBEROOTS_SOURCE_ROOT || process.env.VIBEROOTS_ROOT || repoRoot;
const viberootsTool = (name) => path.join(viberootsRoot, "build-tools", "tools", "dev", name);

const child = spawn(
  "zx-wrapper",
  [viberootsTool("dev-with-wasm-watch.ts")],
  {
    stdio: "inherit",
    cwd: path.join(appRoot, ".."),
    env: { ...process.env, WORKSPACE_ROOT: repoRoot },
  },
);

child.on("exit", (code, signal) => {
  if (signal) {
    process.kill(process.pid, signal);
    return;
  }
  process.exit(code ?? 0);
});
