html,
body,
#app {
  min-height: 100%;
  margin: 0;
}

body {
  background:
    radial-gradient(circle at top, rgba(125, 211, 252, 0.28), transparent 28%),
    linear-gradient(180deg, #09111c 0%, #102033 55%, #17314d 100%);
  color: #f8fafc;
  display: grid;
  font-family: "Trebuchet MS", "Avenir Next", system-ui, sans-serif;
  place-items: center;
}

#app {
  width: min(100%, 42rem);
  padding: 24px;
}

.app-shell {
  backdrop-filter: blur(12px);
  background: rgba(9, 17, 28, 0.72);
  border: 1px solid rgba(125, 211, 252, 0.22);
  border-radius: 24px;
  box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
  padding: 32px;
}

.eyebrow {
  color: #7dd3fc;
  font-size: 0.85rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  margin: 0 0 12px;
  text-transform: uppercase;
}

h1 {
  font-size: clamp(2rem, 6vw, 3.5rem);
  line-height: 1;
  margin: 0 0 12px;
}

.lede {
  color: #dbeafe;
  margin: 0 0 24px;
  max-width: 32rem;
}

.signals {
  display: grid;
  gap: 12px;
  grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
  margin: 0;
}

.signals div {
  background: rgba(248, 250, 252, 0.08);
  border-radius: 16px;
  padding: 14px 16px;
}

.signals dt {
  color: #93c5fd;
  font-size: 0.8rem;
  margin-bottom: 6px;
  text-transform: uppercase;
}

.signals dd {
  font-size: 1.1rem;
  font-weight: 700;
  margin: 0;
}

