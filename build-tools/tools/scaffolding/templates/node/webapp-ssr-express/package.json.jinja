{
  "name": "{{ pkgScope }}/{{ name }}",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "scripts": {
    "dev:ssr": "vite dev --host 127.0.0.1 --port 5173 --strictPort",
    "build:ssr": "vite build --outDir dist/client && vite build --ssr src/entry-server.ts --outDir dist/server && tsc -p tsconfig.server.json && mkdir -p dist/server/wasm-contract && cp src/wasm-contract/top.wasm dist/server/wasm-contract/top.wasm",
    "start:ssr": "node dist/server/index.js",
    {% if includeNodeTests %}
    "test": "vitest run"
    {% else %}
    "test": "node --test dist/**/*.test.js"
    {% endif %}
  },
  "dependencies": {
    "express": "^4.21.2"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "esbuild": "^0.21.5",
    "@esbuild/darwin-arm64": "^0.21.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0"{% if includeNodeTests %},
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0"
    {% endif %}
  }
}
