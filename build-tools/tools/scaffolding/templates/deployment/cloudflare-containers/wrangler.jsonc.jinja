{
  "$schema": "../../../node_modules/wrangler/config-schema.json",
  "name": "{{ worker }}",
  "main": "{{ cloudflare_worker_entrypoint_path }}",
  "compatibility_date": "{{ compatibility_date }}",
{% if ingress_mode == "public" and domain %}
  "routes": [
    {
      "pattern": "{{ domain }}",
      "custom_domain": true,
      "zone_id": "{{ cloudflare_zone_id }}",
    },
  ],
{% endif %}
  "durable_objects": {
    "bindings": [
      {
        "name": "{{ cloudflare_container_binding_name }}",
        "class_name": "{{ cloudflare_container_class_name }}",
      },
    ],
  },
  "migrations": [
    {
      "tag": "{{ cloudflare_container_migration_tag }}",
      "new_classes": ["{{ cloudflare_container_class_name }}"],
    },
  ],
  "containers": [
    {
      "class_name": "{{ cloudflare_container_class_name }}",
      "image": "./Dockerfile",
      "max_instances": {{ max_instances }},
      "instance_type": "dev",
      "sleep_after": "{{ sleep_after }}",
    },
  ],
}
