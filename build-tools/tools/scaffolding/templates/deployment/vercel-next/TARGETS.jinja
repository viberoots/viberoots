load("//build-tools/deployments:defs.bzl", "vercel_next_webapp_deployment")

vercel_next_webapp_deployment(
    name = "deploy",
    component = "{{ component }}",
    team = "{{ team }}",
    project = "{{ project }}",
    environment = "{{ environment }}",
    canonical_url = "{{ canonical_url }}",
    lane_policy = "//projects/deployments/{{ shared_package }}:lane",
    environment_stage = "{{ stage }}",
    admission_policy = "//projects/deployments/{{ shared_package }}:{{ stage }}_release",
    secret_requirements = [
        {
            "name": "vercel-api-token",
            "step": "publish",
            "contract_id": "secret://deployments/{{ name }}/vercel_api_token",
            "required": "true",
        },
    ],
    runtime_config_requirements = [
        {
            "name": "public-console-url",
            "step": "publish",
            "contract_id": "runtime://deployments/{{ name }}/public_url",
            "required": "true",
        },
    ],
    smoke = {
        "runner": "http",
        "url": "{{ canonical_url }}",
        "expected_status": "200",
    },
)
