#!/usr/bin/env zx-wrapper
import fs from "fs-extra";
import { writeIfChanged } from "../../lib/fs-helpers";
import { providerAutoTargetsPath } from "../../lib/workspace-state-paths";

export async function sync{{ display_name }}Providers(opts?: { outFile?: string; patchDir?: string; strict?: boolean }) {
  const out = opts?.outFile || providerAutoTargetsPath("{{ lang_id }}");
  const patchDir = opts?.patchDir || `patches/{{ lang_id }}`;
  if (!(await fs.pathExists(patchDir))) {
    await writeIfChanged(out, `# GENERATED FILE — DO NOT EDIT.\n# No patches present for {{ lang_id }}.\n`);
    return;
  }
  await writeIfChanged(out, `# GENERATED FILE — DO NOT EDIT.\n# TODO: implement {{ lang_id }} provider sync.\n`);
}
