{
  "language": "python",
  "template": "app",
  "resolverDestination": "projects/apps/{name}",
  "description": "Python app scaffold (uv + Buck2 macros)",
  "help": {
    "usage": "scaf new python app <name> [--path=DEST]",
    "notes": [
      "Creates a Python app under projects/apps/<name> with uv.lock, a library, and a binary entrypoint.",
      "Lockfile label uses importer-scoped form: lockfile:projects/apps/<name>/uv.lock#projects/apps/<name>.",
      "Edit pyproject.toml and regenerate uv.lock using uv."
    ],
    "examples": [
      "scaf new python app demo-app --path=projects/apps/demo-app",
      "scaf regen projects/apps/demo-app"
    ]
  }
}
