load("//build-tools/python:defs.bzl", "nix_python_wasm_app", "nix_python_library", "nix_python_test")

nix_python_library(
    name = "{{ name }}_lib",
    srcs = glob(["src/**/*.py"]),
    visibility = ["PUBLIC"],
)

nix_python_wasm_app(
    name = "{{ name }}",
    srcs = glob(["**/*.py"]),
    visibility = ["PUBLIC"],
)

nix_python_test(
    name = "{{ name }}_test",
    srcs = glob(["tests/**/*.py"]),
    deps = [":{{ name }}_lib"],
    visibility = ["PUBLIC"],
)


