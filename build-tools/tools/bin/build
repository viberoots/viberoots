#!/usr/bin/env bash
set -euo pipefail
case "${1:-}" in
	-h|--help)
		cat <<'EOF'
usage: b [buck-subcommand|target...] [options]
       build [buck-subcommand|target...] [options]

Build workspace targets through Buck/Nix.

subcommands:
  build, test, run, cquery, query, install, kill, server, clean

options:
  --impure
  --no-materialize
  -h, --help
EOF
		exit 0
		;;
esac

script_dir="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=/dev/null
. "${script_dir}/artifact-ingress-env.sh"
artifact_ingress_reexec_with_devshell "$0" "$@"
artifact_ingress_clear_selectors

# shell helpers
# shellcheck source=/dev/null
export VBR_DEVSHELL_USE_GENERATED_AUTHORITY=1
. "${script_dir}/devshell.sh"

artifact_ingress_trust_devshell_baseline "${LIVE_ROOT}"
artifact_ingress_restore_or_remove_selectors
artifact_ingress_exec "${LIVE_ROOT}" "build-tools/tools/dev/dev-build.ts" "$@"
