#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname -- "${SCRIPT_PATH}")"

find_tool_excluding_wrapper_dir() {
  local tool="$1"
  local dir
  local old_ifs="$IFS"
  IFS=':'
  for dir in ${PATH:-}; do
    [[ -n "$dir" ]] || continue
    if [[ "$(cd -- "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")" == "$SCRIPT_DIR" ]]; then
      continue
    fi
    if [[ -x "$dir/$tool" ]]; then
      printf '%s\n' "$(cd -- "$(dirname -- "$dir/$tool")" && pwd -P)/$(basename -- "$dir/$tool")"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

real_codex="$(find_tool_excluding_wrapper_dir codex || true)"
if [[ -z "$real_codex" ]]; then
  echo "Error: codex binary not found in PATH (excluding wrapper directory)" >&2
  exit 1
fi

real_git="$(find_tool_excluding_wrapper_dir git || true)"

git_root() {
  [[ -n "$real_git" ]] || return 1
  "$real_git" rev-parse --show-toplevel 2>/dev/null
}

WORKTREE_REQUESTED=0
LIST_WORKTREES_REQUESTED=0
REMOVE_WORKTREE_REQUESTED=0
REMOVE_ALL_WORKTREES_REQUESTED=0
FORCE_REMOVE_WORKTREE=0
WORKTREE_NAME=""
REMOVE_WORKTREE_NAME=""
CODEX_ARGS=()

codex_args_request_sandbox() {
  local token
  while [[ "$#" -gt 0 ]]; do
    token="$1"
    shift
    case "$token" in
      --sandbox|--sandbox=*|-s|--dangerously-bypass-approvals-and-sandbox)
        return 0
        ;;
    esac
  done
  return 1
}

codex_default_sandbox_args() {
  if codex_args_request_sandbox "$@"; then
    printf '%s\0' "$@"
  else
    printf '%s\0' --sandbox danger-full-access "$@"
  fi
}

parse_codex_worktree_args() {
  local token
  while [[ "$#" -gt 0 ]]; do
    token="$1"
    shift

    case "$token" in
      --force)
        FORCE_REMOVE_WORKTREE=1
        ;;
      --list-worktrees)
        LIST_WORKTREES_REQUESTED=1
        ;;
      --remove-worktree=*)
        REMOVE_WORKTREE_REQUESTED=1
        REMOVE_WORKTREE_NAME="${token#--remove-worktree=}"
        ;;
      --remove-worktree)
        REMOVE_WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          REMOVE_WORKTREE_NAME="$1"
          shift
        fi
        ;;
      --remove-all-worktrees)
        REMOVE_ALL_WORKTREES_REQUESTED=1
        ;;
      --worktree=*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#--worktree=}"
        ;;
      --worktree|-w)
        WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          WORKTREE_NAME="$1"
          shift
        fi
        ;;
      -w?*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#-w}"
        ;;
      *)
        CODEX_ARGS+=("$token")
        ;;
    esac
  done
}

default_worktree_name() {
  printf 'codex-%s-%s\n' "$(date +%Y%m%d%H%M%S)" "$$"
}

validate_worktree_name() {
  local name="$1"
  if [[ -z "$name" || "$name" == /* || "$name" == *"/"* || "$name" == "." || "$name" == ".." || "$name" == *".."* ]]; then
    echo "Error: invalid Codex worktree name: ${name}" >&2
    return 2
  fi
}

git_worktree_base() {
  if [[ -n "$real_git" ]] && "$real_git" rev-parse --verify --quiet origin/HEAD >/dev/null 2>&1; then
    printf '%s\n' "origin/HEAD"
    return 0
  fi
  printf '%s\n' "HEAD"
}

git_branch_exists() {
  local branch="$1"
  "$real_git" rev-parse --verify --quiet "refs/heads/${branch}" >/dev/null 2>&1
}

list_codex_worktrees() {
  local root="$1"
  local base="${root}/.codex/worktrees"
  local name
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      printf '%s\t%s\n' "$name" "$worktree"
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
}

remove_codex_worktree() {
  local root="$1"
  local name="$2"
  local force="${3:-0}"
  local target="${root}/.codex/worktrees/${name}"
  local branch="worktree-${name}"
  local remove_flags=()
  local status

  validate_worktree_name "$name"
  if [[ ! -e "$target/.git" ]] || ! "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Codex worktree not found: ${name}" >&2
    return 1
  fi

  if [[ "$force" == "1" ]]; then
    remove_flags=(--force)
  elif worktree_has_only_discardable_autogenerated_changes "$target"; then
    echo "Info: ${name} has only discardable autogenerated provider changes; removing with --force" >&2
    remove_flags=(--force)
  fi

  set +e
  (
    cd -- "$root"
    if [[ "${#remove_flags[@]}" -gt 0 ]]; then
      "$real_git" worktree remove "${remove_flags[@]}" "$target"
    else
      "$real_git" worktree remove "$target"
    fi
  )
  status=$?
  set -e
  [[ "$status" -eq 0 ]] || return "$status"

  if git_branch_exists "$branch"; then
    set +e
    "$real_git" -C "$root" branch -D "$branch"
    status=$?
    set -e
    [[ "$status" -eq 0 ]] || return "$status"
  fi

  "$real_git" -C "$root" worktree prune
}

worktree_has_only_discardable_autogenerated_changes() {
  local target="$1"
  local item
  local path
  local status
  local status_file
  local saw_discardable=0

  status_file="$(mktemp "${TMPDIR:-/tmp}/bnx-codex-worktree-status.XXXXXX")"
  if ! "$real_git" -C "$target" status --porcelain -z --untracked-files=all > "$status_file"; then
    rm -f -- "$status_file"
    return 1
  fi

  while IFS= read -r -d '' item; do
    [[ -n "$item" ]] || continue
    status="${item:0:2}"
    path="${item:3}"
    case "${status}:${path}" in
      " M:third_party/providers/TARGETS"|" M:third_party/providers/auto_map.bzl")
        saw_discardable=1
        ;;
      *)
        rm -f -- "$status_file"
        return 1
        ;;
    esac
  done < "$status_file"

  rm -f -- "$status_file"
  [[ "$saw_discardable" == "1" ]]
}

remove_all_codex_worktrees() {
  local root="$1"
  local force="${2:-0}"
  local base="${root}/.codex/worktrees"
  local name
  local status=0
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      if remove_codex_worktree "$root" "$name" "$force"; then
        :
      else
        status=1
      fi
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
  return "$status"
}

ensure_codex_worktree() {
  local root="$1"
  local name="$2"
  local target="${root}/.codex/worktrees/${name}"
  local branch="worktree-${name}"
  local base
  local git_wrapper="${BNX_CODEX_GIT_WRAPPER_FOR_TEST:-${SCRIPT_DIR}/git}"

  if [[ -e "$target/.git" ]]; then
    if "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      printf '%s\n' "$target"
      return 0
    fi
    echo "Error: existing Codex worktree path is not a valid git worktree: ${target}" >&2
    return 1
  fi

  if [[ -e "$target" ]]; then
    echo "Error: Codex worktree path already exists but is not a git worktree: ${target}" >&2
    return 1
  fi

  if [[ ! -x "$git_wrapper" ]]; then
    echo "Error: git CoW wrapper not found: ${git_wrapper}" >&2
    return 127
  fi

  mkdir -p -- "$(dirname -- "$target")"
  if git_branch_exists "$branch"; then
    (
      cd -- "$root"
      "$git_wrapper" worktree add "$target" "$branch" >&2
    )
  else
    base="$(git_worktree_base)"
    (
      cd -- "$root"
      "$git_wrapper" worktree add -b "$branch" "$target" "$base" >&2
    )
  fi
  printf '%s\n' "$target"
}

should_safehouse_codex() {
  local mode="${BNX_CODEX_SAFEHOUSE:-auto}"
  local root="$1"

  if [[ "${BNX_CODEX_SAFEHOUSE_ACTIVE:-}" == "1" ]]; then
    if [[ -n "${BNX_CODEX_SAFEHOUSE_ROOT:-}" && "$(real_path "$root")" != "$(real_path "$BNX_CODEX_SAFEHOUSE_ROOT")" ]]; then
      echo "Error: cannot launch Codex worktree agent from inside another Safehouse sandbox: $root" >&2
      echo "Hint: macOS sandbox-exec cannot apply a nested sandbox; launch the parent without BNX_CODEX_SAFEHOUSE=always." >&2
      exit 126
    fi
    return 1
  fi
  [[ "$mode" == "0" || "$mode" == "false" || "$mode" == "off" ]] && return 1
  [[ "$mode" == "1" || "$mode" == "true" || "$mode" == "always" ]] && return 0
  if [[ "$mode" == "auto" ]] && is_worker_worktree "$root"; then
    return 0
  fi
  return 1
}

is_worker_worktree() {
  local root="$1"
  case "$root" in
    */.claude/worktrees/*|*/.codex/worktrees/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

sandbox_string_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s\n' "$value"
}

real_path() {
  local path="$1"
  cd -- "$path" 2>/dev/null && pwd -P
}

write_home_deny_profile() {
  local profile="$1"
  local home_real=""
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  [[ -n "$home_real" ]] || return 0
  local escaped_home
  escaped_home="$(sandbox_string_escape "$home_real")"
  {
    printf '(deny file-read-data (literal "%s"))\n' "$escaped_home"
    printf '(deny file-write* (literal "%s"))\n' "$escaped_home"
    printf '(allow file-read-metadata (literal "%s") (literal "%s/.gitconfig") (literal "%s/.config") (literal "%s/.config/git") (literal "%s/.config/git/config"))\n' "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home"
    printf '(allow file-read-metadata (literal "/etc") (literal "/etc/bashrc") (literal "/etc/profile") (literal "/etc/static") (literal "/etc/static/bashrc") (literal "/etc/nix") (literal "/nix") (literal "/nix/var") (literal "/nix/var/nix") (literal "/nix/var/nix/daemon-socket") (literal "/var") (literal "/var/db") (literal "/private") (literal "/private/etc") (literal "/private/etc/bashrc") (literal "/private/etc/profile") (literal "/private/etc/static") (literal "/private/etc/static/bashrc") (literal "/private/etc/nix") (literal "/private/var") (literal "/private/var/db"))\n'
    printf '(allow file-read-metadata (literal "/Applications") (literal "/Applications/Xcode.app") (literal "/Applications/Xcode.app/Contents") (literal "/Applications/Xcode.app/Contents/Developer"))\n'
    printf '(allow file-read* (literal "/var/db/xcode_select_link") (literal "/private/var/db/xcode_select_link"))\n'
    printf '(allow file-read* (literal "/nix/var/nix/daemon-socket/socket") (literal "/etc/bashrc") (literal "/private/etc/bashrc") (literal "/etc/profile") (literal "/private/etc/profile") (literal "/etc/static/bashrc") (literal "/private/etc/static/bashrc") (literal "/etc/nix") (literal "/private/etc/nix"))\n'
    printf '(allow mach-lookup (global-name "com.apple.sysmond"))\n'
    printf '(allow process-info*)\n'
    printf '(allow signal)\n'
  } >"$profile"
}

nix_safehouse_readonly_paths() {
  local paths=("/nix/store" "/var/run/nix-daemon.socket")
  local developer_dir=""
  [[ -e "/nix/var/nix/daemon-socket/socket" ]] && paths+=("/nix/var/nix/daemon-socket/socket")
  [[ -e "/etc/nix" ]] && paths+=("/etc/nix")
  if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
    paths+=("/private/var/run/nix-daemon.socket")
    [[ -e "/etc/bashrc" ]] && paths+=("/etc/bashrc")
    [[ -e "/private/etc/bashrc" ]] && paths+=("/private/etc/bashrc")
    [[ -e "/etc/profile" ]] && paths+=("/etc/profile")
    [[ -e "/private/etc/profile" ]] && paths+=("/private/etc/profile")
    [[ -e "/etc/static/bashrc" ]] && paths+=("/etc/static/bashrc")
    [[ -e "/private/etc/static/bashrc" ]] && paths+=("/private/etc/static/bashrc")
    [[ -e "/private/etc/nix" ]] && paths+=("/private/etc/nix")
    [[ -e "/var/db/xcode_select_link" ]] && paths+=("/var/db/xcode_select_link")
    [[ -e "/private/var/db/xcode_select_link" ]] && paths+=("/private/var/db/xcode_select_link")
    developer_dir="$(xcode-select -p 2>/dev/null || true)"
    if [[ -z "$developer_dir" ]]; then
      developer_dir="/Applications/Xcode.app/Contents/Developer"
    fi
    [[ -e "$developer_dir" ]] && paths+=("$developer_dir")
  fi
  local IFS=:
  printf '%s\n' "${paths[*]}"
}

run_codex_in_safehouse() {
  local root="$1"
  shift
  local codex_home=""
  local codex_home_args=()
  local codex_args=()
  local home_real=""
  local nix_bin
  local profile
  local root_real
  local safehouse_cache
  local safehouse_home
  local nix_ro_paths
  local safehouse_path="${PATH:-}"
  local status
  while IFS= read -r -d '' arg; do
    codex_args+=("$arg")
  done < <(codex_default_sandbox_args "$@")
  root_real="$(real_path "$root")"
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  if [[ -n "${CODEX_HOME:-}" ]]; then
    case "$CODEX_HOME" in
      /*) codex_home="$CODEX_HOME" ;;
      *) codex_home="$root_real/$CODEX_HOME" ;;
    esac
  elif [[ -n "$home_real" ]]; then
    codex_home="$home_real/.codex"
  fi
  safehouse_cache="$root_real/buck-out/tmp/safehouse-cache/xdg"
  safehouse_home="$root_real/buck-out/tmp/safehouse-home"
  mkdir -p -- "$safehouse_cache" "$safehouse_home"
  if [[ -n "$codex_home" ]]; then
    mkdir -p -- "$codex_home" 2>/dev/null || true
    if [[ -d "$codex_home" ]]; then
      rm -rf -- "$safehouse_home/.codex"
      ln -s -- "$codex_home" "$safehouse_home/.codex"
      codex_home_args=(--add-dirs="$codex_home")
    fi
  fi
  nix_ro_paths="$(nix_safehouse_readonly_paths)"
  nix_bin="$(find_tool_excluding_wrapper_dir nix || true)"
  if [[ -n "$nix_bin" ]]; then
    safehouse_path="$(dirname -- "$nix_bin"):${safehouse_path}"
  fi
  profile="$(mktemp "${TMPDIR:-/tmp}/bnx-codex-safehouse.XXXXXX")"
  write_home_deny_profile "$profile"
  set +e
  env \
    BNX_CODEX_SAFEHOUSE_ACTIVE=1 \
    BNX_CODEX_SAFEHOUSE_ROOT="$root_real" \
    CODEX_HOME="$codex_home" \
    HOME="$safehouse_home" \
    NIX_DAEMON_SOCKET_PATH="/var/run/nix-daemon.socket" \
    NIX_REMOTE="daemon" \
    PATH="$safehouse_path" \
    BUCK2_REAL_HOME="$safehouse_home" \
    XDG_CACHE_HOME="$safehouse_cache" \
    "$safehouse" \
    --workdir="$root_real" \
    ${codex_home_args[@]+"${codex_home_args[@]}"} \
    --add-dirs-ro="$nix_ro_paths" \
    --append-profile="$profile" \
    --env \
    "$real_codex" \
    "${codex_args[@]}"
  status=$?
  set -e
  rm -f -- "$profile"
  exit "$status"
}

root="$(git_root || pwd -P)"
parse_codex_worktree_args "$@"

operation_count=0
[[ "$LIST_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))

if [[ "$operation_count" -gt 1 ]]; then
  echo "Error: worktree management flags cannot be combined" >&2
  exit 2
fi

if [[ "$FORCE_REMOVE_WORKTREE" == "1" && "$REMOVE_WORKTREE_REQUESTED" != "1" && "$REMOVE_ALL_WORKTREES_REQUESTED" != "1" ]]; then
  echo "Error: --force can only be combined with --remove-worktree or --remove-all-worktrees" >&2
  exit 2
fi

if [[ "$LIST_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot list Codex worktrees" >&2
    exit 127
  fi
  list_codex_worktrees "$root"
  exit 0
fi

if [[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Codex worktree" >&2
    exit 127
  fi
  if [[ -z "$REMOVE_WORKTREE_NAME" ]]; then
    echo "Error: --remove-worktree requires a worktree name" >&2
    exit 2
  fi
  remove_codex_worktree "$root" "$REMOVE_WORKTREE_NAME" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Codex worktrees" >&2
    exit 127
  fi
  remove_all_codex_worktrees "$root" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot create Codex worktree" >&2
    exit 127
  fi
  if [[ -z "$WORKTREE_NAME" ]]; then
    WORKTREE_NAME="$(default_worktree_name)"
  fi
  validate_worktree_name "$WORKTREE_NAME"
  if root="$(ensure_codex_worktree "$root" "$WORKTREE_NAME")"; then
    :
  else
    exit $?
  fi
  # Re-enter from the worktree so first launch and later resume use the same Safehouse path.
  cd -- "$root"
  exec "$SCRIPT_PATH" "${CODEX_ARGS[@]}"
fi

if should_safehouse_codex "$root"; then
  safehouse="$(find_tool_excluding_wrapper_dir safehouse || true)"
  if [[ -z "$safehouse" ]]; then
    echo "Error: safehouse not found; refusing to launch unsandboxed Codex: $root" >&2
    echo "Hint: run through the Nix dev shell so agent-safehouse is on PATH, or set BNX_CODEX_SAFEHOUSE=0 to bypass." >&2
    exit 127
  fi

  if is_worker_worktree "$root"; then
    run_codex_in_safehouse "$root" --dangerously-bypass-approvals-and-sandbox "$@"
  fi

  run_codex_in_safehouse "$root" "$@"
fi

codex_launch_args=()
while IFS= read -r -d '' arg; do
  codex_launch_args+=("$arg")
done < <(codex_default_sandbox_args "$@")

exec "$real_codex" "${codex_launch_args[@]}"
