#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname -- "${SCRIPT_PATH}")"

canonical_executable_path() {
  local file="$1"
  local target
  while [[ -L "$file" ]]; do
    target="$(readlink "$file")" || break
    case "$target" in
      /*) file="$target" ;;
      *) file="$(dirname -- "$file")/$target" ;;
    esac
  done
  printf '%s\n' "$(cd -- "$(dirname -- "$file")" && pwd -P)/$(basename -- "$file")"
}

is_transient_codex_arg0_path() {
  local dir="$1"
  [[ -n "$dir" && -n "${HOME:-}" ]] || return 1
  local dir_real
  local home_real
  dir_real="$(cd -- "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")"
  home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || printf '%s' "$HOME")"
  case "$dir_real" in
    "${home_real}/.codex/tmp/arg0"|"${home_real}/.codex/tmp/arg0"/*)
      return 0
      ;;
  esac
  return 1
}

VIBEROOTS_SOURCE_ROOT="$(cd -- "${SCRIPT_DIR}/../../.." && pwd -P)"

find_tool_in_path_list_excluding_wrapper_dir() {
  local tool="$1"
  local path_list="${2:-}"
  local dir
  local old_ifs="$IFS"
  IFS=':'
  for dir in ${path_list}; do
    [[ -n "$dir" ]] || continue
    is_transient_codex_arg0_path "$dir" && continue
    if [[ "$(cd -- "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")" == "$SCRIPT_DIR" ]]; then
      continue
    fi
    if [[ -x "$dir/$tool" ]]; then
      canonical_executable_path "$dir/$tool"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

managed_codex_path() {
  local candidate="${VBR_CODEX_MANAGED_PATH_FOR_TEST:-${VIBEROOTS_SOURCE_ROOT}/node_modules/.bin/codex}"
  [[ -n "$candidate" && -f "$candidate" && -x "$candidate" ]] || return 1
  canonical_executable_path "$candidate"
}

find_managed_codex_in_path_list() {
  local path_list="${1:-}"
  local managed="$2"
  local dir
  local found
  local old_ifs="$IFS"
  IFS=':'
  for dir in ${path_list}; do
    [[ -n "$dir" ]] || continue
    is_transient_codex_arg0_path "$dir" && continue
    if [[ "$(cd -- "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")" == "$SCRIPT_DIR" ]]; then
      continue
    fi
    if [[ -x "$dir/codex" ]]; then
      found="$(canonical_executable_path "$dir/codex")"
      if [[ "$found" == "$managed" ]]; then
        IFS="$old_ifs"
        return 0
      fi
    fi
  done
  IFS="$old_ifs"
  return 1
}

captured_host_path() {
  local start
  local dir
  for start in "${PWD:-}" "${WORKSPACE_ROOT:-}"; do
    [[ -n "$start" ]] || continue
    dir="$start"
    while [[ "$dir" != "/" ]]; do
      if [[ -f "$dir/.viberoots/workspace/host-path" ]]; then
        cat "$dir/.viberoots/workspace/host-path" 2>/dev/null || true
        return 0
      fi
      dir="$(dirname -- "$dir")"
    done
  done
  return 1
}

find_tool_excluding_wrapper_dir() {
  local tool="$1"
  local host_path
  find_tool_in_path_list_excluding_wrapper_dir "$tool" "${PATH:-}" && return 0
  host_path="$(captured_host_path || true)"
  find_tool_in_path_list_excluding_wrapper_dir "$tool" "$host_path" && return 0
  find_tool_in_path_list_excluding_wrapper_dir "$tool" "${VBR_HOST_PATH:-}" && return 0
  find_tool_in_path_list_excluding_wrapper_dir "$tool" "${HOST_PATH:-}" && return 0
  return 1
}

find_codex_excluding_wrapper_dir() {
  local managed
  managed="$(managed_codex_path || true)"
  if [[ -z "$managed" ]]; then
    echo "Error: viberoots-managed Codex is missing or not executable at ${VBR_CODEX_MANAGED_PATH_FOR_TEST:-${VIBEROOTS_SOURCE_ROOT}/node_modules/.bin/codex}" >&2
    echo "Hint: run the repo install path so Nix materializes the pinned @openai/codex package; do not fall back to /Applications/Codex.app or transient Codex arg0 shims." >&2
    return 1
  fi
  if [[ -n "${CODEX_CLI_PATH:-}" ]]; then
    local explicit
    explicit="$(canonical_executable_path "${CODEX_CLI_PATH}" 2>/dev/null || true)"
    if [[ "$explicit" == "$managed" ]]; then
      printf '%s\n' "$managed"
      return 0
    fi
    echo "Error: CODEX_CLI_PATH must point to the viberoots-managed Codex at ${managed}" >&2
    echo "Refusing unmanaged Codex path: ${CODEX_CLI_PATH}" >&2
    return 1
  fi
  if find_managed_codex_in_path_list "${PATH:-}" "$managed"; then
    printf '%s\n' "$managed"
    return 0
  fi
  echo "Error: viberoots-managed Codex is not on PATH: ${managed}" >&2
  echo "Hint: enter the Nix dev shell or rerun the repo install path; do not fall back to /Applications/Codex.app or transient Codex arg0 shims." >&2
  return 1
}

real_codex="$(find_codex_excluding_wrapper_dir || true)"
if [[ -z "$real_codex" ]]; then
  exit 1
fi

if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] && command -v xattr >/dev/null 2>&1; then
  if xattr -p com.apple.quarantine "$real_codex" >/dev/null 2>&1; then
    echo "Error: viberoots-managed Codex is quarantined by macOS: $real_codex" >&2
    echo "Hint: fix the Nix Codex package/signing or quarantine state; refusing app or arg0 fallback." >&2
    exit 126
  fi
fi

real_git="$(find_tool_excluding_wrapper_dir git || true)"

mark_macos_metadata_never_index() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] || return 0
  local dir
  for dir in "$@"; do
    [[ -n "$dir" ]] || continue
    [[ -e "${dir}/.metadata_never_index" ]] || : > "${dir}/.metadata_never_index" 2>/dev/null || true
  done
}

git_root() {
  [[ -n "$real_git" ]] || return 1
  "$real_git" rev-parse --show-toplevel 2>/dev/null
}

WORKTREE_REQUESTED=0
LIST_WORKTREES_REQUESTED=0
REMOVE_WORKTREE_REQUESTED=0
REMOVE_ALL_WORKTREES_REQUESTED=0
FORCE_REMOVE_WORKTREE=0
WORKTREE_NAME=""
REMOVE_WORKTREE_NAME=""
CODEX_ARGS=()

codex_args_request_sandbox() {
  local token
  while [[ "$#" -gt 0 ]]; do
    token="$1"
    shift
    case "$token" in
      --sandbox|--sandbox=*|-s|--dangerously-bypass-approvals-and-sandbox)
        return 0
        ;;
    esac
  done
  return 1
}

codex_args_are_top_level_introspection() {
  case "${1:-}" in
    --version|-V|version|--help|-h|help)
      return 0
      ;;
  esac
  return 1
}

codex_default_sandbox_args() {
  if codex_args_are_top_level_introspection "$@" || codex_args_request_sandbox "$@"; then
    printf '%s\0' "$@"
  else
    printf '%s\0' --sandbox danger-full-access "$@"
  fi
}

parse_codex_worktree_args() {
  local token
  while [[ "$#" -gt 0 ]]; do
    token="$1"
    shift

    case "$token" in
      --force)
        FORCE_REMOVE_WORKTREE=1
        ;;
      --list-worktrees)
        LIST_WORKTREES_REQUESTED=1
        ;;
      --remove-worktree=*)
        REMOVE_WORKTREE_REQUESTED=1
        REMOVE_WORKTREE_NAME="${token#--remove-worktree=}"
        ;;
      --remove-worktree)
        REMOVE_WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          REMOVE_WORKTREE_NAME="$1"
          shift
        fi
        ;;
      --remove-all-worktrees)
        REMOVE_ALL_WORKTREES_REQUESTED=1
        ;;
      --worktree=*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#--worktree=}"
        ;;
      --worktree|-w)
        WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          WORKTREE_NAME="$1"
          shift
        fi
        ;;
      -w?*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#-w}"
        ;;
      *)
        CODEX_ARGS+=("$token")
        ;;
    esac
  done
}

default_worktree_name() {
  printf 'codex-%s-%s\n' "$(date +%Y%m%d%H%M%S)" "$$"
}

validate_worktree_name() {
  local name="$1"
  if [[ -z "$name" || "$name" == /* || "$name" == *"/"* || "$name" == "." || "$name" == ".." || "$name" == *".."* ]]; then
    echo "Error: invalid Codex worktree name: ${name}" >&2
    return 2
  fi
}

git_worktree_base() {
  if [[ -n "$real_git" ]] && "$real_git" rev-parse --verify --quiet origin/HEAD >/dev/null 2>&1; then
    printf '%s\n' "origin/HEAD"
    return 0
  fi
  printf '%s\n' "HEAD"
}

git_branch_exists() {
  local branch="$1"
  "$real_git" rev-parse --verify --quiet "refs/heads/${branch}" >/dev/null 2>&1
}

list_codex_worktrees() {
  local root="$1"
  local base="${root}/.codex/worktrees"
  local name
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      printf '%s\t%s\n' "$name" "$worktree"
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
}

remove_codex_worktree() {
  local root="$1"
  local name="$2"
  local force="${3:-0}"
  local target="${root}/.codex/worktrees/${name}"
  local branch="worktree-${name}"
  local remove_error
  local remove_force=0
  local status

  validate_worktree_name "$name"
  if [[ ! -e "$target/.git" ]] || ! "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Codex worktree not found: ${name}" >&2
    return 1
  fi

  if [[ "$force" == "1" ]]; then
    remove_force=1
  elif worktree_has_only_discardable_autogenerated_changes "$target"; then
    echo "Info: ${name} has only discardable autogenerated provider changes; removing with --force" >&2
    remove_force=1
  fi

  remove_error="$(mktemp "${TMPDIR:-/tmp}/vbr-codex-worktree-remove.XXXXXX")"
  set +e
  if [[ "$remove_force" == "1" ]]; then
    git_remove_worktree "$root" "$target" "$remove_error" --force
  else
    git_remove_worktree "$root" "$target" "$remove_error"
  fi
  status=$?
  set -e
  if [[ "$status" -ne 0 ]]; then
    if worktree_remove_failed_because_submodules "$remove_error"; then
      if [[ "$force" == "1" ]] || worktree_clean_for_submodule_force "$target"; then
        echo "Info: ${name} contains clean submodules; deinitializing them before forced removal" >&2
        "$real_git" -C "$target" submodule deinit -f --all
        set +e
        git_remove_worktree "$root" "$target" "$remove_error" --force
        status=$?
        set -e
      fi
    fi
  fi
  cat "$remove_error" >&2
  rm -f -- "$remove_error"
  [[ "$status" -eq 0 ]] || return "$status"

  if git_branch_exists "$branch"; then
    set +e
    "$real_git" -C "$root" branch -D "$branch"
    status=$?
    set -e
    [[ "$status" -eq 0 ]] || return "$status"
  fi

  "$real_git" -C "$root" worktree prune
}

git_remove_worktree() {
  local root="$1"
  local target="$2"
  local stderr_file="$3"
  shift 3
  : > "$stderr_file"
  (
    cd -- "$root"
    "$real_git" worktree remove "$@" "$target" 2> "$stderr_file"
  )
}

worktree_remove_failed_because_submodules() {
  local stderr_file="$1"
  grep -q "working trees containing submodules cannot be moved or removed" "$stderr_file"
}

worktree_clean_for_submodule_force() {
  local target="$1"
  local status_file
  status_file="$(mktemp "${TMPDIR:-/tmp}/vbr-codex-worktree-clean.XXXXXX")"
  if ! "$real_git" -C "$target" status --porcelain -z --untracked-files=all > "$status_file"; then
    rm -f -- "$status_file"
    return 1
  fi
  if [[ -s "$status_file" ]]; then
    rm -f -- "$status_file"
    return 1
  fi
  rm -f -- "$status_file"
  "$real_git" -C "$target" submodule foreach --quiet --recursive \
    'test -z "$(git status --porcelain --untracked-files=all)"'
}

worktree_has_only_discardable_autogenerated_changes() {
  local target="$1"
  local item
  local path
  local status
  local status_file
  local saw_discardable=0

  status_file="$(mktemp "${TMPDIR:-/tmp}/vbr-codex-worktree-status.XXXXXX")"
  if ! "$real_git" -C "$target" status --porcelain -z --untracked-files=all > "$status_file"; then
    rm -f -- "$status_file"
    return 1
  fi

  while IFS= read -r -d '' item; do
    [[ -n "$item" ]] || continue
    status="${item:0:2}"
    path="${item:3}"
    case "${status}:${path}" in
      " M:.viberoots/workspace/providers/TARGETS"|" M:.viberoots/workspace/providers/TARGETS."*.auto|" M:.viberoots/workspace/providers/auto_map.bzl"|" M:.viberoots/workspace/providers/nix_attr_map.bzl")
        saw_discardable=1
        ;;
      *)
        rm -f -- "$status_file"
        return 1
        ;;
    esac
  done < "$status_file"

  rm -f -- "$status_file"
  [[ "$saw_discardable" == "1" ]]
}

remove_all_codex_worktrees() {
  local root="$1"
  local force="${2:-0}"
  local base="${root}/.codex/worktrees"
  local name
  local status=0
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      if remove_codex_worktree "$root" "$name" "$force"; then
        :
      else
        status=1
      fi
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
  return "$status"
}

ensure_codex_worktree() {
  local root="$1"
  local name="$2"
  local target="${root}/.codex/worktrees/${name}"
  local branch="worktree-${name}"
  local base
  local git_wrapper="${VBR_CODEX_GIT_WRAPPER_FOR_TEST:-${SCRIPT_DIR}/git}"

  if [[ -e "$target/.git" ]]; then
    if "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      printf '%s\n' "$target"
      return 0
    fi
    echo "Error: existing Codex worktree path is not a valid git worktree: ${target}" >&2
    return 1
  fi

  if [[ -e "$target" ]]; then
    echo "Error: Codex worktree path already exists but is not a git worktree: ${target}" >&2
    return 1
  fi

  if [[ ! -x "$git_wrapper" ]]; then
    echo "Error: git CoW wrapper not found: ${git_wrapper}" >&2
    return 127
  fi

  mkdir -p -- "$(dirname -- "$target")"
  if git_branch_exists "$branch"; then
    (
      cd -- "$root"
      "$git_wrapper" worktree add "$target" "$branch" >&2
    )
  else
    base="$(git_worktree_base)"
    (
      cd -- "$root"
      "$git_wrapper" worktree add -b "$branch" "$target" "$base" >&2
    )
  fi
  printf '%s\n' "$target"
}

should_safehouse_codex() {
  local mode="${VBR_CODEX_SAFEHOUSE:-auto}"
  local root="$1"

  if [[ "${VBR_CODEX_SAFEHOUSE_ACTIVE:-}" == "1" ]]; then
    if [[ -n "${VBR_CODEX_SAFEHOUSE_ROOT:-}" && "$(real_path "$root")" != "$(real_path "$VBR_CODEX_SAFEHOUSE_ROOT")" ]]; then
      echo "Error: cannot launch Codex worktree agent from inside another Safehouse sandbox: $root" >&2
      echo "Hint: macOS sandbox-exec cannot apply a nested sandbox; launch the parent without VBR_CODEX_SAFEHOUSE=always." >&2
      exit 126
    fi
    return 1
  fi
  [[ "$mode" == "0" || "$mode" == "false" || "$mode" == "off" ]] && return 1
  [[ "$mode" == "1" || "$mode" == "true" || "$mode" == "always" ]] && return 0
  if [[ "$mode" == "auto" ]] && is_worker_worktree "$root"; then
    return 0
  fi
  return 1
}

is_worker_worktree() {
  local root="$1"
  case "$root" in
    */.claude/worktrees/*|*/.codex/worktrees/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

sandbox_string_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s\n' "$value"
}

real_path() {
  local path="$1"
  cd -- "$path" 2>/dev/null && pwd -P
}

write_home_deny_profile() {
  local profile="$1"
  local known_hosts="${2:-}"
  local home_real=""
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  [[ -n "$home_real" ]] || return 0
  local escaped_home
  escaped_home="$(sandbox_string_escape "$home_real")"
  local escaped_known_hosts=""
  if [[ -n "$known_hosts" ]]; then
    escaped_known_hosts="$(sandbox_string_escape "$known_hosts")"
  fi
  {
    printf '(deny file-read-data (literal "%s"))\n' "$escaped_home"
    printf '(deny file-write* (literal "%s"))\n' "$escaped_home"
    printf '(allow file-read-metadata (literal "%s") (literal "%s/.gitconfig") (literal "%s/.config") (literal "%s/.config/git") (literal "%s/.config/git/config") (literal "%s/.ssh"))\n' "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home"
    if [[ -n "$escaped_known_hosts" ]]; then
      printf '(allow file-read* (literal "%s"))\n' "$escaped_known_hosts"
    fi
    printf '(allow file-read-metadata (literal "/etc") (literal "/etc/bashrc") (literal "/etc/profile") (literal "/etc/static") (literal "/etc/static/bashrc") (literal "/etc/nix") (literal "/nix") (literal "/nix/var") (literal "/nix/var/nix") (literal "/nix/var/nix/daemon-socket") (literal "/var") (literal "/var/db") (literal "/private") (literal "/private/etc") (literal "/private/etc/bashrc") (literal "/private/etc/profile") (literal "/private/etc/static") (literal "/private/etc/static/bashrc") (literal "/private/etc/nix") (literal "/private/var") (literal "/private/var/db"))\n'
    printf '(allow file-read-metadata (literal "/Applications") (literal "/Applications/Xcode.app") (literal "/Applications/Xcode.app/Contents") (literal "/Applications/Xcode.app/Contents/Developer"))\n'
    printf '(allow file-read* (literal "/var/db/xcode_select_link") (literal "/private/var/db/xcode_select_link"))\n'
    printf '(allow file-read* (literal "/nix/var/nix/daemon-socket/socket") (literal "/etc/bashrc") (literal "/private/etc/bashrc") (literal "/etc/profile") (literal "/private/etc/profile") (literal "/etc/static/bashrc") (literal "/private/etc/static/bashrc") (literal "/etc/nix") (literal "/private/etc/nix"))\n'
    printf '(allow mach-lookup (global-name "com.apple.securityd") (global-name "com.apple.sysmond"))\n'
    printf '(allow process-info*)\n'
    printf '(allow signal)\n'
  } >"$profile"
}

safehouse_known_hosts_path() {
  local home_real="$1"
  [[ -n "$home_real" ]] || return 0
  local candidate="$home_real/.ssh/known_hosts"
  [[ -f "$candidate" ]] || return 0
  cd -- "$(dirname -- "$candidate")" 2>/dev/null || return 0
  printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$candidate")"
}

nix_safehouse_readonly_paths() {
  local paths=("/nix/store" "/var/run/nix-daemon.socket")
  local developer_dir=""
  [[ -e "/nix/var/nix/daemon-socket/socket" ]] && paths+=("/nix/var/nix/daemon-socket/socket")
  [[ -e "/etc/nix" ]] && paths+=("/etc/nix")
  if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
    paths+=("/private/var/run/nix-daemon.socket")
    [[ -e "/etc/bashrc" ]] && paths+=("/etc/bashrc")
    [[ -e "/private/etc/bashrc" ]] && paths+=("/private/etc/bashrc")
    [[ -e "/etc/profile" ]] && paths+=("/etc/profile")
    [[ -e "/private/etc/profile" ]] && paths+=("/private/etc/profile")
    [[ -e "/etc/static/bashrc" ]] && paths+=("/etc/static/bashrc")
    [[ -e "/private/etc/static/bashrc" ]] && paths+=("/private/etc/static/bashrc")
    [[ -e "/private/etc/nix" ]] && paths+=("/private/etc/nix")
    [[ -e "/var/db/xcode_select_link" ]] && paths+=("/var/db/xcode_select_link")
    [[ -e "/private/var/db/xcode_select_link" ]] && paths+=("/private/var/db/xcode_select_link")
    developer_dir="$(xcode-select -p 2>/dev/null || true)"
    if [[ -z "$developer_dir" ]]; then
      developer_dir="/Applications/Xcode.app/Contents/Developer"
    fi
    [[ -e "$developer_dir" ]] && paths+=("$developer_dir")
  fi
  local IFS=:
  printf '%s\n' "${paths[*]}"
}

run_codex_in_safehouse() {
  local root="$1"
  shift
  local codex_home=""
  local codex_home_args=()
  local codex_args=()
  local home_real=""
  local known_hosts=""
  local nix_bin
  local profile
  local root_real
  local safehouse_tmp
  local safehouse_cache_parent
  local safehouse_cache
  local safehouse_home
  local nix_ro_paths
  local safehouse_path="${PATH:-}"
  local status
  while IFS= read -r -d '' arg; do
    codex_args+=("$arg")
  done < <(codex_default_sandbox_args "$@")
  root_real="$(real_path "$root")"
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  known_hosts="$(safehouse_known_hosts_path "$home_real")"
  if [[ -n "${CODEX_HOME:-}" ]]; then
    case "$CODEX_HOME" in
      /*) codex_home="$CODEX_HOME" ;;
      *) codex_home="$root_real/$CODEX_HOME" ;;
    esac
  elif [[ -n "$home_real" ]]; then
    codex_home="$home_real/.codex"
  fi
  safehouse_tmp="$root_real/buck-out/tmp"
  safehouse_cache_parent="$safehouse_tmp/safehouse-cache"
  safehouse_cache="$root_real/buck-out/tmp/safehouse-cache/xdg"
  safehouse_home="$root_real/buck-out/tmp/safehouse-home"
  mkdir -p -- "$root_real/buck-out"
  mark_macos_metadata_never_index "$root_real/buck-out"
  mkdir -p -- "$safehouse_tmp"
  mark_macos_metadata_never_index "$safehouse_tmp"
  mkdir -p -- "$safehouse_cache_parent"
  mark_macos_metadata_never_index "$safehouse_cache_parent"
  mkdir -p -- "$safehouse_cache" "$safehouse_home"
  mark_macos_metadata_never_index \
    "$safehouse_cache" \
    "$safehouse_home"
  rm -f -- "$safehouse_home/.ssh/known_hosts" 2>/dev/null || true
  if [[ -n "$known_hosts" ]]; then
    mkdir -p -- "$safehouse_home/.ssh"
    mark_macos_metadata_never_index "$safehouse_home/.ssh"
    ln -s -- "$known_hosts" "$safehouse_home/.ssh/known_hosts"
  fi
  if [[ -n "$codex_home" ]]; then
    mkdir -p -- "$codex_home" 2>/dev/null || true
    if [[ -d "$codex_home" ]]; then
      rm -rf -- "$safehouse_home/.codex"
      ln -s -- "$codex_home" "$safehouse_home/.codex"
      codex_home_args=(--add-dirs="$codex_home")
    fi
  fi
  nix_ro_paths="$(nix_safehouse_readonly_paths)"
  nix_bin="$(find_tool_excluding_wrapper_dir nix || true)"
  if [[ -n "$nix_bin" ]]; then
    safehouse_path="$(dirname -- "$nix_bin"):${safehouse_path}"
  fi
  profile="$(mktemp "${TMPDIR:-/tmp}/vbr-codex-safehouse.XXXXXX")"
  write_home_deny_profile "$profile" "$known_hosts"
  set +e
  env \
    VBR_CODEX_SAFEHOUSE_ACTIVE=1 \
    VBR_CODEX_SAFEHOUSE_ROOT="$root_real" \
    CODEX_HOME="$codex_home" \
    HOME="$safehouse_home" \
    NIX_DAEMON_SOCKET_PATH="/var/run/nix-daemon.socket" \
    NIX_REMOTE="daemon" \
    PATH="$safehouse_path" \
    BUCK2_REAL_HOME="$safehouse_home" \
    XDG_CACHE_HOME="$safehouse_cache" \
    "$safehouse" \
    --enable=keychain \
    --workdir="$root_real" \
    ${codex_home_args[@]+"${codex_home_args[@]}"} \
    --add-dirs-ro="$nix_ro_paths" \
    ${known_hosts:+--add-dirs-ro="$known_hosts"} \
    --append-profile="$profile" \
    --env \
    "$real_codex" \
    "${codex_args[@]}"
  status=$?
  set -e
  rm -f -- "$profile"
  exit "$status"
}

root="$(git_root || pwd -P)"
parse_codex_worktree_args "$@"

operation_count=0
[[ "$LIST_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))

if [[ "$operation_count" -gt 1 ]]; then
  echo "Error: worktree management flags cannot be combined" >&2
  exit 2
fi

if [[ "$FORCE_REMOVE_WORKTREE" == "1" && "$REMOVE_WORKTREE_REQUESTED" != "1" && "$REMOVE_ALL_WORKTREES_REQUESTED" != "1" ]]; then
  echo "Error: --force can only be combined with --remove-worktree or --remove-all-worktrees" >&2
  exit 2
fi

if [[ "$LIST_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot list Codex worktrees" >&2
    exit 127
  fi
  list_codex_worktrees "$root"
  exit 0
fi

if [[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Codex worktree" >&2
    exit 127
  fi
  if [[ -z "$REMOVE_WORKTREE_NAME" ]]; then
    echo "Error: --remove-worktree requires a worktree name" >&2
    exit 2
  fi
  remove_codex_worktree "$root" "$REMOVE_WORKTREE_NAME" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Codex worktrees" >&2
    exit 127
  fi
  remove_all_codex_worktrees "$root" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot create Codex worktree" >&2
    exit 127
  fi
  if [[ -z "$WORKTREE_NAME" ]]; then
    WORKTREE_NAME="$(default_worktree_name)"
  fi
  validate_worktree_name "$WORKTREE_NAME"
  if root="$(ensure_codex_worktree "$root" "$WORKTREE_NAME")"; then
    :
  else
    exit $?
  fi
  # Re-enter from the worktree so first launch and later resume use the same Safehouse path.
  cd -- "$root"
  exec "$SCRIPT_PATH" "${CODEX_ARGS[@]}"
fi

if should_safehouse_codex "$root"; then
  safehouse="$(find_tool_excluding_wrapper_dir safehouse || true)"
  if [[ -z "$safehouse" ]]; then
    echo "Error: safehouse not found; refusing to launch unsandboxed Codex: $root" >&2
    echo "Hint: run through the Nix dev shell so agent-safehouse is on PATH, or set VBR_CODEX_SAFEHOUSE=0 to bypass." >&2
    exit 127
  fi

  if is_worker_worktree "$root" && ! codex_args_are_top_level_introspection "$@"; then
    run_codex_in_safehouse "$root" --dangerously-bypass-approvals-and-sandbox "$@"
  fi

  run_codex_in_safehouse "$root" "$@"
fi

codex_launch_args=()
while IFS= read -r -d '' arg; do
  codex_launch_args+=("$arg")
done < <(codex_default_sandbox_args "$@")

exec "$real_codex" "${codex_launch_args[@]}"
