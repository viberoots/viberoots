#!/usr/bin/env bash
set -euo pipefail

# Uniform gomod2nix entrypoint for dev and CI.
# Prefer a flake app, then shell, then a bare binary on PATH.

ARGS=("$@")

try_run() {
  local cmd=(bash --noprofile --norc -c "exec $1")
  if "${cmd[@]}"; then
    exit 0
  fi
}

# If gomod2nix already on PATH (e.g., via dev shell), use it directly
if command -v gomod2nix >/dev/null 2>&1; then exec gomod2nix "${ARGS[@]}"; fi

# Prefer repo-pinned app first for determinism across platforms
try_run "nix run --accept-flake-config .#gomod2nix -- ${ARGS[*]} 2>/dev/null" || true

# Fallback to nixpkgs app/shell if repo app is unavailable on this platform
try_run "nix run --accept-flake-config nixpkgs#gomod2nix -- ${ARGS[*]} 2>/dev/null" || true
try_run "nix shell --accept-flake-config nixpkgs#gomod2nix -c bash --noprofile --norc -c 'exec gomod2nix ${ARGS[*]}' 2>/dev/null" || true

echo "error: gomod2nix is not available via nix on this platform (nixpkgs app missing and upstream unreachable). Ensure a pinned gomod2nix input is present in flake.nix or provide a nixpkgs release that includes gomod2nix." >&2
exit 127


