#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

if [[ "${1:-}" == "aws-account" && -z "${VIBEROOTS_AWS_ACCOUNT_NIX_ENV:-}" && -z "${NO_DEV_SHELL:-}" ]]; then
  REPO_ROOT="$(cd "${SCRIPT_DIR}/../../.." && pwd)"
  if command -v nix >/dev/null 2>&1; then
    exec nix develop --accept-flake-config "${REPO_ROOT}#" -c env VIBEROOTS_AWS_ACCOUNT_NIX_ENV=1 "${SCRIPT_DIR}/control-plane" "$@"
  fi
fi

# shellcheck source=/dev/null
. "${SCRIPT_DIR}/devshell.sh"

if [[ "${1:-}" == "aws-account" && -z "${IN_NIX_SHELL:-}" && -z "${NO_DEV_SHELL:-}" ]]; then
  export BUCK_DEV_SHELL_FASTPATH=0
fi

run_ts "../deployments/deployment-control-plane.ts" "$@"
