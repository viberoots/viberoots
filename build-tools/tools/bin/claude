#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(dirname -- "${SCRIPT_PATH}")"

is_cmux_claude_wrapper() {
  local candidate="$1"
  local candidate_dir
  [[ -x "$candidate" ]] || return 1
  candidate_dir="$(cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd -P || return 1)"
  [[ -x "$candidate_dir/cmux" ]] || return 1
  LC_ALL=C sed -n '1,8p' "$candidate" 2>/dev/null | grep -q "cmux claude wrapper"
}

find_tool_excluding_wrapper_dir() {
  local tool="$1"
  local dir
  local candidate
  local old_ifs="$IFS"
  IFS=':'
  for dir in ${PATH:-}; do
    [[ -n "$dir" ]] || continue
    if [[ "$(cd -- "$dir" 2>/dev/null && pwd -P || printf '%s' "$dir")" == "$SCRIPT_DIR" ]]; then
      continue
    fi
    candidate="$dir/$tool"
    if [[ "$tool" == "claude" ]] && is_cmux_claude_wrapper "$candidate"; then
      continue
    fi
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$(cd -- "$(dirname -- "$candidate")" && pwd -P)/$(basename -- "$candidate")"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"
  return 1
}

detect_claude_platform_key() {
  local system
  local machine
  local cpu=""
  local libc_suffix=""

  if [[ -n "${VBR_CLAUDE_PLATFORM_KEY_FOR_TEST:-}" ]]; then
    printf '%s\n' "$VBR_CLAUDE_PLATFORM_KEY_FOR_TEST"
    return 0
  fi

  system="$(uname -s 2>/dev/null || true)"
  machine="$(uname -m 2>/dev/null || true)"
  case "$machine" in
    x86_64|amd64)
      cpu="x64"
      ;;
    arm64|aarch64)
      cpu="arm64"
      ;;
    arm|armv7l|armv6l)
      cpu="arm"
      ;;
    *)
      return 1
      ;;
  esac

  case "$system" in
    Darwin)
      if [[ "$cpu" == "x64" && "$(sysctl -n sysctl.proc_translated 2>/dev/null || true)" == "1" ]]; then
        cpu="arm64"
      fi
      printf 'darwin-%s\n' "$cpu"
      ;;
    Linux)
      if command -v node >/dev/null 2>&1; then
        if node -e 'const r=process.report?.getReport?.(); process.exit(r && r.header && r.header.glibcVersionRuntime === undefined ? 0 : 1)' >/dev/null 2>&1; then
          libc_suffix="-musl"
        fi
      fi
      printf 'linux-%s%s\n' "$cpu" "$libc_suffix"
      ;;
    *)
      return 1
      ;;
  esac
}

resolve_native_claude_from_node_modules_bin() {
  local candidate="$1"
  local bin_dir
  local node_modules_dir
  local platform_key
  local native

  case "$candidate" in
    */node_modules/.bin/claude)
      ;;
    *)
      return 1
      ;;
  esac

  bin_dir="$(cd -- "$(dirname -- "$candidate")" 2>/dev/null && pwd -P || return 1)"
  node_modules_dir="$(cd -- "${bin_dir}/.." 2>/dev/null && pwd -P || return 1)"
  platform_key="$(detect_claude_platform_key || true)"
  [[ -n "$platform_key" ]] || return 1

  for native in \
    "${node_modules_dir}/.pnpm/@anthropic-ai+claude-code-${platform_key}"@*/node_modules/@anthropic-ai/claude-code-"${platform_key}"/claude \
    "${node_modules_dir}/.pnpm/node_modules/@anthropic-ai/claude-code-${platform_key}/claude" \
    "${node_modules_dir}/@anthropic-ai/claude-code-${platform_key}/claude"; do
    [[ -x "$native" ]] || continue
    printf '%s\n' "$native"
    return 0
  done

  return 1
}

real_git="$(find_tool_excluding_wrapper_dir git || true)"

mark_macos_metadata_never_index() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] || return 0
  local dir
  for dir in "$@"; do
    [[ -n "$dir" ]] || continue
    [[ -e "${dir}/.metadata_never_index" ]] || : > "${dir}/.metadata_never_index" 2>/dev/null || true
  done
}

resolve_native_claude_from_git_root_node_modules() {
  local root
  local native
  [[ -n "$real_git" ]] || return 1
  root="$("$real_git" rev-parse --show-toplevel 2>/dev/null || true)"
  [[ -n "$root" ]] || return 1
  native="$(resolve_native_claude_from_node_modules_bin "${root}/node_modules/.bin/claude" || true)"
  [[ -n "$native" ]] || return 1
  printf '%s\n' "$native"
  return 0
}

resolve_native_claude_from_cwd_node_modules() {
  local native
  native="$(resolve_native_claude_from_node_modules_bin "$(pwd -P)/node_modules/.bin/claude" || true)"
  [[ -n "$native" ]] || return 1
  printf '%s\n' "$native"
  return 0
}

real_claude="$(resolve_native_claude_from_cwd_node_modules || resolve_native_claude_from_git_root_node_modules || true)"
if [[ -z "$real_claude" ]]; then
  real_claude="$(find_tool_excluding_wrapper_dir claude || true)"
fi
if [[ -z "$real_claude" ]]; then
  echo "Error: claude binary not found in PATH (excluding wrapper directory)" >&2
  exit 1
fi
native_claude="$(resolve_native_claude_from_node_modules_bin "$real_claude" || true)"
if [[ -n "$native_claude" && "$native_claude" != "$real_claude" ]]; then
  real_claude="$native_claude"
fi

git_root() {
  [[ -n "$real_git" ]] || return 1
  "$real_git" rev-parse --show-toplevel 2>/dev/null
}

WORKTREE_REQUESTED=0
LIST_WORKTREES_REQUESTED=0
REMOVE_WORKTREE_REQUESTED=0
REMOVE_ALL_WORKTREES_REQUESTED=0
FORCE_REMOVE_WORKTREE=0
WORKTREE_NAME=""
REMOVE_WORKTREE_NAME=""
CLAUDE_ARGS=()

parse_claude_worktree_args() {
  local token
  while [[ "$#" -gt 0 ]]; do
    token="$1"
    shift

    case "$token" in
      --force)
        FORCE_REMOVE_WORKTREE=1
        ;;
      --list-worktrees)
        LIST_WORKTREES_REQUESTED=1
        ;;
      --remove-worktree=*)
        REMOVE_WORKTREE_REQUESTED=1
        REMOVE_WORKTREE_NAME="${token#--remove-worktree=}"
        ;;
      --remove-worktree)
        REMOVE_WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          REMOVE_WORKTREE_NAME="$1"
          shift
        fi
        ;;
      --remove-all-worktrees)
        REMOVE_ALL_WORKTREES_REQUESTED=1
        ;;
      --worktree=*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#--worktree=}"
        ;;
      --worktree|-w)
        WORKTREE_REQUESTED=1
        if [[ "$#" -gt 0 && "${1:-}" != -* ]]; then
          WORKTREE_NAME="$1"
          shift
        fi
        ;;
      -w?*)
        WORKTREE_REQUESTED=1
        WORKTREE_NAME="${token#-w}"
        ;;
      --yolo)
        CLAUDE_ARGS+=("--dangerously-skip-permissions")
        ;;
      *)
        CLAUDE_ARGS+=("$token")
        ;;
    esac
  done
}

claude_args_request_skip_permissions() {
  local token
  for token in "$@"; do
    case "$token" in
      --dangerously-skip-permissions)
        return 0
        ;;
    esac
  done
  return 1
}

default_worktree_name() {
  printf 'claude-%s-%s\n' "$(date +%Y%m%d%H%M%S)" "$$"
}

validate_worktree_name() {
  local name="$1"
  if [[ -z "$name" || "$name" == /* || "$name" == *"/"* || "$name" == "." || "$name" == ".." || "$name" == *".."* ]]; then
    echo "Error: invalid Claude worktree name: ${name}" >&2
    return 2
  fi
}

git_worktree_base() {
  if [[ -n "$real_git" ]] && "$real_git" rev-parse --verify --quiet origin/HEAD >/dev/null 2>&1; then
    printf '%s\n' "origin/HEAD"
    return 0
  fi
  printf '%s\n' "HEAD"
}

git_branch_exists() {
  local branch="$1"
  "$real_git" rev-parse --verify --quiet "refs/heads/${branch}" >/dev/null 2>&1
}

list_claude_worktrees() {
  local root="$1"
  local base="${root}/.claude/worktrees"
  local name
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      printf '%s\t%s\n' "$name" "$worktree"
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
}

remove_claude_worktree() {
  local root="$1"
  local name="$2"
  local force="${3:-0}"
  local target="${root}/.claude/worktrees/${name}"
  local branch="worktree-${name}"
  local remove_flags=()
  local status

  validate_worktree_name "$name"
  if [[ ! -e "$target/.git" ]] || ! "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "Error: Claude worktree not found: ${name}" >&2
    return 1
  fi

  if [[ "$force" == "1" ]]; then
    remove_flags=(--force)
  elif worktree_has_only_discardable_autogenerated_changes "$target"; then
    echo "Info: ${name} has only discardable autogenerated provider changes; removing with --force" >&2
    remove_flags=(--force)
  fi

  set +e
  (
    cd -- "$root"
    if [[ "${#remove_flags[@]}" -gt 0 ]]; then
      "$real_git" worktree remove "${remove_flags[@]}" "$target"
    else
      "$real_git" worktree remove "$target"
    fi
  )
  status=$?
  set -e
  [[ "$status" -eq 0 ]] || return "$status"

  if git_branch_exists "$branch"; then
    set +e
    "$real_git" -C "$root" branch -D "$branch"
    status=$?
    set -e
    [[ "$status" -eq 0 ]] || return "$status"
  fi

  "$real_git" -C "$root" worktree prune
}

worktree_has_only_discardable_autogenerated_changes() {
  local target="$1"
  local item
  local path
  local status
  local status_file
  local saw_discardable=0

  status_file="$(mktemp "${TMPDIR:-/tmp}/vbr-claude-worktree-status.XXXXXX")"
  if ! "$real_git" -C "$target" status --porcelain -z --untracked-files=all > "$status_file"; then
    rm -f -- "$status_file"
    return 1
  fi

  while IFS= read -r -d '' item; do
    [[ -n "$item" ]] || continue
    status="${item:0:2}"
    path="${item:3}"
    case "${status}:${path}" in
      " M:.viberoots/workspace/providers/TARGETS"|" M:.viberoots/workspace/providers/TARGETS."*.auto|" M:.viberoots/workspace/providers/auto_map.bzl"|" M:.viberoots/workspace/providers/nix_attr_map.bzl")
        saw_discardable=1
        ;;
      *)
        rm -f -- "$status_file"
        return 1
        ;;
    esac
  done < "$status_file"

  rm -f -- "$status_file"
  [[ "$saw_discardable" == "1" ]]
}

remove_all_claude_worktrees() {
  local root="$1"
  local force="${2:-0}"
  local base="${root}/.claude/worktrees"
  local name
  local status=0
  local worktree
  [[ -d "$base" ]] || return 0
  while IFS= read -r -d '' worktree; do
    if [[ -e "$worktree/.git" ]] && "$real_git" -C "$worktree" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      name="$(basename -- "$worktree")"
      if remove_claude_worktree "$root" "$name" "$force"; then
        :
      else
        status=1
      fi
    fi
  done < <(find "$base" -mindepth 1 -maxdepth 1 -type d -print0 | sort -z)
  return "$status"
}

ensure_claude_worktree() {
  local root="$1"
  local name="$2"
  local target="${root}/.claude/worktrees/${name}"
  local branch="worktree-${name}"
  local base
  local git_wrapper="${VBR_CLAUDE_GIT_WRAPPER_FOR_TEST:-${SCRIPT_DIR}/git}"

  if [[ -e "$target/.git" ]]; then
    if "$real_git" -C "$target" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
      printf '%s\n' "$target"
      return 0
    fi
    echo "Error: existing Claude worktree path is not a valid git worktree: ${target}" >&2
    return 1
  fi

  if [[ -e "$target" ]]; then
    echo "Error: Claude worktree path already exists but is not a git worktree: ${target}" >&2
    return 1
  fi

  if [[ ! -x "$git_wrapper" ]]; then
    echo "Error: git CoW wrapper not found: ${git_wrapper}" >&2
    return 127
  fi

  mkdir -p -- "$(dirname -- "$target")"
  if git_branch_exists "$branch"; then
    (
      cd -- "$root"
      "$git_wrapper" worktree add "$target" "$branch" >&2
    )
  else
    base="$(git_worktree_base)"
    (
      cd -- "$root"
      "$git_wrapper" worktree add -b "$branch" "$target" "$base" >&2
    )
  fi
  printf '%s\n' "$target"
}

should_safehouse_claude() {
  local mode="${VBR_CLAUDE_SAFEHOUSE:-auto}"
  local root="$1"

  if [[ "${VBR_CLAUDE_SAFEHOUSE_ACTIVE:-}" == "1" ]]; then
    if [[ -n "${VBR_CLAUDE_SAFEHOUSE_ROOT:-}" && "$(real_path "$root")" != "$(real_path "$VBR_CLAUDE_SAFEHOUSE_ROOT")" ]]; then
      echo "Error: cannot launch Claude worktree agent from inside another Safehouse sandbox: $root" >&2
      echo "Hint: macOS sandbox-exec cannot apply a nested sandbox; launch the parent without VBR_CLAUDE_SAFEHOUSE=always." >&2
      exit 126
    fi
    return 1
  fi
  [[ "$mode" == "0" || "$mode" == "false" || "$mode" == "off" ]] && return 1
  [[ "$mode" == "1" || "$mode" == "true" || "$mode" == "always" ]] && return 0
  if [[ "$mode" == "auto" ]] && is_worker_worktree "$root"; then
    return 0
  fi
  return 1
}

is_worker_worktree() {
  local root="$1"
  case "$root" in
    */.claude/worktrees/*|*/.codex/worktrees/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

sandbox_string_escape() {
  local value="$1"
  value="${value//\\/\\\\}"
  value="${value//\"/\\\"}"
  printf '%s\n' "$value"
}

real_path() {
  local path="$1"
  cd -- "$path" 2>/dev/null && pwd -P
}

write_home_deny_profile() {
  local profile="$1"
  local known_hosts="${2:-}"
  local home_real=""
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  [[ -n "$home_real" ]] || return 0
  local escaped_home
  escaped_home="$(sandbox_string_escape "$home_real")"
  local escaped_known_hosts=""
  if [[ -n "$known_hosts" ]]; then
    escaped_known_hosts="$(sandbox_string_escape "$known_hosts")"
  fi
  {
    printf '(deny file-read-data (literal "%s"))\n' "$escaped_home"
    printf '(deny file-write* (literal "%s"))\n' "$escaped_home"
    printf '(allow file-read-metadata (literal "%s") (literal "%s/.gitconfig") (literal "%s/.config") (literal "%s/.config/git") (literal "%s/.config/git/config") (literal "%s/.ssh"))\n' "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home" "$escaped_home"
    if [[ -n "$escaped_known_hosts" ]]; then
      printf '(allow file-read* (literal "%s"))\n' "$escaped_known_hosts"
    fi
    printf '(allow file-read-metadata (literal "/etc") (literal "/etc/bashrc") (literal "/etc/profile") (literal "/etc/static") (literal "/etc/static/bashrc") (literal "/etc/nix") (literal "/nix") (literal "/nix/var") (literal "/nix/var/nix") (literal "/nix/var/nix/daemon-socket") (literal "/var") (literal "/var/db") (literal "/private") (literal "/private/etc") (literal "/private/etc/bashrc") (literal "/private/etc/profile") (literal "/private/etc/static") (literal "/private/etc/static/bashrc") (literal "/private/etc/nix") (literal "/private/var") (literal "/private/var/db"))\n'
    printf '(allow file-read-metadata (literal "/Applications") (literal "/Applications/Xcode.app") (literal "/Applications/Xcode.app/Contents") (literal "/Applications/Xcode.app/Contents/Developer"))\n'
    printf '(allow file-read* (literal "/var/db/xcode_select_link") (literal "/private/var/db/xcode_select_link"))\n'
    printf '(allow file-read* (literal "/nix/var/nix/daemon-socket/socket") (literal "/etc/bashrc") (literal "/private/etc/bashrc") (literal "/etc/profile") (literal "/private/etc/profile") (literal "/etc/static/bashrc") (literal "/private/etc/static/bashrc") (literal "/etc/nix") (literal "/private/etc/nix"))\n'
    printf '(allow mach-lookup (global-name "com.apple.sysmond"))\n'
    printf '(allow process-info*)\n'
    printf '(allow signal)\n'
  } >"$profile"
}

safehouse_known_hosts_path() {
  local home_real="$1"
  [[ -n "$home_real" ]] || return 0
  local candidate="$home_real/.ssh/known_hosts"
  [[ -f "$candidate" ]] || return 0
  cd -- "$(dirname -- "$candidate")" 2>/dev/null || return 0
  printf '%s/%s\n' "$(pwd -P)" "$(basename -- "$candidate")"
}

nix_safehouse_readonly_paths() {
  local paths=("/nix/store" "/var/run/nix-daemon.socket")
  local developer_dir=""
  [[ -e "/nix/var/nix/daemon-socket/socket" ]] && paths+=("/nix/var/nix/daemon-socket/socket")
  [[ -e "/etc/nix" ]] && paths+=("/etc/nix")
  if [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]]; then
    paths+=("/private/var/run/nix-daemon.socket")
    [[ -e "/etc/bashrc" ]] && paths+=("/etc/bashrc")
    [[ -e "/private/etc/bashrc" ]] && paths+=("/private/etc/bashrc")
    [[ -e "/etc/profile" ]] && paths+=("/etc/profile")
    [[ -e "/private/etc/profile" ]] && paths+=("/private/etc/profile")
    [[ -e "/etc/static/bashrc" ]] && paths+=("/etc/static/bashrc")
    [[ -e "/private/etc/static/bashrc" ]] && paths+=("/private/etc/static/bashrc")
    [[ -e "/private/etc/nix" ]] && paths+=("/private/etc/nix")
    [[ -e "/var/db/xcode_select_link" ]] && paths+=("/var/db/xcode_select_link")
    [[ -e "/private/var/db/xcode_select_link" ]] && paths+=("/private/var/db/xcode_select_link")
    developer_dir="$(xcode-select -p 2>/dev/null || true)"
    if [[ -z "$developer_dir" ]]; then
      developer_dir="/Applications/Xcode.app/Contents/Developer"
    fi
    [[ -e "$developer_dir" ]] && paths+=("$developer_dir")
  fi
  local IFS=:
  printf '%s\n' "${paths[*]}"
}

run_claude_in_safehouse() {
  local root="$1"
  shift
  local claude_config_dir=""
  local claude_config_args=()
  local home_real=""
  local known_hosts=""
  local nix_bin
  local profile
  local root_real
  local safehouse_tmp
  local safehouse_cache_parent
  local safehouse_cache
  local safehouse_home
  local nix_ro_paths
  local safehouse_path="${PATH:-}"
  local status
  root_real="$(real_path "$root")"
  if [[ -n "${HOME:-}" ]]; then
    home_real="$(cd -- "$HOME" 2>/dev/null && pwd -P || true)"
  fi
  known_hosts="$(safehouse_known_hosts_path "$home_real")"
  if [[ -n "${CLAUDE_CONFIG_DIR:-}" ]]; then
    case "$CLAUDE_CONFIG_DIR" in
      /*) claude_config_dir="$CLAUDE_CONFIG_DIR" ;;
      *) claude_config_dir="$root_real/$CLAUDE_CONFIG_DIR" ;;
    esac
  elif [[ -n "$home_real" ]]; then
    claude_config_dir="$home_real/.claude"
  fi
  safehouse_tmp="$root_real/buck-out/tmp"
  safehouse_cache_parent="$safehouse_tmp/safehouse-cache"
  safehouse_cache="$root_real/buck-out/tmp/safehouse-cache/xdg"
  safehouse_home="$root_real/buck-out/tmp/safehouse-home"
  mkdir -p -- "$root_real/buck-out"
  mark_macos_metadata_never_index "$root_real/buck-out"
  mkdir -p -- "$safehouse_tmp"
  mark_macos_metadata_never_index "$safehouse_tmp"
  mkdir -p -- "$safehouse_cache_parent"
  mark_macos_metadata_never_index "$safehouse_cache_parent"
  mkdir -p -- "$safehouse_cache" "$safehouse_home"
  mark_macos_metadata_never_index \
    "$safehouse_cache" \
    "$safehouse_home"
  rm -f -- "$safehouse_home/.ssh/known_hosts" 2>/dev/null || true
  if [[ -n "$known_hosts" ]]; then
    mkdir -p -- "$safehouse_home/.ssh"
    mark_macos_metadata_never_index "$safehouse_home/.ssh"
    ln -s -- "$known_hosts" "$safehouse_home/.ssh/known_hosts"
  fi
  if [[ -n "$claude_config_dir" ]]; then
    mkdir -p -- "$claude_config_dir" 2>/dev/null || true
    if [[ -d "$claude_config_dir" ]]; then
      rm -rf -- "$safehouse_home/.claude"
      ln -s -- "$claude_config_dir" "$safehouse_home/.claude"
      claude_config_args=(--add-dirs="$claude_config_dir")
    fi
  fi
  nix_ro_paths="$(nix_safehouse_readonly_paths)"
  nix_bin="$(find_tool_excluding_wrapper_dir nix || true)"
  if [[ -n "$nix_bin" ]]; then
    safehouse_path="$(dirname -- "$nix_bin"):${safehouse_path}"
  fi
  profile="$(mktemp "${TMPDIR:-/tmp}/vbr-claude-safehouse.XXXXXX")"
  write_home_deny_profile "$profile" "$known_hosts"
  set +e
  env \
    VBR_CLAUDE_SAFEHOUSE_ACTIVE=1 \
    VBR_CLAUDE_SAFEHOUSE_ROOT="$root_real" \
    CLAUDE_CONFIG_DIR="$claude_config_dir" \
    DISABLE_AUTOUPDATER=1 \
    HOME="$safehouse_home" \
    NIX_DAEMON_SOCKET_PATH="/var/run/nix-daemon.socket" \
    NIX_REMOTE="daemon" \
    PATH="$safehouse_path" \
    BUCK2_REAL_HOME="$safehouse_home" \
    XDG_CACHE_HOME="$safehouse_cache" \
    "$safehouse" \
    --workdir="$root_real" \
    ${claude_config_args[@]+"${claude_config_args[@]}"} \
    --add-dirs-ro="$nix_ro_paths" \
    ${known_hosts:+--add-dirs-ro="$known_hosts"} \
    --append-profile="$profile" \
    --env \
    "$real_claude" \
    "$@"
  status=$?
  set -e
  rm -f -- "$profile"
  exit "$status"
}

root="$(git_root || pwd -P)"
parse_claude_worktree_args "$@"

operation_count=0
[[ "$LIST_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))
[[ "$WORKTREE_REQUESTED" == "1" ]] && operation_count=$((operation_count + 1))

if [[ "$operation_count" -gt 1 ]]; then
  echo "Error: worktree management flags cannot be combined" >&2
  exit 2
fi

if [[ "$FORCE_REMOVE_WORKTREE" == "1" && "$REMOVE_WORKTREE_REQUESTED" != "1" && "$REMOVE_ALL_WORKTREES_REQUESTED" != "1" ]]; then
  echo "Error: --force can only be combined with --remove-worktree or --remove-all-worktrees" >&2
  exit 2
fi

if [[ "$LIST_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot list Claude worktrees" >&2
    exit 127
  fi
  list_claude_worktrees "$root"
  exit 0
fi

if [[ "$REMOVE_WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Claude worktree" >&2
    exit 127
  fi
  if [[ -z "$REMOVE_WORKTREE_NAME" ]]; then
    echo "Error: --remove-worktree requires a worktree name" >&2
    exit 2
  fi
  remove_claude_worktree "$root" "$REMOVE_WORKTREE_NAME" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$REMOVE_ALL_WORKTREES_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot remove Claude worktrees" >&2
    exit 127
  fi
  remove_all_claude_worktrees "$root" "$FORCE_REMOVE_WORKTREE"
  exit $?
fi

if [[ "$WORKTREE_REQUESTED" == "1" ]]; then
  if [[ -z "$real_git" ]]; then
    echo "Error: git binary not found; cannot create Claude worktree" >&2
    exit 127
  fi
  if [[ -z "$WORKTREE_NAME" ]]; then
    WORKTREE_NAME="$(default_worktree_name)"
  fi
  validate_worktree_name "$WORKTREE_NAME"
  if root="$(ensure_claude_worktree "$root" "$WORKTREE_NAME")"; then
    :
  else
    exit $?
  fi
  # Re-enter from the worktree so first launch and later --resume use the same Safehouse path.
  cd -- "$root"
  exec "$SCRIPT_PATH" "${CLAUDE_ARGS[@]}"
fi

if should_safehouse_claude "$root"; then
  safehouse="$(find_tool_excluding_wrapper_dir safehouse || true)"
  if [[ -z "$safehouse" ]]; then
    echo "Error: safehouse not found; refusing to launch unsandboxed Claude: $root" >&2
    echo "Hint: run through the Nix dev shell so agent-safehouse is on PATH, or set VBR_CLAUDE_SAFEHOUSE=0 to bypass." >&2
    exit 127
  fi

  if is_worker_worktree "$root"; then
    if claude_args_request_skip_permissions "${CLAUDE_ARGS[@]}"; then
      run_claude_in_safehouse "$root" "${CLAUDE_ARGS[@]}"
    else
      run_claude_in_safehouse "$root" --dangerously-skip-permissions "${CLAUDE_ARGS[@]}"
    fi
  fi

  run_claude_in_safehouse "$root" "${CLAUDE_ARGS[@]}"
fi

exec env DISABLE_AUTOUPDATER=1 "$real_claude" "${CLAUDE_ARGS[@]}"
