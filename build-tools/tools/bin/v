#!/usr/bin/env bash
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
case "${1:-}" in
	-h|--help)
		exec "${SCRIPT_DIR}/verify" "$@"
		;;
esac

# shell helpers
# shellcheck source=/dev/null
. "${SCRIPT_DIR}/devshell.sh"

cleanup_verify_root_buck_out() {
	local allow_broad_buck_cleanup="${1:-0}"
	local cleanup_root="${2:-${LIVE_ROOT}}"
	local buck_out="${cleanup_root}/buck-out"
	if [[ "${allow_broad_buck_cleanup}" == "1" && -d "${cleanup_root}" ]] && command -v buck2 >/dev/null 2>&1; then
		(cd "${cleanup_root}" && timeout 10s buck2 kill >/dev/null 2>&1) || true
	fi
	[[ -d "${buck_out}" ]] || return 0
	local entry base owner_pid
	for entry in "${buck_out}"/* "${buck_out}"/.[!.]* "${buck_out}"/..?*; do
		[[ -e "${entry}" ]] || continue
		base="$(basename "${entry}")"
		case "${base}" in
			v-*|verify-nested-*)
				owner_pid=""
				case "${base}" in
					v-*-*) owner_pid="${base#v-}"; owner_pid="${owner_pid%%-*}" ;;
					verify-nested-*-*) owner_pid="${base#verify-nested-}"; owner_pid="${owner_pid%%-*}" ;;
				esac
				[[ "${owner_pid}" =~ ^[0-9]+$ ]] || continue
				if [[ "${owner_pid}" =~ ^[0-9]+$ ]] && kill -0 "${owner_pid}" >/dev/null 2>&1; then
					continue
				fi
				if registered_isolation_owner_alive "${base}" "${cleanup_root}"; then
					continue
				fi
				if command -v buck2 >/dev/null 2>&1; then
					(cd "${cleanup_root}" && timeout 10s buck2 --isolation-dir "${base}" kill >/dev/null 2>&1) || true
				fi
				rm -rf "${entry}" 2>/dev/null || true
				;;
			test-logs|tmp|zx_shims|v2|deployment-query-*|zxtest-shared-*|exporter-shared-*)
				[[ "${allow_broad_buck_cleanup}" == "1" ]] || continue
				if command -v buck2 >/dev/null 2>&1; then
					if [[ "${base}" == "v2" ]]; then
						(cd "${cleanup_root}" && timeout 10s buck2 kill >/dev/null 2>&1) || true
					else
						(cd "${cleanup_root}" && timeout 10s buck2 --isolation-dir "${base}" kill >/dev/null 2>&1) || true
					fi
				fi
				rm -rf "${entry}" 2>/dev/null || true
				;;
		esac
	done
	rmdir "${buck_out}" 2>/dev/null || true
}

cleanup_verify_owned_buck_out_roots() {
	local allow_broad_buck_cleanup="${1:-0}"
	cleanup_verify_root_buck_out "${allow_broad_buck_cleanup}" "${LIVE_ROOT}"
	if [[ -n "${VIBEROOTS_ROOT:-}" && "${VIBEROOTS_ROOT}" != "${LIVE_ROOT}" && -f "${VIBEROOTS_ROOT}/build-tools/tools/dev/zx-init.mjs" ]]; then
		cleanup_verify_root_buck_out "${allow_broad_buck_cleanup}" "${VIBEROOTS_ROOT}"
	fi
}

registered_isolation_owner_alive() {
	local iso="$1"
	local cleanup_root="${2:-${LIVE_ROOT}}"
	local state_file="${VBR_VERIFY_PROCESS_STATE_FILE:-${VBR_BUCK_REAPER_STATE_FILE:-}}"
	[[ -n "${state_file}" && -f "${state_file}" ]] || return 1
	local line owner_pid
	while IFS= read -r line; do
		[[ "${line}" == isolation$'\t'* ]] || continue
		[[ "${line}" == *"\"iso\":\"${iso}\""* ]] || continue
		[[ "${line}" == *"\"repoRoot\":\"${cleanup_root}\""* ]] || continue
		owner_pid="${line#*\"ownerPid\":}"
		owner_pid="${owner_pid%%,*}"
		if [[ "${owner_pid}" =~ ^[0-9]+$ ]] && kill -0 "${owner_pid}" >/dev/null 2>&1; then
			return 0
		fi
	done <"${state_file}"
	return 1
}

status=0
cleanup_verify_owned_buck_out_roots "${VBR_VERIFY_BROAD_BUCK_OUT_CLEANUP:-0}"
"${SCRIPT_DIR}/verify" "$@" || status="$?"
cleanup_verify_owned_buck_out_roots "${VBR_VERIFY_BROAD_BUCK_OUT_CLEANUP:-0}"
exit "${status}"
