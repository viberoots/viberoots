#!/usr/bin/env bash
set -euo pipefail
case "${1:-}" in
	-h|--help)
		cat <<'EOF'
usage: v [options] [target...]
       verify [options] [target...]

Run workspace verification.

options:
  --coverage
  --console <auto|super|simple>
  --selector <default|project-closure>
  --project <name>
  --projects <name[,name...]>
  --explain-selection
  -h, --help
EOF
		exit 0
		;;
esac

# shell helpers
# shellcheck source=/dev/null
. "$(cd "$(dirname "$0")" && pwd)/devshell.sh"

# Substantive logic lives in TypeScript (zx). Keep this wrapper tiny for file-size linting.
run_ts "../dev/verify.ts" "$@"
