#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd -P)/$(basename -- "${BASH_SOURCE[0]}")"

mark_macos_metadata_never_index() {
  [[ "$(uname -s 2>/dev/null || true)" == "Darwin" ]] || return 0
  local dir
  for dir in "$@"; do
    [[ -n "$dir" ]] || continue
    [[ -e "${dir}/.metadata_never_index" ]] || : > "${dir}/.metadata_never_index" 2>/dev/null || true
  done
}

is_same_file() {
  local a="$1"
  local b="$2"
  [[ -e "$a" && -e "$b" ]] || return 1
  [[ "$(cd -- "$(dirname -- "$a")" && pwd -P)/$(basename -- "$a")" == "$(cd -- "$(dirname -- "$b")" && pwd -P)/$(basename -- "$b")" ]]
}

resolve_symlink_path() {
  local p="$1"
  local dir
  local link
  local limit=0
  while [[ -L "$p" && "$limit" -lt 40 ]]; do
    dir="$(cd -- "$(dirname -- "$p")" && pwd -P)"
    link="$(readlink "$p")"
    if [[ "$link" == /* ]]; then
      p="$link"
    else
      p="${dir}/${link}"
    fi
    limit=$((limit + 1))
  done
  printf '%s\n' "$p"
}

is_nix_store_git() {
  local candidate="$1"
  local resolved
  resolved="$(resolve_symlink_path "$candidate")"
  [[ "$candidate" == /nix/store/*/bin/git || "$resolved" == /nix/store/*/bin/git ]]
}

resolve_real_git() {
  if [[ -n "${VBR_REAL_GIT:-}" ]]; then
    if [[ ! -x "${VBR_REAL_GIT}" ]]; then
      echo "git wrapper: VBR_REAL_GIT is not executable: ${VBR_REAL_GIT}" >&2
      return 127
    fi
    if is_same_file "${VBR_REAL_GIT}" "${SCRIPT_PATH}"; then
      echo "git wrapper: VBR_REAL_GIT points back to this wrapper: ${VBR_REAL_GIT}" >&2
      return 127
    fi
    printf '%s\n' "${VBR_REAL_GIT}"
    return 0
  fi

  local old_ifs="$IFS"
  local dir
  IFS=':'
  for dir in ${PATH:-}; do
    [[ -n "$dir" ]] || continue
    local candidate="${dir}/git"
    [[ -x "$candidate" ]] || continue
    is_same_file "$candidate" "$SCRIPT_PATH" && continue
    if is_nix_store_git "$candidate"; then
      printf '%s\n' "$candidate"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"

  echo "git wrapper: could not find flake-provided git on PATH; run inside the Nix dev shell or set VBR_REAL_GIT" >&2
  return 127
}

is_nix_store_python() {
  local candidate="$1"
  local resolved
  resolved="$(resolve_symlink_path "$candidate")"
  [[ "$candidate" == /nix/store/*/bin/python3 || "$resolved" == /nix/store/*/bin/python3 ]]
}

resolve_python3() {
  if [[ -n "${VBR_PYTHON_BIN:-}" ]]; then
    if [[ ! -x "${VBR_PYTHON_BIN}" ]] || ! is_nix_store_python "${VBR_PYTHON_BIN}"; then
      echo "git wrapper: VBR_PYTHON_BIN must be an executable /nix/store python3: ${VBR_PYTHON_BIN}" >&2
      return 127
    fi
    printf '%s\n' "${VBR_PYTHON_BIN}"
    return 0
  fi

  local old_ifs="$IFS"
  local dir
  IFS=':'
  for dir in ${PATH:-}; do
    [[ -n "$dir" ]] || continue
    local candidate="${dir}/python3"
    if [[ -x "$candidate" ]] && is_nix_store_python "$candidate"; then
      printf '%s\n' "$candidate"
      IFS="$old_ifs"
      return 0
    fi
  done
  IFS="$old_ifs"

  echo "git wrapper: could not find Nix-store python3 on PATH; run inside the Nix dev shell" >&2
  return 127
}

is_worktree_add() {
  [[ "${1:-}" == "worktree" && "${2:-}" == "add" ]]
}

PARSED_TARGET=""
parse_worktree_add_target() {
  PARSED_TARGET=""
  while [[ "$#" -gt 0 ]]; do
    local token="$1"
    shift

    case "$token" in
      --)
        [[ "$#" -gt 0 ]] || return 2
        PARSED_TARGET="$1"
        return 0
        ;;
      -b|-B|--reason)
        [[ "$#" -gt 0 ]] || return 2
        shift
        continue
        ;;
      -b?*|-B?*|--reason=*)
        continue
        ;;
      -f|--force|-d|--detach|--lock|--no-checkout|--guess-remote|--no-guess-remote|--track|--no-track|-q|--quiet|--relative-paths|--no-relative-paths)
        continue
        ;;
      --checkout|--orphan)
        return 2
        ;;
      -*)
        return 2
        ;;
      *)
        PARSED_TARGET="$token"
        return 0
        ;;
    esac
  done
  return 2
}

cow_copy_tree() {
  local src="$1"
  local dst="$2"
  local manifest="$3"

  if [[ -n "${VBR_GIT_COW_COPY_PROG_FOR_TEST:-}" ]]; then
    "${VBR_GIT_COW_COPY_PROG_FOR_TEST}" "$src" "$dst" "$manifest"
    return $?
  fi

  local python3_bin
  python3_bin="$(resolve_python3)"
  local ostype="${VBR_GIT_COW_OSTYPE:-${OSTYPE:-}}"
  if [[ "$ostype" == darwin* ]]; then
    "$python3_bin" - "$src" "$dst" "$manifest" <<'PY'
import ctypes
import os
import shutil
import stat
import sys

src_root = sys.argv[1]
dst_root = sys.argv[2]
manifest = sys.argv[3]
rel_excluded_roots = [os.path.join(".claude", "worktrees"), os.path.join(".codex", "worktrees")]
libc = ctypes.CDLL(None, use_errno=True)
clonefile = libc.clonefile
clonefile.argtypes = [ctypes.c_char_p, ctypes.c_char_p, ctypes.c_int]
clonefile.restype = ctypes.c_int

def is_unsafe_relpath(rel):
    return rel == "" or os.path.isabs(rel) or rel == ".." or rel.startswith(".." + os.sep)

def is_rel_excluded(rel):
    return any(rel == root or rel.startswith(root + os.sep) for root in rel_excluded_roots)

def clone_entry(rel):
    if is_unsafe_relpath(rel) or is_rel_excluded(rel):
        return
    src = os.path.join(src_root, rel)
    dst = os.path.join(dst_root, rel)
    try:
        st = os.lstat(src)
    except FileNotFoundError:
        return

    parent = os.path.dirname(dst)
    if parent:
        os.makedirs(parent, exist_ok=True)

    if stat.S_ISLNK(st.st_mode):
        os.symlink(os.readlink(src), dst)
        return
    if stat.S_ISDIR(st.st_mode):
        os.makedirs(dst, exist_ok=True)
        os.chmod(dst, stat.S_IMODE(st.st_mode) | 0o700)
        return
    if not stat.S_ISREG(st.st_mode):
        raise RuntimeError(f"unsupported file type: {src}")

    rc = clonefile(src.encode(), dst.encode(), 0)
    if rc != 0:
        err = ctypes.get_errno()
        raise OSError(err, os.strerror(err), src)
    os.chmod(dst, stat.S_IMODE(st.st_mode) | 0o600)

if os.path.exists(dst_root):
    shutil.rmtree(dst_root)
os.makedirs(dst_root, exist_ok=True)

with open(manifest, "rb") as f:
    for raw in f.read().split(b"\0"):
        if raw:
            clone_entry(raw.decode("utf-8", "surrogateescape"))
PY
  else
    "$python3_bin" - "$src" "$dst" "$manifest" <<'PY'
import fcntl
import os
import shutil
import stat
import sys

FICLONE = 0x40049409
src_root = sys.argv[1]
dst_root = sys.argv[2]
manifest = sys.argv[3]
rel_excluded_roots = [os.path.join(".claude", "worktrees"), os.path.join(".codex", "worktrees")]

def is_unsafe_relpath(rel):
    return rel == "" or os.path.isabs(rel) or rel == ".." or rel.startswith(".." + os.sep)

def is_rel_excluded(rel):
    return any(rel == root or rel.startswith(root + os.sep) for root in rel_excluded_roots)

def reflink(src, dst, mode):
    src_fd = os.open(src, os.O_RDONLY)
    try:
        dst_fd = os.open(dst, os.O_WRONLY | os.O_CREAT | os.O_EXCL, mode | 0o600)
        try:
            fcntl.ioctl(dst_fd, FICLONE, src_fd)
        except OSError:
            os.close(dst_fd)
            try:
                os.unlink(dst)
            except FileNotFoundError:
                pass
            raise
        else:
            os.close(dst_fd)
    finally:
        os.close(src_fd)

def clone_entry(rel):
    if is_unsafe_relpath(rel) or is_rel_excluded(rel):
        return
    src = os.path.join(src_root, rel)
    dst = os.path.join(dst_root, rel)
    try:
        st = os.lstat(src)
    except FileNotFoundError:
        return

    parent = os.path.dirname(dst)
    if parent:
        os.makedirs(parent, exist_ok=True)

    if stat.S_ISLNK(st.st_mode):
        os.symlink(os.readlink(src), dst)
        return
    if stat.S_ISDIR(st.st_mode):
        os.makedirs(dst, exist_ok=True)
        os.chmod(dst, stat.S_IMODE(st.st_mode) | 0o700)
        return
    if not stat.S_ISREG(st.st_mode):
        raise RuntimeError(f"unsupported file type: {src}")

    reflink(src, dst, stat.S_IMODE(st.st_mode))
    os.chmod(dst, stat.S_IMODE(st.st_mode) | 0o600)

if os.path.exists(dst_root):
    shutil.rmtree(dst_root)
os.makedirs(dst_root, exist_ok=True)

with open(manifest, "rb") as f:
    for raw in f.read().split(b"\0"):
        if raw:
            clone_entry(raw.decode("utf-8", "surrogateescape"))
PY
  fi
}

move_staged_contents() {
  local staged_repo="$1"
  local target="$2"
  find "$staged_repo" -mindepth 1 -maxdepth 1 -exec mv {} "$target"/ \;
}

write_cow_copy_manifest() {
  local real_git="$1"
  local source_root="$2"
  local manifest="$3"
  local rel

  "$real_git" -C "$source_root" ls-files -z --cached --others --exclude-standard |
    while IFS= read -r -d '' rel; do
      case "$rel" in
        .claude/worktrees|.claude/worktrees/*|.codex/worktrees|.codex/worktrees/*)
          continue
          ;;
      esac
      printf '%s\0' "$rel"
    done > "$manifest"
}

cleanup_partial_worktree() {
  local real_git="$1"
  local target="$2"
  local stage="$3"
  if [[ -n "$stage" ]]; then
    rm -rf -- "$stage"
    rm -rf -- "$(dirname -- "$stage")"
  fi
  if [[ -n "$target" ]]; then
    "$real_git" worktree remove --force "$target" >/dev/null 2>&1 || true
    rm -rf -- "$target"
  fi
}

run_cow_worktree_add() {
  local real_git="$1"
  shift
  local args=("$@")
  local target="$PARSED_TARGET"
  local source_root
  local target_parent
  local target_abs
  local stage_parent=""
  local stage=""
  local staged_repo=""
  local manifest=""

  source_root="$(pwd -P)"

  if "$real_git" worktree add --no-checkout "${args[@]}"; then
    :
  else
    return $?
  fi

  target_parent="$(cd -- "$(dirname -- "$target")" && pwd -P)"
  target_abs="${target_parent}/$(basename -- "$target")"
  stage_parent="${target_parent}/.git-cow-stage.noindex"
  mkdir -p -- "$stage_parent"
  mark_macos_metadata_never_index "$stage_parent"
  stage="$(mktemp -d "${stage_parent}/stage.XXXXXX")"
  mark_macos_metadata_never_index "$stage"
  staged_repo="${stage}/repo"
  manifest="${stage}/paths.zlist"

  if write_cow_copy_manifest "$real_git" "$source_root" "$manifest"; then
    :
  else
    local status=$?
    cleanup_partial_worktree "$real_git" "$target_abs" "$stage"
    return "$status"
  fi

  if cow_copy_tree "$source_root" "$staged_repo" "$manifest"; then
    :
  else
    local status=$?
    cleanup_partial_worktree "$real_git" "$target_abs" "$stage"
    return "$status"
  fi

  rm -rf -- "${staged_repo}/.git"

  if move_staged_contents "$staged_repo" "$target_abs"; then
    :
  else
    local status=$?
    cleanup_partial_worktree "$real_git" "$target_abs" "$stage"
    return "$status"
  fi

  rm -rf -- "$stage"
  rm -rf -- "$stage_parent"

  if "$real_git" -C "$target_abs" reset --mixed -q HEAD >/dev/null; then
    :
  else
    local status=$?
    cleanup_partial_worktree "$real_git" "$target_abs" ""
    return "$status"
  fi

  echo "Success: CoW worktree ready: ${target_abs}"
}

main() {
  local real_git
  real_git="$(resolve_real_git)"

  if is_worktree_add "$@"; then
    shift 2
    if parse_worktree_add_target "$@"; then
      echo "Using CoW worktree copy for: ${PARSED_TARGET}"
      run_cow_worktree_add "$real_git" "$@"
      return $?
    fi
    exec "$real_git" worktree add "$@"
  fi

  exec "$real_git" "$@"
}

main "$@"
