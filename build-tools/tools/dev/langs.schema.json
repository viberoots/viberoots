{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Languages Manifest Schema",
  "type": ["array", "object"],
  "definitions": {
    "lang": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "displayName", "requiredPaths", "kinds", "templatesDir", "hermetic"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "requiredPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "optionalPaths": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "kinds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "templatesDir": { "type": "string", "minLength": 1 },
        "hermetic": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "sourceRoles",
            "dependencyReconciliation",
            "immutableBundleInputs",
            "storeQualifiedToolchain",
            "selectorTransport",
            "sandboxNetwork",
            "remoteExecution",
            "publicationAdmission",
            "reproducibilityMatrixIds"
          ],
          "properties": {
            "status": { "enum": ["scaffold", "graduated"] },
            "sourceRoles": { "type": "boolean" },
            "dependencyReconciliation": { "type": "boolean" },
            "immutableBundleInputs": { "type": "boolean" },
            "storeQualifiedToolchain": { "type": "boolean" },
            "selectorTransport": { "type": "boolean" },
            "sandboxNetwork": { "type": "boolean" },
            "remoteExecution": { "type": "boolean" },
            "publicationAdmission": { "type": "boolean" },
            "reproducibilityMatrixIds": {
              "type": "array",
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "allOf": [
            {
              "if": { "properties": { "status": { "const": "graduated" } } },
              "then": {
                "properties": {
                  "sourceRoles": { "const": true },
                  "dependencyReconciliation": { "const": true },
                  "immutableBundleInputs": { "const": true },
                  "storeQualifiedToolchain": { "const": true },
                  "selectorTransport": { "const": true },
                  "sandboxNetwork": { "const": true },
                  "remoteExecution": { "const": true },
                  "publicationAdmission": { "const": true },
                  "reproducibilityMatrixIds": { "minItems": 1 }
                }
              }
            }
          ]
        }
      }
    }
  },
  "oneOf": [
    {
      "type": "array",
      "items": { "$ref": "#/definitions/lang" }
    },
    {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": {
          "type": "array",
          "items": { "type": "string" }
        },
        "languages": {
          "type": "array",
          "items": { "$ref": "#/definitions/lang" }
        }
      }
    }
  ]
}
