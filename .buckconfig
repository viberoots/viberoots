[buildfile]
name = TARGETS

[repositories]
root = .
viberoots = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./config/fbsource_stub
fbcode = ./config/fbcode_stub
config = ./config
workspace_providers = ./config/workspace_providers
workspace_buck = ./config/workspace_buck

[cells]
root = .
viberoots = .
prelude = ./prelude
toolchains = ./toolchains
repo_toolchains = ./toolchains
fbsource = ./config/fbsource_stub
fbcode = ./config/fbcode_stub
config = ./config
workspace_providers = ./config/workspace_providers
workspace_buck = ./config/workspace_buck

[build]
prelude = prelude
user_platform = prelude//platforms:default
target_platforms = prelude//platforms:default

[project]
ignore = buck-out/tmp,.viberoots/buck/tmp,.viberoots/workspace/buck/tmp,.claude/worktrees,.codex/worktrees
