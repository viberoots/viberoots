{
  "schemaVersion": "viberoots-project-config@1",
  "environments": {
    "staging": {
      "infisicalEnvironment": "staging"
    },
    "prod": {
      "infisicalEnvironment": "prod"
    }
  },
  "runtimeHosts": {
    "local-macos": {
      "backend": "macos-keychain",
      "service": "viberoots-bootstrap"
    },
    "local-file": {
      "backend": "local-file"
    },
    "github-actions": {
      "backend": "github-actions",
      "scope": "repository",
      "namePrefix": "VIBEROOTS_"
    },
    "jenkins": {
      "backend": "jenkins",
      "scope": "repository",
      "namePrefix": "VIBEROOTS_"
    },
    "gitlab-ci": {
      "backend": "gitlab-ci",
      "scope": "repository",
      "namePrefix": "VIBEROOTS_"
    },
    "bitbucket-pipelines": {
      "backend": "bitbucket-pipelines",
      "scope": "repository",
      "namePrefix": "VIBEROOTS_"
    }
  },
  "controlPlanes": {
    "pleomino-prod": {
      "serviceClient": {
        "controlPlaneUrl": "https://control-plane.viberoots.example",
        "controlPlaneTokenRef": "secret://control-plane/pleomino/prod/service-token"
      },
      "records": {
        "backend": "service"
      }
    },
    "pleomino-staging": {
      "serviceClient": {
        "controlPlaneUrl": "https://staging.control-plane.viberoots.example",
        "controlPlaneTokenRef": "secret://control-plane/pleomino/staging/service-token"
      },
      "records": {
        "backend": "service"
      }
    }
  },
  "deploymentContexts": {
    "pleomino-prod": {
      "controlPlane": "pleomino-prod",
      "secretBackend": "infisical/default",
      "aws": {
        "accountId": "",
        "organizationId": "",
        "defaultRegion": "us-west-2"
      },
      "infisical": {
        "host": "https://app.infisical.com",
        "projectId": "5a927a1a-e78d-433e-affc-17cc051780c0",
        "projectName": "pleomino-deployments",
        "projectSlug": "pleomino-deployments",
        "environment": "prod",
        "defaultPath": "/",
        "clientIdEnv": "PLEOMINO_PROD_INFISICAL_CLIENT_ID",
        "clientSecretEnv": "PLEOMINO_PROD_INFISICAL_CLIENT_SECRET",
        "clientIdRef": "secret://deployments/pleomino/prod/infisical-client-id",
        "clientSecretRef": "secret://deployments/pleomino/prod/infisical-client-secret",
        "clientIdFileName": "pleomino-prod-infisical-client-id",
        "clientSecretFileName": "pleomino-prod-infisical-client-secret",
        "machineIdentityId": "ceca24df-0e8b-457e-a5a8-cf20a122d2da",
        "machineIdentityName": "pleomino-prod-deploy"
      },
      "supabase": {
        "organizationId": "",
        "projectRef": "",
        "region": "us-west-2"
      },
      "cloudflare": {
        "account": "web-platform-prod",
        "accountId": "1b911846f80a89272c0dbaf44f5c810f",
        "projectName": "pleomino-prod-pages",
        "customDomain": "pleomino.com",
        "zoneId": "9411ac5903acb1c2e29b3d4c04ef7e6f",
        "apiTokenRef": "secret://deployments/pleomino/cloudflare_api_token"
      }
    },
    "pleomino-staging": {
      "controlPlane": "pleomino-staging",
      "secretBackend": "infisical/default",
      "infisical": {
        "host": "https://app.infisical.com",
        "projectId": "5a927a1a-e78d-433e-affc-17cc051780c0",
        "projectName": "pleomino-deployments",
        "projectSlug": "pleomino-deployments",
        "environment": "staging",
        "defaultPath": "/",
        "clientIdEnv": "PLEOMINO_STAGING_INFISICAL_CLIENT_ID",
        "clientSecretEnv": "PLEOMINO_STAGING_INFISICAL_CLIENT_SECRET",
        "clientIdRef": "secret://deployments/pleomino/staging/infisical-client-id",
        "clientSecretRef": "secret://deployments/pleomino/staging/infisical-client-secret",
        "clientIdFileName": "pleomino-staging-infisical-client-id",
        "clientSecretFileName": "pleomino-staging-infisical-client-secret",
        "machineIdentityId": "8b9bc77a-ad32-459f-82a9-b72cd7a3530d",
        "machineIdentityName": "pleomino-staging-deploy"
      },
      "cloudflare": {
        "account": "web-platform-staging",
        "accountId": "1b911846f80a89272c0dbaf44f5c810f",
        "projectName": "pleomino-staging-pages",
        "customDomain": "staging.pleomino.com",
        "zoneId": "9411ac5903acb1c2e29b3d4c04ef7e6f",
        "apiTokenRef": "secret://deployments/pleomino/cloudflare_api_token"
      }
    }
  },
  "values": {
    "control-plane": {
      "domain": "viberoots.example"
    }
  },
  "sprinkleref": {
    "version": 1,
    "defaultCategory": "control",
    "categories": {
      "main": {
        "profile": "infisical-default",
        "environment": "staging"
      },
      "control": {
        "profile": "infisical-control",
        "environment": "prod"
      }
    },
    "profiles": {
      "infisical-default": {
        "backend": "infisical",
        "generatedBy": "viberoots-repo-bootstrap",
        "host": "https://app.infisical.com",
        "defaultEnvironment": "staging",
        "defaultPath": "/",
        "projectId": "55d756b1-7523-4025-b144-cc23c20ff156",
        "projectName": "viberoots-deployments",
        "clientIdRef": "secret://viberoots/bootstrap/viberoots-iac-bootstrap/client-id",
        "clientSecretRef": "secret://viberoots/bootstrap/viberoots-iac-bootstrap/client-secret"
      },
      "infisical-control": {
        "backend": "infisical",
        "generatedBy": "viberoots-repo-bootstrap",
        "host": "https://app.infisical.com",
        "defaultEnvironment": "staging",
        "defaultPath": "/",
        "projectId": "55d756b1-7523-4025-b144-cc23c20ff156",
        "projectName": "viberoots-deployments",
        "clientIdRef": "secret://viberoots/bootstrap/viberoots-iac-bootstrap/client-id",
        "clientSecretRef": "secret://viberoots/bootstrap/viberoots-iac-bootstrap/client-secret"
      }
    }
  }
}
