load(
    "//build-tools/deployments:defs.bzl",
    "deployment_admission_policy",
    "deployment_lane_governance",
    "deployment_lane_policy",
    "migration_bundle",
)
load("//projects/deployments/platform-shared:phase0_contracts.bzl", "phase0_readiness_gates")

deployment_lane_governance(
    name = "lane_governance",
    scm_backend = "github",
    repository = "replace-me/platform",
    source_ref_policies = [
        {"stage": "dev", "allowed_refs": "main", "required_checks": "deploy/admission"},
        {"stage": "staging", "allowed_refs": "main,refs/tags/release/*", "required_checks": "deploy/admission"},
        {"stage": "prod", "allowed_refs": "refs/tags/release/*", "required_checks": "deploy/admission"},
    ],
    trusted_reporter_identities = ["repository-role:admin"],
    required_approval_boundaries = [
        {"stage": "staging", "required_approvals": "release-owner"},
        {"stage": "prod", "required_approvals": "release-owner,security-owner"},
    ],
    visibility = ["PUBLIC"],
)

deployment_lane_policy(
    name = "lane",
    defaults = "//projects/deployments:defaults",
    stages = ["dev", "staging", "prod"],
    source_ref_policy = {
        "dev": "main",
        "staging": "main",
        "prod": "refs/tags/release/*",
    },
    allowed_promotion_edges = ["dev->staging", "staging->prod"],
    artifact_reuse_mode = "same_artifact",
    governance_policy = ":lane_governance",
    default_client_profile = "phase0",
    visibility = ["PUBLIC"],
)

deployment_admission_policy(
    name = "dev_release",
    allowed_refs = ["main"],
    required_checks = ["deploy/admission"],
    readiness_gates = phase0_readiness_gates("direct_upload_pilot,connector_internal"),
    artifact_attestation_mode = "recorded_exact_artifact",
    visibility = ["PUBLIC"],
)

deployment_admission_policy(
    name = "staging_release",
    allowed_refs = ["main", "refs/tags/release/*"],
    required_checks = ["deploy/admission"],
    required_approvals = ["release-owner"],
    readiness_gates = phase0_readiness_gates("direct_upload_pilot,connector_demo"),
    artifact_attestation_mode = "recorded_exact_artifact",
    visibility = ["PUBLIC"],
)

deployment_admission_policy(
    name = "prod_release",
    allowed_refs = ["refs/tags/release/*"],
    required_checks = ["deploy/admission"],
    required_approvals = ["release-owner", "security-owner"],
    readiness_gates = phase0_readiness_gates("direct_upload_pilot,connector_demo"),
    artifact_attestation_mode = "recorded_exact_artifact",
    visibility = ["PUBLIC"],
)

migration_bundle(
    name = "migration_bundle",
    migration_sets = [
        "//projects/libs/platform-db:migrations",
        "//projects/libs/data-room-db:migrations",
    ],
    labels = ["kind:migration-bundle", "deployment:migration-bundle", "deployment-component:provision-only"],
    visibility = ["PUBLIC"],
)
